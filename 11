// Inline CSV parser — used when PapaParse CDN is unavailable (offline / blocked)
function _parseCSVFallback(txt){
  const firstLine = txt.split('\n')[0] || '';
  const counts = {',':0,';':0,'\t':0,'|':0};
  for(const ch of firstLine){ if(counts[ch]!==undefined) counts[ch]++; }
  const delim = Object.entries(counts).sort((a,b)=>b[1]-a[1])[0][0];

  function splitRow(line){
    const r=[]; let c='',q=false;
    for(let i=0;i<line.length;i++){
      const ch=line[i];
      if(ch==='"'){ q=!q; }
      else if(ch===delim&&!q){ r.push(c); c=''; }
      else { c+=ch; }
    }
    r.push(c); return r;
  }

  const lines = txt.trim().split(/\r?\n/);
  if(lines.length<2) return {data:[],meta:{fields:[],delimiter:delim},errors:[]};
  const fields = splitRow(lines[0]).map(h=>h.trim().replace(/^"|"$/g,'').trim());
  const data = lines.slice(1).map(line=>{
    const v=splitRow(line); const o={};
    fields.forEach((h,i)=>{ o[h]=(v[i]||'').trim().replace(/^"|"$/g,'').trim(); });
    return o;
  }).filter(r=>Object.values(r).some(v=>v!==''));
  return {data, meta:{fields, delimiter:delim}, errors:[]};
}

function parseCSV(txt){
  // ── 1. Strip BOM (Excel UTF-8 export) ──────────────────
  txt = txt.replace(/^\uFEFF/, '');

  // ── 2. PapaParse — robust multi-delimiter, header-aware ─
  // Use PapaParse if loaded, else inline fallback parser
  let result;
  if(typeof Papa !== 'undefined'){
    try {
      result = Papa.parse(txt, {
        header:           true,
        skipEmptyLines:   true,
        dynamicTyping:    false,
        delimitersToGuess:[',', ';', '\t', '|'],
        transformHeader:  h => h.trim().replace(/^"|"$/g, '').trim(),
        transform:        v => (v||'').trim().replace(/^"|"$/g, '').trim(),
      });
    } catch(e) {
      console.error('[CSV] PapaParse error:', e);
      result = _parseCSVFallback(txt);
    }
  } else {
    result = _parseCSVFallback(txt);
  }

  const rows  = (result.data || []).filter(r => Object.values(r).some(v => v !== ''));
  const hdrs  = result.meta && result.meta.fields ? result.meta.fields : [];

  // ── 3. Validation ───────────────────────────────────────
  if (!hdrs.length) {
    showCSVError('El CSV no tiene columnas reconocibles. Verificá el formato del archivo.');
    return [];
  }
  if (!rows.length) {
    showCSVError('El CSV no tiene filas de datos válidas.');
    return [];
  }

  // ── 4. Build column resolver from actual headers ────────
  buildColResolver(hdrs);

  // ── 5. Debug log ────────────────────────────────────────
  const normalizedHeaders = hdrs.map(h =>
    h.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'_')
  );

  return rows;
}

function showCSVError(msg){
  const el = document.getElementById('csv-tag');
  if(el){ el.textContent = '⚠ '+msg; el.className='h-tag off'; }
  console.error('[CSV]', msg);
}

// ── Column Resolver ────────────────────────────────────────
// Maps canonical column names → actual header in loaded CSV.
// Runs once after parseCSV. All subsequent access goes through resolve().
const colResolverCache = {};  // canonical → actual header

function buildColResolver(headers){
  // Clear cache
  Object.keys(colResolverCache).forEach(k=>delete colResolverCache[k]);

  // Normalize: lowercase, remove accents, replace non-alphanumeric with space
  const n = s => (s||'').toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/[^a-z0-9]/g,' ').replace(/\s+/g,' ').trim();

  const normHeaders = headers.map(h=>({ raw:h, norm:n(h) }));

  // Extended canonical list — each entry has a primary name + optional aliases
  const CANONICAL = [
    // ── Result / RR ────────────────────────────────────────
    { primary:'iFVG - RR',            aliases:['ifvg rr','rr ifvg','rr entry','rr entrada','resultado rr','rr 1','rr principal'] },
    { primary:'RR Parciales 50% + BE',aliases:['rr parciales','parciales 50','rr 50 be','rr parcial','parciales be','rr2'] },
    { primary:'iFVG - RES',           aliases:['ifvg res','resultado','res ifvg','result','win loss','ganado perdido','ifvg resultado'] },
    // ── Time ───────────────────────────────────────────────
    { primary:'Dia',      aliases:['dia','day','weekday','dia semana','dia de la semana'] },
    { primary:'Mes',      aliases:['mes','month','month number'] },
    { primary:'Semana',   aliases:['semana','week','week number','semana del mes','numero semana'] },
    { primary:'Fecha',    aliases:['fecha','date','trade date','fecha trade'] },
    // ── Context ────────────────────────────────────────────
    { primary:'Bias',           aliases:['bias','sesgo','direccion','direction','market bias','bias diario'] },
    { primary:'WO',             aliases:['wo','weekly open','apertura semanal','weekly opening','open semanal'] },
    { primary:'ES Pre-Open LT', aliases:['es pre open lt','es pre open','es preopen','pre open lt','es lt','es previo','es pre'] },
    { primary:'Rango AS/LN',    aliases:['rango as ln','rango as','rango ln','rango','range','range type','acumulo distribuyo','as ln'] },
    { primary:'Target',         aliases:['target','objetivo','target price','tp','take profit','objetivo precio'] },
    // ── Setup ──────────────────────────────────────────────
    { primary:'PDA',        aliases:['pda','premium discount','discount premium','precio relativo','relative price'] },
    { primary:'ERL/IRL',    aliases:['erl irl','erl','irl','external internal','liquidez tipo','liquidity type'] },
    { primary:'STDV',       aliases:['stdv','std dev','desviacion','standard deviation','desv'] },
    { primary:'Tipo MMXM',  aliases:['tipo mmxm','mmxm','model type','tipo modelo','market maker','modelo'] },
    { primary:'Liquidez OC',aliases:['liquidez oc','liquidez','oc','liquidity','order concentration'] },
    { primary:'SMT OPEN',   aliases:['smt open','smt','smart money','divergencia smt','smart money trap'] },
    { primary:'Horario OC', aliases:['horario oc','horario','hora','session','sesion','time','trading session'] },
    // ── Gallery ────────────────────────────────────────────
    { primary:'Link Trade', aliases:['link trade','link de trade','link','url','imagen','image url','img','foto','screenshot','chart','trade link','enlace'] },
    { primary:'Observación',aliases:['observacion','observaciones','obs','nota','notas','note','notes','comentario','comentarios','comments'] },
  ];

  CANONICAL.forEach(entry=>{
    const allNames = [entry.primary, ...entry.aliases].map(n);
    const nc = n(entry.primary);

    // Pass 1: exact norm match against any alias
    let found = normHeaders.find(h=> allNames.some(a=> h.norm === a));
    // Pass 2: any header norm starts with any alias (or vice versa)
    if(!found) found = normHeaders.find(h=> allNames.some(a=> h.norm.startsWith(a) || a.startsWith(h.norm)));
    // Pass 3: all words of primary canonical present in header
    if(!found){
      const words = nc.split(' ').filter(w=>w.length>1);
      if(words.length) found = normHeaders.find(h=> words.every(w=>h.norm.includes(w)));
    }
    // Pass 4: all words of any alias present in header
    if(!found){
      for(const a of allNames){
        const words = a.split(' ').filter(w=>w.length>1);
        if(!words.length) continue;
        const h = normHeaders.find(hh=> words.every(w=>hh.norm.includes(w)));
        if(h){ found=h; break; }
      }
    }
    // Pass 5: header contains primary canonical as substring
    if(!found) found = normHeaders.find(h=> h.norm.includes(nc) || nc.includes(h.norm));
    // Pass 6: best word-overlap score (last resort)
    if(!found){
      const words = nc.split(' ').filter(w=>w.length>1);
      if(words.length >= 2){
        let best=null, bestScore=0;
        normHeaders.forEach(h=>{
          const score = words.filter(w=>h.norm.includes(w)).length;
          if(score>bestScore){ bestScore=score; best=h; }
        });
        if(bestScore >= Math.ceil(words.length/2)) found=best;
      }
    }

    if(found) colResolverCache[entry.primary] = found.raw;
  });

  // Auto-detect image column if still unresolved
  if(!colResolverCache['Link Trade']){
    const imgKw = ['link','img','image','foto','screenshot','chart','trade url','enlace'];
    const imgCol = normHeaders.find(h=>imgKw.some(kw=>h.norm.includes(kw)));
    if(imgCol) colResolverCache['Link Trade'] = imgCol.raw;
  }

}

// Resolve canonical name → real CSV header (falls back to canonical if not found)
function resolveCol(canonical){
  return colResolverCache[canonical] || canonical;
}

