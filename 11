  });
}

function chatSend(){
  const input   = document.getElementById('chat-input');
  const history = document.getElementById('chat-history');
  if(!input || !history) return;
  const q = input.value.trim();
  if(!q) return;
  input.value = '';

  // User bubble
  const uBub = document.createElement('div');
  uBub.className = 'chat-msg-user';
  uBub.textContent = q;
  history.appendChild(uBub);

  // Thinking indicator
  const think = document.createElement('div');
  think.className = 'chat-thinking';
  think.id = 'chat-think-' + Date.now();
  history.appendChild(think);
  history.scrollTop = history.scrollHeight;

  const apiKey = (document.getElementById('chat-api-key')?.value || '').trim();

  if(apiKey){
    think.textContent = 'Consultando IA…';
    chatAskAI(q, apiKey, think, history);
  } else {
    think.textContent = 'Analizando datos…';
    setTimeout(() => {
      think.remove();
      const answer = chatAnalyze(q);
      history.appendChild(answer);
      history.scrollTop = history.scrollHeight;
    }, 80);
  }
}

// ── Prepare compact dataset for AI ───────────
function chatBuildContext(){
  const executed = csvData.filter(isExecuted);
  const stats    = computeStats(executed);
  const d        = stats ? buildDecision(stats, {}) : null;

  // Column names from first row
  const columns  = executed.length ? Object.keys(executed[0]) : [];

  // Per-variable summary (WR + RR per value, min 3 trades)
  const CAT_COLS = ['Bias','Dia','Target','Rango AS/LN','Tipo MMXM','SMT OPEN',
                    'ERL/IRL','PDA','Horario OC','WO','Semana','STDV','Liquidez OC'];
  const varSummary = {};
  CAT_COLS.forEach(col => {
    const m = {};
    executed.forEach(t => {
      const v = (t[col]||'').trim(); if(!v) return;
      if(!m[v]) m[v] = {w:0,n:0,rrs:[]};
      m[v].n++;
      const res=(t[RES_COL]||'').toUpperCase();
      const rr=parseRR(t[RR_COL]);
      const win = res.includes('WIN')?true:res.includes('LOSS')?false:(!isNaN(rr)?rr>0:false);
      if(win) m[v].w++;
      if(!isNaN(rr)) m[v].rrs.push(rr);
    });
    const rows = Object.entries(m)
      .filter(([,d])=>d.n>=3)
      .map(([val,d])=>({
        val, n:d.n,
        wr:+(d.w/d.n*100).toFixed(1),
        rrSum:+d.rrs.reduce((a,b)=>a+b,0).toFixed(2),
      }))
      .sort((a,b)=>b.wr-a.wr);
    if(rows.length) varSummary[col] = rows;
  });

  // Raw trades — limit to 120 rows, keep key cols only
  const KEY_COLS = ['Dia','Bias','Target','Rango AS/LN','Tipo MMXM','SMT OPEN',
                    'ERL/IRL','Horario OC',RR_COL,RES_COL,'Semana'];
  const sampleTrades = executed.slice(-120).map(t => {
    const o = {};
    KEY_COLS.forEach(c => { if(t[c]!==undefined) o[c]=t[c]; });
    return o;
  });

  return {
    totalTrades:  executed.length,
    columns,
    metrics: stats ? {
      winRate:    +stats.wr.toFixed(1),
      profitFactor: +stats.pf.toFixed(2),
      ev:         +stats.ev.toFixed(3),
      rrTotal:    +stats.rrTotal.toFixed(2),
      avgWin:     +stats.avgWin.toFixed(2),
      avgLoss:    +stats.avgLoss.toFixed(2),
      maxDD:      +stats.maxDD.toFixed(2),
      maxCL:      stats.maxCL,
      calmar:     d ? +d.calmar.toFixed(2) : null,
    } : null,
    variableSummary: varSummary,
    sampleTrades,
  };
}

async function chatAskAI(q, apiKey, thinkEl, history){
  try {
    const ctx  = chatBuildContext();
    const ctxJson = JSON.stringify(ctx, null, 0);

    const systemPrompt =
      `Sos un analista experto en trading de futuros (NQ/ES) usando metodología ICT/SMC/MMXM.
Tenés acceso al dataset completo de trades del usuario.
REGLAS:
- Respondé SOLO con datos reales del CSV. No inventes información.
- Usá los nombres exactos de columnas del dataset.
- Siempre dividí tu respuesta en DOS bloques claramente separados:
  📊 BLOQUE ESTADÍSTICO — datos numéricos, métricas, comparaciones
  🧠 BLOQUE EXPLICATIVO — interpretación, conclusiones, recomendaciones
- Sé preciso, directo y accionable.
- Si no tenés datos suficientes para responder algo, decílo claramente.`;

    const userMsg =
      `DATASET DEL USUARIO:\n${ctxJson}\n\nPREGUNTA: ${q}`;

    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true',
      },
      body: JSON.stringify({
        model: 'claude-opus-4-5',
        max_tokens: 1024,
        system: systemPrompt,
        messages: [{ role: 'user', content: userMsg }],
      }),
    });

    if(!resp.ok){
      const err = await resp.json().catch(()=>({error:{message:resp.statusText}}));
      throw new Error(err?.error?.message || `HTTP ${resp.status}`);
    }

    const data = await resp.json();
    const text = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');

    thinkEl.remove();
    const bubble = document.createElement('div');
    bubble.className = 'chat-msg-bot';
    bubble.innerHTML = chatFormatAIResponse(text);
    history.appendChild(bubble);
    history.scrollTop = history.scrollHeight;

  } catch(err){
    thinkEl.textContent = 'IA no disponible — usando análisis local…';
    setTimeout(() => {
      thinkEl.remove();
      // FALLBACK to local engine
      const answer = chatAnalyze(q);
      // Add a small note about the fallback
      const note = document.createElement('div');
      note.style.cssText = 'font-size:8px;color:var(--t3);margin-bottom:4px;font-style:italic;';
      note.textContent = `⚠ IA no disponible (${err.message}) — respuesta generada con motor local`;
      answer.prepend(note);
      history.appendChild(answer);
      history.scrollTop = history.scrollHeight;
    }, 600);
  }
}

function chatFormatAIResponse(text){
  // Convert the AI's plain text into styled HTML
  // Preserve the 📊 / 🧠 block structure
  let html = text
    // Block titles
    .replace(/(📊[^\n]*)/g, '<div class="chat-block-title">$1</div>')
    .replace(/(🧠[^\n]*)/g, '<div class="chat-block-title">$1</div>')
    // Bold **text**
    .replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')
    // Line breaks
    .replace(/\n/g, '<br>');
  return `<div class="chat-expl" style="line-height:1.7">${html}</div>`;
}

function chatAnalyze(q){

  const norm  = s => (s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim();
  const qn    = norm(q);

  // ══════════════════════════════════════════
  //  PASO 1 — MAPA COMPLETO DE COLUMNAS
  //  col = nombre exacto en el CSV
  //  aliases = palabras que el usuario puede escribir
  // ══════════════════════════════════════════
  const COL_DEFS = [
    { col:'iFVG - RR',             type:'numeric',  lbl:'iFVG RR',
      aliases:['ifvg rr','ifvg - rr','rr ifvg','rr principal','rr entrada','rr1','1rr'] },
    { col:'RR Parciales 50% + BE', type:'numeric',  lbl:'RR Parciales',
      aliases:['rr parciales','parciales','50% be','rr parcial','parcial','be','break even','rr2','2rr'] },
    { col:'iFVG - RES',            type:'category', lbl:'Resultado',
      aliases:['resultado','res','ifvg res','ganador','perdedor','win','loss','resultado trade'] },
    { col:'Dia',                   type:'category', lbl:'Día',
      aliases:['dia','dia semana','lunes','martes','miercoles','jueves','viernes'] },
    { col:'Mes',                   type:'category', lbl:'Mes',
      aliases:['mes','enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'] },
    { col:'Semana',                type:'category', lbl:'Semana',
      aliases:['semana','semana del mes','week'] },
    { col:'Bias',                  type:'category', lbl:'Bias',
      aliases:['bias','sesgo','alcista','bajista','bull','bear','bullish','bearish'] },
    { col:'WO',                    type:'category', lbl:'WO',
      aliases:['wo','weekly open','apertura semanal','apertura semana'] },
    { col:'ES Pre-Open LT',        type:'category', lbl:'ES Pre-Open',
      aliases:['es pre open','es preopen','pre open','pre-open','es lt'] },
    { col:'Rango AS/LN',           type:'category', lbl:'Rango',
      aliases:['rango','rango as ln','acumulo','distribuyo','rango as','rango ln'] },
    { col:'Target',                type:'category', lbl:'Target',
      aliases:['target','objetivo','ln','as','lnkz','askz'] },
    { col:'PDA',                   type:'category', lbl:'PDA',
      aliases:['pda','premium','discount','equilibrio'] },
    { col:'ERL/IRL',               type:'category', lbl:'ERL/IRL',
      aliases:['erl','irl','erl irl','external','internal','liquidez externa','liquidez interna'] },
    { col:'STDV',                  type:'category', lbl:'STDV',
      aliases:['stdv','desviacion','desviación','standard deviation'] },
    { col:'Tipo MMXM',             type:'category', lbl:'MMXM',
      aliases:['mmxm','tipo mmxm','modelo mmxm','market maker','acumulo distribuyo','distribuyo acumulo'] },
    { col:'Liquidez OC',           type:'category', lbl:'Liquidez OC',
      aliases:['liquidez','liquidez oc','oc','liquidity'] },
    { col:'SMT OPEN',              type:'category', lbl:'SMT',
      aliases:['smt','smt open','smart money','divergencia smt','smt true','smt false','smt si','smt no'] },
    { col:'Horario OC',            type:'category', lbl:'Horario OC',
      aliases:['horario','horario oc','hora','sesion','session','new york','london','asia'] },
  ];

  // ══════════════════════════════════════════
  //  PASO 6 — MAPEO DINÁMICO DESDE CSV REAL
  //  Incluye todas las columnas reales del CSV
  //  aunque no estén en COL_DEFS
  // ══════════════════════════════════════════
  const realCols = csvData.length ? Object.keys(csvData[0]) : [];

  // Build a lookup: normalized col name → real col name
  const colLookup = {};
  realCols.forEach(c => { colLookup[norm(c)] = c; });
  // Also map from COL_DEFS aliases
  COL_DEFS.forEach(def => {
    def.aliases.forEach(a => { colLookup[norm(a)] = def.col; });
    colLookup[norm(def.lbl)] = def.col;
    colLookup[norm(def.col)] = def.col;
  });

  // Resolve a user term to a real CSV column name
  function resolveCol(term) {
    const t = norm(term);
    if (colLookup[t]) return colLookup[t];
    // Partial match
    const match = Object.keys(colLookup).find(k => k.includes(t) || t.includes(k));
    return match ? colLookup[match] : null;
  }

  // ══════════════════════════════════════════
  //  VALUE NORMALISATION
  //  Maps user-written values to CSV values
  // ══════════════════════════════════════════
  const VALUE_ALIASES = {
    // booleans / SMT
    'true':'SI', 'si':'SI', 'yes':'SI', 'verdadero':'SI', 'con smt':'SI',
    'false':'NO', 'no':'NO', 'not':'NO', 'falso':'NO', 'sin smt':'NO',
    // resultado
    'win':'WIN', 'ganador':'WIN', 'ganadores':'WIN', 'ganado':'WIN', 'gano':'WIN',
    'loss':'LOSS', 'perdedor':'LOSS', 'perdedores':'LOSS', 'perdido':'LOSS', 'perdi':'LOSS',
    // bias
    'alcista':'BULL', 'bull':'BULL', 'bullish':'BULL', 'comprador':'BULL',
    'bajista':'BEAR', 'bear':'BEAR', 'bearish':'BEAR', 'vendedor':'BEAR',
    // days
    'lunes':'LUNES','martes':'MARTES','miercoles':'MIÉRCOLES','miércoles':'MIÉRCOLES',
    'jueves':'JUEVES','viernes':'VIERNES',
  };

  function normalizeValue(v) {
    const n = norm(v);
    return VALUE_ALIASES[n] ? VALUE_ALIASES[n] : v.trim().toUpperCase();
  }

  // ══════════════════════════════════════════
  //  PASO 1+2 — CONDITION EXTRACTOR
  //  Parses "col VALUE [AND/Y col VALUE]" chains
  //  Returns array of {col, val} objects
  // ══════════════════════════════════════════
  function extractConditions() {
    const conditions = [];

    // Strategy A: scan for "colAlias VALUE" pairs
    // We tokenise the query and try to match each token as a col alias,
    // then grab the following token(s) as the value.
    const tokens = qn.split(/[\s,;:]+/).filter(Boolean);

    // Build sorted alias list (longest first to avoid partial clobbers)
    const aliasList = Object.keys(colLookup).sort((a,b) => b.length - a.length);

    let i = 0;
    while (i < tokens.length) {
      // Try multi-word aliases (up to 4 words)
      let matched = false;
      for (let len = Math.min(4, tokens.length - i); len >= 1; len--) {
        const phrase = tokens.slice(i, i + len).join(' ');
        const col = colLookup[phrase];
        if (col) {
          // Grab the next 1-2 tokens as value candidates
          const valTokens = tokens.slice(i + len, i + len + 2);
          // Skip connecting words
          const skip = ['en','con','=','==','es','igual','a','de','que','el','la','los','las'];
          const cleaned = valTokens.filter(t => !skip.includes(t));
          if (cleaned.length) {
            const rawVal = cleaned[0];
            const normVal = normalizeValue(rawVal);
            // Check value exists in CSV for this col (loose match)
            const vals = [...new Set(csvData.map(t=>(t[col]||'').trim().toUpperCase()))];
            const found = vals.find(v => v === normVal || v.includes(normVal) || normVal.includes(v));
            conditions.push({ col, val: found || normVal, raw: rawVal });
            i += len + 1;
            matched = true;
          } else {
            i += len;
            matched = true;
          }
          break;
        }
      }
      if (!matched) i++;
    }

    // Strategy B: scan for "VALUE en/con/de COLUMN" (reverse order)
    // e.g. "terminaron en LOSS" → resultado = LOSS
    const reversePattern = /\b(terminaron|termino|cerraron|cerro|resultado|resultaron)\s+(?:en|con|siendo|como)\s+(\w+)/gi;
    let m;
    while ((m = reversePattern.exec(q)) !== null) {
      const rawVal  = m[2];
      const normVal = normalizeValue(rawVal);
      const resCols = ['iFVG - RES','Resultado'];
      for (const rc of resCols) {
        if (realCols.includes(rc)) {
          if (!conditions.some(c => c.col === rc)) {
            conditions.push({ col: rc, val: normVal, raw: rawVal });
          }
          break;
        }
      }
    }

    // Strategy C: explicit "COL = VALUE" patterns
    const eqPattern = /(\w[\w\s\-\/]*?)\s*(?:=|==|igual a|es)\s*["']?(\w[\w\s]*)["']?/gi;
    while ((m = eqPattern.exec(q)) !== null) {
      const colTry = resolveCol(m[1].trim());
      if (colTry && !conditions.some(c => c.col === colTry)) {
        conditions.push({ col: colTry, val: normalizeValue(m[2].trim()), raw: m[2].trim() });
      }
    }

    return conditions;
  }

  // ══════════════════════════════════════════
  //  PASO 2 — FILTER BUILDER
  //  Returns filtered subset of csvData
  // ══════════════════════════════════════════
  function applyConditions(data, conditions) {
    if (!conditions.length) return data;
    return data.filter(row => {
      return conditions.every(cond => {
        const cell = (row[cond.col] || '').toString().trim().toUpperCase();
        const want = cond.val.toUpperCase();
        // Flexible match: exact, contains, or partial
        return cell === want || cell.includes(want) || want.includes(cell);
      });
    });
  }

  // ══════════════════════════════════════════
  //  PASO 4 — INTENT DETECTOR
  // ══════════════════════════════════════════
  const intentCount   = /cuantos|cuántos|cantidad|numero de|número de|contá|contar|total de trades|how many/i.test(q);
  const intentSum     = /suma|sumatoria|total rr|sum|acumulado|cuanto rr|cuánto rr/i.test(q);
  const intentAvg     = /promedio|media|average|avg|por trade/i.test(q);
  const intentCompare = / vs | versus | contra |comparar|comparame|diferencia entre/i.test(q);
  const intentPattern = /repite|patron|patrón|comun|común|frecuente|tendencia/i.test(q);
  const intentGeneral = /resumen|general|todo|sistema|overview/i.test(q);
  const intentWinners = /ganador|ganadores|win|positivo|exitoso/i.test(q);
  const intentLosers  = /perdedor|perdedores|loss|negativo|malo/i.test(q);


  // ══════════════════════════════════════════
  //  HELPERS — stats & UI
  // ══════════════════════════════════════════
  function isWin(t) {
    const res = (t[RES_COL]||'').toUpperCase();
    if (res.includes('WIN'))  return true;
    if (res.includes('LOSS')) return false;
    const rr = parseRR(t[RR_COL]);
    return !isNaN(rr) ? rr > 0 : false;
  }
  function sumRR(data, col) {
    return data.reduce((acc, row) => {
      const v = parseRR(row[col || RR_COL]);
      return acc + (v !== null ? v : 0);
    }, 0);
  }
  function computeLocalStats(trades) {
    if (!trades.length) return null;
    const wins   = trades.filter(isWin);
    const rrVals = trades.map(t => parseRR(t[RR_COL])).filter(v => v !== null);
    const winRRs  = rrVals.filter(r => r > 0);
    const lossRRs = rrVals.filter(r => r <= 0);
    const sumW = winRRs.reduce((a,b)=>a+b,0);
    const sumL = Math.abs(lossRRs.reduce((a,b)=>a+b,0));
    return {
      total:   trades.length,
      wins:    wins.length,
      losses:  trades.length - wins.length,
      wr:      (wins.length / trades.length * 100).toFixed(1),
      pf:      sumL > 0 ? (sumW/sumL).toFixed(2) : sumW > 0 ? '∞' : '0',
      rrTotal: rrVals.reduce((a,b)=>a+b,0).toFixed(2),
      avgRR:   rrVals.length ? (rrVals.reduce((a,b)=>a+b,0)/rrVals.length).toFixed(2) : '—',
      avgWin:  winRRs.length  ? (sumW/winRRs.length).toFixed(2)  : '—',
      avgLoss: lossRRs.length ? (sumL/lossRRs.length).toFixed(2) : '—',
    };
  }
  function chip(lbl, val, color) {
    return `<span class="chat-chip" style="color:${color||'var(--tx)'}">${lbl}: <b>${val}</b></span>`;
  }
  function statsBlock(stats, label) {
    if (!stats || !stats.total) return `<div class="chat-expl">Sin datos para <b>${label}</b>.</div>`;
    const wc = parseFloat(stats.wr)>=60?'var(--green2)':parseFloat(stats.wr)>=50?'var(--amber2)':'var(--red2)';
    const rc = parseFloat(stats.rrTotal)>=0?'var(--green2)':'var(--red2)';
    return `<div class="chat-block-title">📊 ${label}</div>
      <div class="chat-stat-row">
        ${chip('Trades',    stats.total)}
        ${chip('WIN',       stats.wins,   'var(--green2)')}
        ${chip('LOSS',      stats.losses, 'var(--red2)')}
        ${chip('Win Rate',  stats.wr+'%', wc)}
        ${chip('PF',        stats.pf)}
        ${chip('RR Total',  stats.rrTotal+'R', rc)}
        ${chip('RR Prom',   stats.avgRR+'R')}
        ${chip('Avg WIN',  '+'+stats.avgWin+'R',  'var(--green2)')}
        ${chip('Avg LOSS', '-'+stats.avgLoss+'R', 'var(--red2)')}
      </div>`;
  }
  function explainBlock(stats, label) {
    if (!stats || !stats.total) return '';
    const wr  = parseFloat(stats.wr);
    const rrt = parseFloat(stats.rrTotal);
    const pf  = parseFloat(stats.pf);
    const wTxt = wr>=60?'<b style="color:var(--green2)">favorable</b>':wr>=50?'<b style="color:var(--amber2)">neutral</b>':'<b style="color:var(--red2)">desfavorable</b>';
    return `<div class="chat-block-title">🧠 Interpretación</div>
      <div class="chat-expl">
        <b>${label}</b>: ${stats.total} trades — WR <b>${stats.wr}%</b> (${wTxt}).<br>
        Profit Factor <b>${stats.pf}</b> — ${pf>=1.5?'sistema rentable':pf>=1?'margen positivo ajustado':'sistema negativo'} en este segmento.<br>
        RR acumulado: <b style="color:${rrt>=0?'var(--green2)':'var(--red2)'}">${rrt>=0?'+':''}${stats.rrTotal}R</b>.
        ${wr<50?'<br>⚠️ Estadísticamente, este contexto no es favorable.':wr>=60?'<br>✅ Contexto estadísticamente válido.':''}
      </div>`;
  }
  function mkBubble(sections) {
    const el = document.createElement('div');
    el.className = 'chat-msg-bot';
    el.innerHTML = sections.join('<hr class="chat-separator">');
    return el;
  }

  // ══════════════════════════════════════════
  //  MAIN ROUTING
  // ══════════════════════════════════════════
  const conditions = extractConditions();
  const base       = csvData.filter(isExecuted);

  // ── PASO 3: MULTI-CONDITION FILTER + COUNT/SUM/AVG ──
  if (conditions.length >= 1) {
    const filtered = applyConditions(base, conditions);

    const condLabel = conditions.map(c => `${c.col} = ${c.val}`).join(' AND ');

    // COUNT intent — primary: "cuántos X con Y terminaron en Z"
    if (intentCount) {
      const pct = base.length ? (filtered.length / base.length * 100).toFixed(1) : 0;
      const explanation = filtered.length === 0
        ? 'No se encontraron trades con esas condiciones. Verificá que los valores existan en el CSV.'
        : filtered.length <= 3
          ? `Muestra muy pequeña (${filtered.length} trades). No es suficiente para sacar conclusiones estadísticas.`
          : parseFloat(pct) > 50
            ? `El ${pct}% del total de trades cumple estas condiciones — es un segmento significativo.`
            : `Representa el ${pct}% del total. Segmento relativamente pequeño.`;
      return mkBubble([
        `<div class="chat-block-title">📊 Conteo — ${condLabel}</div>
         <div class="chat-stat-row">
           ${chip('Trades encontrados', filtered.length, filtered.length>0?'var(--green2)':'var(--red2)')}
           ${chip('Total base', base.length)}
           ${chip('Porcentaje', pct+'%', parseFloat(pct)>50?'var(--blue2)':'var(--t2)')}
         </div>`,
        `<div class="chat-block-title">🧠 Interpretación</div>
         <div class="chat-expl">${explanation}</div>`
      ]);
    }

    // SUM intent
    if (intentSum) {
      const s = sumRR(filtered, RR_COL);
      const pct = base.length ? (filtered.length / base.length * 100).toFixed(1) : 0;
      return mkBubble([
        `<div class="chat-block-title">📊 Suma RR — ${condLabel}</div>
         <div class="chat-stat-row">
           ${chip('Trades',  filtered.length)}
           ${chip('ΣRR',     s.toFixed(2)+'R', s>=0?'var(--green2)':'var(--red2)')}
           ${chip('Avg RR',  filtered.length?(s/filtered.length).toFixed(2)+'R':'—')}
           ${chip('% base',  pct+'%')}
         </div>`,
        `<div class="chat-block-title">🧠 Interpretación</div>
         <div class="chat-expl">
           Con las condiciones <b>${condLabel}</b>, el sistema acumula <b style="color:${s>=0?'var(--green2)':'var(--red2)'}">${s>=0?'+':''}${s.toFixed(2)}R</b> en ${filtered.length} trades.<br>
           ${s>=0?'El subsegmento es rentable.':'El subsegmento muestra pérdida neta.'}
         </div>`
      ]);
    }

    // AVG intent
    if (intentAvg) {
      const rrVals = filtered.map(t=>parseRR(t[RR_COL])).filter(v=>v!==null);
      const avg    = rrVals.length ? (rrVals.reduce((a,b)=>a+b,0)/rrVals.length).toFixed(2) : '—';
      return mkBubble([
        `<div class="chat-block-title">📊 Promedio — ${condLabel}</div>
         <div class="chat-stat-row">
           ${chip('Trades',   filtered.length)}
           ${chip('RR prom',  avg+'R', parseFloat(avg)>=0?'var(--green2)':'var(--red2)')}
           ${chip('Con dato RR', rrVals.length)}
         </div>`,
        `<div class="chat-block-title">🧠 Interpretación</div>
         <div class="chat-expl">El RR promedio para <b>${condLabel}</b> es <b>${avg}R</b>.
           ${parseFloat(avg)>=1.5?'✅ Buena relación riesgo/beneficio.':parseFloat(avg)>=0?'⚠️ Margen positivo pero ajustado.':'❌ Relación negativa en este segmento.'}
         </div>`
      ]);
    }

    // Default for multi-condition: full stats
    const stats = computeLocalStats(filtered);
    if (!stats) {
      return mkBubble([`<div class="chat-expl">No se encontraron trades con: <b>${condLabel}</b>.<br>
        Verificá que los valores existan en el CSV. Valores detectados: ${conditions.map(c=>`${c.col}=${c.val}`).join(', ')}</div>`]);
    }
    return mkBubble([statsBlock(stats, condLabel), explainBlock(stats, condLabel)]);
  }

  // ── COMPARISON ───────────────────────────────
  if (intentCompare) {
    const detectedCols = COL_DEFS.filter(def =>
      def.aliases.some(a => qn.includes(norm(a))) ||
      norm(def.lbl).split(/[\s\-\/]+/).some(p => p.length>2 && qn.includes(p))
    );
    const def = detectedCols[0];
    if (def) {
      const col  = def.col;
      const vals = [...new Set(base.map(t=>(t[col]||'').trim()).filter(Boolean))].sort();
      // Try to find specific values mentioned
      const mentioned = vals.filter(v => qn.includes(norm(v)));
      const showVals  = mentioned.length >= 2 ? mentioned : vals.slice(0,6);
      const sections  = [];
      showVals.forEach(val => {
        const sub   = base.filter(t=>(t[col]||'').trim().toUpperCase()===val.toUpperCase());
        const stats = computeLocalStats(sub);
        sections.push(statsBlock(stats, `${def.lbl} = ${val}`));
        sections.push(explainBlock(stats, `${def.lbl} = ${val}`));
      });
      if (showVals.length >= 2) {
        const ranked = showVals.map(val=>{
          const s = computeLocalStats(base.filter(t=>(t[col]||'').trim().toUpperCase()===val.toUpperCase()));
          return { val, wr: s ? parseFloat(s.wr) : 0, rrt: s ? parseFloat(s.rrTotal) : 0, n: s?.total||0 };
        }).filter(r=>r.n>0).sort((a,b)=>b.wr-a.wr);
        if (ranked.length >= 2) {
          const best=ranked[0], worst=ranked[ranked.length-1];
          sections.push(`<div class="chat-block-title">🏆 Conclusión comparativa — ${def.lbl}</div>
            <div class="chat-expl">
              Mejor: <b>${best.val}</b> — WR <b>${best.wr.toFixed(1)}%</b> · ΣRR <b>${best.rrt>=0?'+':''}${best.rrt.toFixed(1)}R</b><br>
              Peor:  <b>${worst.val}</b> — WR <b>${worst.wr.toFixed(1)}%</b> · ΣRR <b>${worst.rrt>=0?'+':''}${worst.rrt.toFixed(1)}R</b><br>
              ${best.wr-worst.wr>15?`Diferencia de <b>${(best.wr-worst.wr).toFixed(0)} puntos</b> — estadísticamente relevante. Priorizá <b>${best.val}</b>.`:'Diferencia pequeña — esta variable no discrimina fuertemente el resultado.'}
            </div>`);
        }
      }
      return mkBubble(sections);
    }
  }

  // ── PATTERN (ganadores / perdedores) ─────────
  if (intentPattern || (intentWinners && !conditions.length) || (intentLosers && !conditions.length)) {
    const subset = intentLosers ? base.filter(t=>!isWin(t)) : base.filter(isWin);
    const label  = intentLosers ? 'trades perdedores' : 'trades ganadores';
    const freqs  = [];
    COL_DEFS.filter(d=>d.type==='category').forEach(def => {
      const m = {};
      subset.forEach(t => { const v=(t[def.col]||'').trim(); if(v) m[v]=(m[v]||0)+1; });
      const sorted = Object.entries(m).sort((a,b)=>b[1]-a[1]);
      if (sorted.length) freqs.push({ lbl:def.lbl, top:sorted[0], total:subset.length });
    });
    freqs.sort((a,b)=>b.top[1]-a.top[1]);
    const rows = freqs.slice(0,8).map(f=>chip(f.lbl, f.top[0]+` (${f.top[1]}/${f.total})`, 'var(--blue2)')).join('');
    return mkBubble([
      `<div class="chat-block-title">📊 Valores frecuentes en ${label} (${subset.length} trades)</div>
       <div class="chat-stat-row">${rows}</div>`,
      `<div class="chat-block-title">🧠 Interpretación</div>
       <div class="chat-expl">
         Condiciones que aparecen con más frecuencia en los <b>${label}</b>.<br>
         ${intentLosers?'Considerá evitar estas combinaciones.':'Priorizá estas condiciones en tu checklist pre-trade.'}
       </div>`
    ]);
  }

  // ── SINGLE COLUMN BREAKDOWN ──────────────────
  const detectedCols = COL_DEFS.filter(def =>
    def.aliases.some(a => qn.includes(norm(a))) ||
    norm(def.lbl).split(/[\s\-\/]+/).some(p => p.length>2 && qn.includes(p)) ||
    norm(def.col).split(/[\s\-\/]+/).some(p => p.length>2 && qn.includes(p))
  );
  if (detectedCols.length) {
    // Numeric column
    const numDef = detectedCols.find(d=>d.type==='numeric');
    if (numDef && (intentSum || intentAvg || qn.includes('rr') || qn.includes('total'))) {
      const s = sumRR(base, numDef.col);
      const vals = base.map(t=>parseFloat(t[numDef.col])).filter(v=>!isNaN(v));
      const avg  = vals.length ? (s/vals.length).toFixed(2) : '—';
      return mkBubble([
        `<div class="chat-block-title">📊 ${numDef.lbl}</div>
         <div class="chat-stat-row">
           ${chip('Total acumulado', s.toFixed(2)+'R', s>=0?'var(--green2)':'var(--red2)')}
           ${chip('Trades con dato', vals.length)}
           ${chip('Promedio', avg+'R')}
         </div>`,
        `<div class="chat-block-title">🧠 Interpretación</div>
         <div class="chat-expl">
           <b>${numDef.lbl}</b> acumula <b>${s>=0?'+':''}${s.toFixed(2)}R</b> en ${vals.length} trades.
           ${s>=0?'El sistema es rentable en esta métrica.':'El sistema muestra pérdida neta en esta métrica.'}
         </div>`
      ]);
    }

    // Category column breakdown
    const catDef = detectedCols.find(d=>d.type==='category') || detectedCols[0];
    const col    = catDef.col;
    const allVals = [...new Set(base.map(t=>(t[col]||'').trim()).filter(Boolean))].sort();
    if (!allVals.length) {
      return mkBubble([`<div class="chat-expl">La columna <b>${col}</b> no tiene datos en el CSV cargado.</div>`]);
    }
    const sections = [];
    allVals.slice(0,8).forEach(val => {
      const sub   = base.filter(t=>(t[col]||'').trim().toUpperCase()===val.toUpperCase());
      const stats = computeLocalStats(sub);
      sections.push(statsBlock(stats, `${catDef.lbl} = ${val}`));
      sections.push(explainBlock(stats, `${catDef.lbl} = ${val}`));
    });
    // Conclusion
    const ranked = allVals.slice(0,8).map(val=>{
      const s=computeLocalStats(base.filter(t=>(t[col]||'').trim().toUpperCase()===val.toUpperCase()));
      return {val,wr:s?parseFloat(s.wr):0,rrt:s?parseFloat(s.rrTotal):0,n:s?.total||0};
    }).filter(r=>r.n>=3).sort((a,b)=>b.wr-a.wr);
    if (ranked.length>=2) {
      const best=ranked[0], worst=ranked[ranked.length-1];
      sections.push(`<div class="chat-block-title">🏆 Conclusión — ${catDef.lbl}</div>
        <div class="chat-expl">
          Mejor: <b>${best.val}</b> WR <b>${best.wr.toFixed(1)}%</b> · ΣRR <b>${best.rrt>=0?'+':''}${best.rrt.toFixed(1)}R</b><br>
          Peor:  <b>${worst.val}</b> WR <b>${worst.wr.toFixed(1)}%</b> · ΣRR <b>${worst.rrt>=0?'+':''}${worst.rrt.toFixed(1)}R</b>
        </div>`);
    }
    return mkBubble(sections);
  }

  // ── GENERAL ──────────────────────────────────
  if (intentGeneral) {
    const stats = computeLocalStats(base);
    return mkBubble([statsBlock(stats,'Dataset completo'), explainBlock(stats,'Tu sistema')]);
  }

  // ── PASO 8: columna no reconocida ────────────
  const available = COL_DEFS.map(d=>`<b>${d.lbl}</b>`).join(', ');
  return mkBubble([`
    <div class="chat-block-title red">No pude interpretar la consulta</div>
    <div class="chat-expl">
      No identifiqué columnas o condiciones claras.<br><br>
      <b>Columnas disponibles:</b> ${available}.<br><br>
      <b>Ejemplos que funcionan:</b><br>
      · "cuántos trades con SMT SI terminaron en LOSS"<br>
      · "cuántos RR Parciales TRUE dieron LOSS"<br>
      · "win rate por día"<br>
      · "compará LN vs AS"<br>
      · "qué se repite en ganadores"<br>
      · "resumen general"
    </div>`]);
}

// ══════════════════════════════════════════════
//  PLAN DE TRADING — solo lectura de csvData
// ══════════════════════════════════════════════
function efRenderPlan(){
  const el = document.getElementById('ef-view-plan');
  if(!el) return;

  if(!csvData.length){
    el.innerHTML = '<div class="pt-empty">Cargá el CSV para generar el Plan de Trading</div>';
    return;
  }

  const trades = csvData.filter(isExecuted);
  const total  = trades.length;
  const stats  = computeStats(trades);
  if(!stats){
    el.innerHTML = '<div class="pt-empty">Sin datos suficientes para generar el plan</div>';
    return;
  }

  const d      = buildDecision(stats, {});
  const calmar = d.calmar;
  const mcl    = stats.maxCL || 0;
  const mdd    = stats.maxDD || 0;

  // ── helpers ──────────────────────────────────
  function isWin(t){
    const res=(t[RES_COL]||'').toUpperCase();
    if(res.includes('WIN'))  return true;
    if(res.includes('LOSS')) return false;
    const rr=parseRR(t[RR_COL]);
    return !isNaN(rr)?rr>0:false;
  }
  function getRRv(t){ const v=parseRR(t[RR_COL]); return isNaN(v)?null:v; }

  const wins   = trades.filter(isWin);
  const losses = trades.filter(t=>!isWin(t));
  const wr     = stats.wr;
  const pf     = stats.pf;
  const ev     = stats.ev;
  const rrTotal= stats.rrTotal;
  const avgWin = stats.avgWin;
  const avgLoss= stats.avgLoss;

  // ── variable frequency analysis ──────────────
  const CAT_COLS = [
    {col:'Bias',lbl:'Bias'},{col:'SMT OPEN',lbl:'SMT'},{col:'Target',lbl:'Target'},
    {col:'Rango AS/LN',lbl:'Rango'},{col:'Dia',lbl:'Día'},{col:'Tipo MMXM',lbl:'MMXM'},
    {col:'Horario OC',lbl:'Horario'},{col:'ERL/IRL',lbl:'ERL/IRL'},{col:'PDA',lbl:'PDA'},
  ];

  function topVal(subset, col){
    const m={};
    subset.forEach(t=>{ const v=(t[col]||'').trim(); if(v) m[v]=(m[v]||0)+1; });
    const s=Object.entries(m).sort((a,b)=>b[1]-a[1]);
    return s.length?{val:s[0][0],count:s[0][1],total:subset.length}:null;
  }

  function analyzeCol(col){
    const m={};
    trades.forEach(t=>{
      const v=(t[col]||'').trim(); if(!v) return;
      if(!m[v]) m[v]={w:0,n:0,rrs:[]};
      m[v].n++;
      if(isWin(t)) m[v].w++;
      const rr=getRRv(t); if(rr!==null) m[v].rrs.push(rr);
    });
    return Object.entries(m)
      .filter(([,d])=>d.n>=3)
      .map(([val,d])=>({
        val,n:d.n,
        wr:d.w/d.n*100,
        rrSum:d.rrs.reduce((a,b)=>a+b,0),
      }))
      .sort((a,b)=>b.wr-a.wr);
  }

  // ── setup description ─────────────────────────
  const setupParts = [];
  CAT_COLS.slice(0,6).forEach(({col,lbl})=>{
    const tv=topVal(wins,col);
    if(tv && tv.count/tv.total >= 0.4) setupParts.push(`${lbl}: <b>${tv.val}</b>`);
  });

  // ── invalidation (from losses) ────────────────
  const invalidParts = [];
  CAT_COLS.forEach(({col,lbl})=>{
    const rows = analyzeCol(col).reverse(); // worst first
    if(rows.length && rows[0].wr <= 40) invalidParts.push({lbl, val:rows[0].val, wr:rows[0].wr});
  });

  // ── top 3 best combos ─────────────────────────
  const COMBO_PAIRS = [['Bias','Target'],['Bias','Rango AS/LN'],['Target','Rango AS/LN'],
    ['Bias','SMT OPEN'],['Dia','Bias'],['Target','Tipo MMXM']];
  const allCombos = [];
  COMBO_PAIRS.forEach(([c1,c2])=>{
    const m={};
    trades.forEach(t=>{
      const v1=(t[c1]||'').trim(),v2=(t[c2]||'').trim();
      if(!v1||!v2) return;
      const k=`${v1} + ${v2}`;
      if(!m[k]) m[k]={w:0,n:0,rrs:[]};
      m[k].n++; if(isWin(t)) m[k].w++;
      const rr=getRRv(t); if(rr!==null) m[k].rrs.push(rr);
    });
    Object.entries(m).filter(([,d])=>d.n>=4).forEach(([key,d])=>{
      allCombos.push({key,wr:d.w/d.n*100,n:d.n,rrSum:d.rrs.reduce((a,b)=>a+b,0),
        cols:`${c1} + ${c2}`});
    });
  });
  const bestCombos  = [...allCombos].sort((a,b)=>b.wr-a.wr).slice(0,3);
  const worstCombos = [...allCombos].sort((a,b)=>a.wr-b.wr).slice(0,3);

  // ── semaforo risk ─────────────────────────────
  const semG_risk = '0.5% — 1%';
  const semA_risk = '0.25% — 0.5%';
  const semR_risk = 'NO OPERAR';

  // ── formatters ───────────────────────────────
  const fmt = v => v>=0?'+'+v.toFixed(2)+'R':v.toFixed(2)+'R';
  const fmtWR = v => v.toFixed(1)+'%';
  const c = (v,g,a) => v>=g?'var(--green2)':v>=a?'var(--amber2)':'var(--red2)';

  const wrColor  = c(wr,60,50);
  const pfColor  = c(pf,1.5,1);
  const evColor  = ev>0?'var(--green2)':'var(--red2)';
  const mddColor = mdd>10?'var(--red2)':mdd>5?'var(--amber2)':'var(--green2)';
  const calColor = c(calmar,2,1);

  // ── checklist items from winners ─────────────
  const checkItems = [];
  CAT_COLS.slice(0,5).forEach(({col,lbl})=>{
    const tv=topVal(wins,col);
    if(tv && tv.count>=3) checkItems.push(`${lbl} = ${tv.val}`);
  });

  // ── plan de ejecución ─────────────────────────
  const planSetup  = setupParts.slice(0,4).join(' · ') || 'Definir condiciones base';
  const planAvoid  = invalidParts.slice(0,3).map(x=>`${x.lbl}=${x.val}`).join(' / ') || 'Sin patrones negativos claros';
  const planTarget = avgWin>0 ? `Target mínimo: +${avgWin.toFixed(1)}R` : 'Definir target';
  const planRisk   = mdd>10||mcl>5 ? semA_risk : wr>=60&&ev>0 ? semG_risk : semA_risk;
  const planPause  = mcl>=3 ? `Pausar tras ${mcl} pérdidas seguidas` : 'Pausar tras 3 pérdidas seguidas';

  // ── sample warning ────────────────────────────
  const lowSample = total < 30;

  // ══════════════════════════════════════════════
  // RENDER
  // ══════════════════════════════════════════════
  function card(cls, titleIcon, title, body){
    return `<div class="pt-card ${cls}">
      <div class="pt-card-title"><span>${titleIcon}</span>${title}</div>
      ${body}
    </div>`;
  }
  function row(label, val, color){
    return `<div class="pt-row"><span class="pt-row-label">${label}</span><span class="pt-row-val" style="color:${color||'var(--tx)'}">${val}</span></div>`;
  }
  function rule(dot, text){
    return `<div class="pt-rule"><div class="${dot}"></div><span>${text}</span></div>`;
  }
  function combo(c, rank){
    const wrc = c.wr>=60?'var(--green2)':c.wr>=50?'var(--amber2)':'var(--red2)';
    return `<div class="pt-combo">
      <div class="pt-combo-key">${rank}. ${c.key}</div>
      <div class="pt-combo-stats">
        <span style="color:${wrc}">WR ${c.wr.toFixed(0)}%</span>
        <span style="color:var(--t3)">${c.n} trades</span>
        <span style="color:${c.rrSum>=0?'var(--green2)':'var(--red2)'}">ΣRR ${c.rrSum.toFixed(1)}R</span>
      </div>
    </div>`;
  }

  let html = `<div class="pt-wrap">`;

  // HEADER
  html += `<div class="pt-header">
    <div class="pt-header-title">📋 Plan de Trading Personal</div>
    <div class="pt-header-sub">Generado automáticamente · ${total} trades analizados</div>
  </div>`;

  if(lowSample){
    html += `<div class="pt-warning">⚠️ Muestra de ${total} trades — se recomienda mínimo 30 para mayor confiabilidad estadística.</div>`;
  }

  // ROW 1: setup + stats
  html += `<div class="pt-grid">`;

  // 1. SETUP
  html += card('pt-green','🎯','DEFINICIÓN DEL SETUP',
    (setupParts.length
      ? setupParts.map(p=>`<div class="pt-rule"><div class="pt-dot-g"></div><span>${p}</span></div>`).join('')
      : rule('pt-dot-a','Sin condiciones dominantes detectadas (mín. 40% frecuencia en ganadores)'))
  );

  // 4. ESTADÍSTICA BASE
  html += card('pt-blue','📊','ESTADÍSTICA BASE',
    row('Win Rate', fmtWR(wr), wrColor) +
    row('Profit Factor', pf>=99?'∞':pf.toFixed(2), pfColor) +
    row('EV / Trade', fmt(ev), evColor) +
    row('RR Total', fmt(rrTotal), parseFloat(rrTotal)>=0?'var(--green2)':'var(--red2)') +
    row('Max Drawdown', mdd.toFixed(1)+'R', mddColor) +
    row('Max Racha Pérd.', mcl+' ops', mcl>5?'var(--red2)':mcl>3?'var(--amber2)':'var(--green2)') +
    row('Calmar', calmar>=99?'∞':calmar.toFixed(2), calColor)
  );

  html += `</div>`;

  // ROW 2: invalidacion + SL/TP
  html += `<div class="pt-grid">`;

  // 2. INVALIDACIÓN
  html += card('pt-red','❌','CRITERIOS DE INVALIDACIÓN — NO OPERAR SI',
    (invalidParts.length
      ? invalidParts.slice(0,5).map(x=>rule('pt-dot-r',`<b>${x.lbl} = ${x.val}</b> — WR histórico ${x.wr.toFixed(0)}%`)).join('')
      : rule('pt-dot-g','No se detectaron condiciones con WR ≤40% (mín. 3 trades)'))
  );

  // 3. SL Y TP
  html += card('pt-amber','🎯','SL Y TP — RANGOS ÓPTIMOS',
    row('RR promedio ganador', '+'+avgWin.toFixed(2)+'R', 'var(--green2)') +
    row('RR promedio perdedor', '-'+avgLoss.toFixed(2)+'R', 'var(--red2)') +
    row('RR mínimo objetivo', '+'+(avgWin*0.8).toFixed(1)+'R', 'var(--amber2)') +
    row('Trades con dato RR', (trades.filter(t=>getRRv(t)!==null).length)+' / '+total, 'var(--t2)') +
    `<div style="margin-top:8px;font-size:10px;color:var(--t3);font-weight:600;">
      Apuntá a un mínimo de <b style="color:var(--amber2)">${avgWin.toFixed(1)}R</b> por trade.
      Cortá pérdidas antes de <b style="color:var(--red2)">-${avgLoss.toFixed(1)}R</b>.
    </div>`
  );

  html += `</div>`;

  // ROW 3: gestión de riesgo (semaforo)
  html += `<div class="pt-grid-1">`;
  html += card('pt-blue','💰','GESTIÓN DE RIESGO — SISTEMA SEMÁFORO',
    `<div class="pt-semaforo">
      <div class="pt-sem pt-sem-g">
