function efRenderVariables(){
  const el = document.getElementById('ef-view-variables');
  if(!efWorkTrades.length){ el.innerHTML='<div class="ef-empty">Sin datos.</div>'; return; }

  function stdDev(vals){
    if(vals.length < 2) return 0;
    const m = vals.reduce((a,b)=>a+b,0)/vals.length;
    return Math.sqrt(vals.reduce((s,v)=>s+(v-m)*(v-m),0)/vals.length);
  }

  // Normalise boolean values for Bias a favor column
  function normBiasLabel(v){
    const u = v.toString().trim().toUpperCase();
    if(u==='TRUE'||u==='SI'||u==='1'||u==='YES') return 'A favor';
    if(u==='FALSE'||u==='NO'||u==='0') return 'En contra';
    return v;
  }

  // Month number → name
  const MES_NAMES = ['','Enero','Febrero','Marzo','Abril','Mayo','Junio',
                     'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  function mesLabel(v){
    const n = parseInt(v,10);
    if(!isNaN(n) && n>=1 && n<=12) return MES_NAMES[n];
    // Try Spanish name passthrough
    return v;
  }

  // Build accordion block for any grouped data
  function makeAccordion(lbl, groups, vi, displayFn){
    if(!groups.length) return '';
    const allRR   = groups.flatMap(g=>g.ts.map(t=>getRR(t)).filter(r=>r!==null));
    const totRR   = allRR.reduce((a,b)=>a+b,0);
    const totN    = groups.reduce((s,g)=>s+g.s.n,0);
    const avgWR   = groups.reduce((s,g)=>s+g.s.wr,0)/groups.length;
    const rrColor = totRR>=0?'var(--green2)':'var(--red2)';
    const id      = `acc-${vi}`;

    const rows = groups.map(g=>{
      const rrVals = g.ts.map(t=>getRR(t)).filter(r=>r!==null);
      const sd = stdDev(rrVals);
      const bc = g.s.rrT>=0?'var(--green2)':'var(--red2)';
      const label = displayFn ? displayFn(g.val) : g.val;
      return `<tr>
        <td class="lbl">${label}</td>
        <td class="r ef-dim">${g.s.n}</td>
        <td class="r ${efClrWR(g.s.wr)}">${g.s.wr.toFixed(0)}%</td>
        <td class="r" style="color:${bc}">${efFmt(g.s.rrT)}</td>
        <td class="r ${efClrPF(g.s.pf)}">${g.s.pf>=99?'∞':g.s.pf.toFixed(2)}</td>
        <td class="r ef-dim">${sd.toFixed(2)}</td>
      </tr>`;
    }).join('');

    return `<div class="ef-accordion" id="${id}" style="overflow:hidden;">
      <div class="ef-accordion-hdr" onclick="efToggleAcc('${id}')">
        <span class="ef-accordion-title">${lbl}</span>
        <div class="ef-accordion-meta">
          <span style="color:var(--t3)">${totN} tr</span>
          <span style="color:${rrColor}">${efFmt(totRR)}</span>
          <span style="color:${avgWR>=55?'var(--green2)':avgWR>=50?'var(--amber2)':'var(--red2)'}">${avgWR.toFixed(0)}%WR</span>
          <button onclick="event.stopPropagation();document.getElementById('${id}').remove()"
            style="background:none;border:none;color:var(--t3);cursor:pointer;font-size:12px;padding:0 0 0 6px;line-height:1;border-radius:3px;" title="Eliminar">✕</button>
          <span class="ef-accordion-chevron">▼</span>
        </div>
      </div>
      <div class="ef-accordion-body">
        <table class="ef-tbl">
          <thead><tr>
            <th>${lbl}</th><th class="r">Trades</th><th class="r">WR%</th>
            <th class="r">RR Total</th><th class="r">PF</th><th class="r">σ</th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    </div>`;
  }

  // Standard variable blocks
  const standardBlocks = EF_VARS.map(({col,lbl}, vi)=>{
    const groups = efGroupBy(efWorkTrades, col);
    return makeAccordion(lbl, groups, vi, null);
  });

  const BIAS_BOOL_COL = 'ES Pre-Open LT';
  const biasGroups = efGroupBy(efWorkTrades, BIAS_BOOL_COL);
  const biasExtra = biasGroups.length
    ? makeAccordion('Bias (A favor / En contra)', biasGroups, 'bias-bool', normBiasLabel)
    : '';

  const mesGroups = efGroupBy(efWorkTrades, 'Mes')
    .sort((a,b)=>{ const na=parseInt(a.val,10),nb=parseInt(b.val,10); return (!isNaN(na)&&!isNaN(nb))?na-nb:0; });
  const mesExtra = mesGroups.length
    ? makeAccordion('Mes', mesGroups, 'mes', mesLabel)
    : '';

  // Build CSV column selector for dynamic blocks
  const allCsvCols = csvData.length ? Object.keys(csvData[0]) : [];
  const colOptions = allCsvCols.map(c=>`<option value="${c}">${c}</option>`).join('');

  el.innerHTML = `
    <div id="ef-var-toolbar" style="display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--s2);border-bottom:1px solid var(--bd);flex-shrink:0;">
      <span style="font-size:8px;color:var(--t3);letter-spacing:1.5px;text-transform:uppercase;">+ Variable del CSV:</span>
      <select id="ef-col-sel" style="background:var(--s3);border:1px solid var(--bd2);color:var(--tx);font-size:10px;padding:3px 8px;border-radius:4px;outline:none;cursor:pointer;max-width:200px;">
        <option value="">— seleccioná columna —</option>
        ${colOptions}
      </select>
      <button onclick="efAddDynamicVar()" style="background:var(--blue2);border:none;color:#fff;font-size:9px;padding:4px 12px;border-radius:4px;cursor:pointer;letter-spacing:.5px;">AGREGAR</button>
    </div>
    <div id="ef-var-canvas-wrap" style="flex:1;overflow:auto;position:relative;">
      <div class="ef-var-canvas" id="ef-var-grid-inner" style="position:relative;min-height:100%;min-width:100%">
        ${standardBlocks.join('')}
        ${biasExtra}
        ${mesExtra}
      </div>
    </div>`;

  // Activate free-position drag+resize
  const canvas = document.getElementById('ef-var-grid-inner');
  if(canvas) setTimeout(()=>{
    efInitDrag(canvas);
    efBindStateSave(canvas);
    // Restore persisted positions/sizes/open state
    efRestoreVarState();
  }, 0);
}

function efAddDynamicVar(){
  const sel = document.getElementById('ef-col-sel');
  const col = sel?.value;
  if(!col) return;

  const canvas = document.getElementById('ef-var-grid-inner');
  if(!canvas) return;

  // Deduplicate: don't add if already exists with same title
  const existing = [...canvas.querySelectorAll('.ef-accordion-title')];
  if(existing.some(t=>t.textContent.trim()===col)) {
    sel.value='';
    return;
  }

  // Use all executed trades (not just filtered)
  const source = csvData.filter(isExecuted);
  if(!source.length) return;

  // Group by selected column
  const groups = efGroupBy(source, col);
  if(!groups.length) return;

  const vi     = 'dyn-' + Date.now();
  const id     = `acc-${vi}`;
  const lbl    = col;
  const allRR  = groups.flatMap(g=>g.ts.map(t=>getRR(t)).filter(r=>r!==null));
  const totRR  = allRR.reduce((a,b)=>a+b,0);
  const totN   = groups.reduce((s,g)=>s+g.s.n,0);
  const avgWR  = groups.reduce((s,g)=>s+g.s.wr,0)/groups.length;
  const rrColor= totRR>=0?'var(--green2)':'var(--red2)';

  function sd(vals){
    if(vals.length<2) return 0;
    const m=vals.reduce((a,b)=>a+b,0)/vals.length;
    return Math.sqrt(vals.reduce((s,v)=>s+(v-m)*(v-m),0)/vals.length);
  }

  const rows = groups.map(g=>{
    const bc=g.s.rrT>=0?'var(--green2)':'var(--red2)';
    return `<tr>
      <td class="lbl">${g.val}</td>
      <td class="r ef-dim">${g.s.n}</td>
      <td class="r ${efClrWR(g.s.wr)}">${g.s.wr.toFixed(0)}%</td>
      <td class="r" style="color:${bc}">${efFmt(g.s.rrT)}</td>
      <td class="r ${efClrPF(g.s.pf)}">${g.s.pf>=99?'∞':g.s.pf.toFixed(2)}</td>
      <td class="r ef-dim">${sd(g.ts.map(t=>getRR(t)).filter(r=>r!==null)).toFixed(2)}</td>
    </tr>`;
  }).join('');

  // Find a visible position (top-left of current scroll position)
  const wrap = document.getElementById('ef-var-canvas-wrap');
  const scrollTop  = wrap ? wrap.scrollTop  : 0;
  const scrollLeft = wrap ? wrap.scrollLeft : 0;

  // Find free spot: offset from last card or default
  const cards = [...canvas.querySelectorAll('.ef-accordion')];
  let nx=scrollLeft+12, ny=scrollTop+12;
  if(cards.length){
    const last = cards[cards.length-1];
    nx = parseInt(last.style.left||0)+parseInt(last.style.width||320)+14;
    ny = parseInt(last.style.top||0);
    // If too far right, wrap to new row
    if(nx+320 > canvas.offsetWidth+scrollLeft+200){
      nx = scrollLeft+12;
      ny = scrollTop + 12 + cards.length * 56;
    }
  }

  const html = `<div class="ef-accordion" id="${id}"
    style="position:absolute;overflow:hidden;left:${nx}px;top:${ny}px;width:320px;">
    <div class="ef-accordion-hdr" onclick="efToggleAcc('${id}')">
      <span class="ef-accordion-title">${lbl}</span>
      <div class="ef-accordion-meta">
        <span style="color:var(--t3)">${totN} tr</span>
        <span style="color:${rrColor}">${efFmt(totRR)}</span>
        <span style="color:${avgWR>=55?'var(--green2)':avgWR>=50?'var(--amber2)':'var(--red2)'}">${avgWR.toFixed(0)}%WR</span>
        <button onclick="event.stopPropagation();document.getElementById('${id}').remove()"
          style="background:none;border:none;color:var(--t3);cursor:pointer;font-size:12px;padding:0 0 0 6px;border-radius:3px;">✕</button>
        <span class="ef-accordion-chevron">▼</span>
      </div>
    </div>
    <div class="ef-accordion-body">
      <table class="ef-tbl">
        <thead><tr>
          <th>${lbl}</th><th class="r">Trades</th><th class="r">WR%</th>
          <th class="r">RR Total</th><th class="r">PF</th><th class="r">σ</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
  </div>`;

  canvas.insertAdjacentHTML('beforeend', html);
  const newCard = document.getElementById(id);

  // Grow canvas to accommodate new card
  const need = ny + 200;
  const curH  = parseInt(canvas.style.minHeight||0);
  if(need > curH) canvas.style.minHeight = need + 'px';

  // Scroll into view
  if(wrap) wrap.scrollTo({ left: nx-10, top: ny-10, behavior:'smooth' });

  // Init drag+resize
  efInitSingleCard(canvas, newCard);
  setTimeout(efSaveVarState, 100);

  sel.value = '';
}

function efInitSingleCard(canvas, card){
  let _dx=0,_dy=0;
  if(!card.querySelector('.ef-rh')){
    const rh=document.createElement('div');
    rh.className='ef-rh';
    rh.style.cssText='position:absolute;right:0;bottom:0;width:14px;height:14px;cursor:se-resize;z-index:20;display:flex;align-items:center;justify-content:center;opacity:.4;font-size:10px;';
    rh.textContent='⊿';
    card.appendChild(rh);
    rh.addEventListener('mousedown',e=>{
      e.stopPropagation();e.preventDefault();
      const sx=e.clientX,sy=e.clientY,sw=card.offsetWidth,sh=card.offsetHeight;
      const mv=ev=>{card.style.width=Math.max(200,sw+ev.clientX-sx)+'px';if(card.classList.contains('ef-open'))card.style.height=Math.max(100,sh+ev.clientY-sy)+'px';};
      const up=()=>{document.removeEventListener('mousemove',mv);document.removeEventListener('mouseup',up);};
      document.addEventListener('mousemove',mv);document.addEventListener('mouseup',up);
    });
  }
  const hdr=card.querySelector('.ef-accordion-hdr');
  if(!hdr)return;
  hdr.addEventListener('mousedown',e=>{
    if(e.target.closest('.ef-rh'))return;
    e.preventDefault();
    _dx=e.clientX-card.offsetLeft;_dy=e.clientY-card.offsetTop;
    card.classList.add('ef-moving');
    document.body.style.userSelect='none';
    const mv=ev=>{
      const nx=Math.max(0,ev.clientX-_dx),ny=Math.max(0,ev.clientY-_dy);
      card.style.left=nx+'px';card.style.top=ny+'px';
      const need=ny+card.offsetHeight+20;if(need>canvas.offsetHeight)canvas.style.minHeight=need+'px';
    };
    const up=()=>{card.classList.remove('ef-moving');document.body.style.userSelect='';document.removeEventListener('mousemove',mv);document.removeEventListener('mouseup',up);};
    document.addEventListener('mousemove',mv);document.addEventListener('mouseup',up);
  });
}

function efToggleAcc(id){
  const el = document.getElementById(id);
  if(el) el.classList.toggle('ef-open');
}

// ── Free-position drag + resize for var-canvas ──
function efInitDrag(canvas){
  let _dx=0, _dy=0, _el=null;

  // Lay out initial positions in a loose 3-col grid
  const cards = [...canvas.querySelectorAll('.ef-accordion')];
  const PAD = 12, GAP = 10, COL_W = 320;
  cards.forEach((card, i)=>{
    const col = i % 3;
    const row = Math.floor(i / 3);
    card.style.left = (PAD + col * (COL_W + GAP)) + 'px';
    card.style.top  = (PAD + row * 56) + 'px';
    card.style.width = COL_W + 'px';
  });

  cards.forEach(card=>{
    // Resize handle
    if(!card.querySelector('.ef-rh')){
      const rh = document.createElement('div');
      rh.className = 'ef-rh';
      rh.style.cssText = 'position:absolute;right:0;bottom:0;width:14px;height:14px;cursor:se-resize;z-index:20;display:flex;align-items:center;justify-content:center;opacity:.4;';
      rh.textContent = '⊿';
      rh.style.fontSize = '10px';
      card.style.position = 'absolute';
      card.appendChild(rh);

      rh.addEventListener('mousedown', e=>{
        e.stopPropagation(); e.preventDefault();
        const sx=e.clientX, sy=e.clientY;
        const sw=card.offsetWidth, sh=card.offsetHeight;
        const mv=ev=>{
          card.style.width  = Math.max(200, sw + ev.clientX - sx) + 'px';
          if(card.classList.contains('ef-open'))
            card.style.height = Math.max(100, sh + ev.clientY - sy) + 'px';
        };
        const up=()=>{
          document.removeEventListener('mousemove',mv);
          document.removeEventListener('mouseup',up);
        };
        document.addEventListener('mousemove',mv);
        document.addEventListener('mouseup',up);
      });
    }

    // Drag from header
    const hdr = card.querySelector('.ef-accordion-hdr');
    if(!hdr) return;
    hdr.addEventListener('mousedown', e=>{
      if(e.target.closest('.ef-rh')) return;
      e.preventDefault();
      _el  = card;
      _dx  = e.clientX - card.offsetLeft;
      _dy  = e.clientY - card.offsetTop;
      card.classList.add('ef-moving');
      document.body.style.userSelect = 'none';

      const mv = ev=>{
        if(!_el) return;
        const nx = Math.max(0, ev.clientX - _dx);
        const ny = Math.max(0, ev.clientY - _dy);
        _el.style.left = nx + 'px';
        _el.style.top  = ny + 'px';
        // grow canvas if needed
        const need = ny + _el.offsetHeight + 20;
        if(need > canvas.offsetHeight) canvas.style.minHeight = need + 'px';
      };
      const up=()=>{
        if(_el) _el.classList.remove('ef-moving');
        document.body.style.userSelect = '';
        _el = null;
        document.removeEventListener('mousemove',mv);
        document.removeEventListener('mouseup',up);
      };
      document.addEventListener('mousemove',mv);
      document.addEventListener('mouseup',up);
    });
  });
}

