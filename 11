        imgStore.createIndex('target', 'target', { unique: false });
        imgStore.createIndex('rango',  'rango',  { unique: false });
      }
    };

    req.onsuccess = e => { DB = e.target.result; resolve(DB); };
    req.onerror   = e => reject(e.target.error);
  });
}

