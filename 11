  const map = {'Sí':'si','Parcialmente':'par','No':'no'};
  const el = document.getElementById('dj-plan-'+map[val]);
  if(el) el.classList.add('selected');
}

function djSaveEntry(){
  const get = id => { const e=document.getElementById(id); return e?e.value.trim():''; };
  if(!get('dj-fecha')){ alert('Indicá la fecha'); return; }

  const entries = djLoad();
  const newEntry = {
    id:          djEdit || djId(),
    fecha:       get('dj-fecha'),
    sesion:      get('dj-sesion'),
    emocAntes:   get('dj-emoc-antes'),
    emocDespues: get('dj-emoc-despues'),
    confianza:   get('dj-confianza'),
    disciplina:  get('dj-disciplina'),
    siguioPlan:  djPlanVal || (djEdit && djLoad().find(e=>e.id===djEdit)?.siguioPlan) || '',
    bienes:      get('dj-bien'),
    males:       get('dj-mal'),
    aprendi:     get('dj-aprendi'),
    mejorar:     get('dj-mejorar'),
    nota:        get('dj-nota'),
    imagenes:    [...djImgBase64],
    ts:          Date.now(),
  };

  if(djEdit){
    const idx = entries.findIndex(e=>e.id===djEdit);
    if(idx>=0) entries[idx] = newEntry;
  } else {
    entries.unshift(newEntry);
  }

  djSave(entries);
  djEdit = null;
  djPlanVal = '';
  djImgBase64 = [];
  djView = 'history';
  djRender();
}

// ── HISTORY ──────────────────────────────────
function djRenderHistory(){
  const entries = djLoad();
  const wrap = document.getElementById('dj-content');
  if(!entries.length){
    wrap.innerHTML = `<div class="dj-empty">📓<br>Sin entradas aún<br>Creá tu primera entrada de diario</div>`;
    return;
  }

  wrap.innerHTML = `<div class="dj-history">${entries.map(e=>djCardHTML(e)).join('')}</div>`;
}

function djCardHTML(e){
  const preview = (e.nota || e.bienes || e.aprendi || '').slice(0,80) + '...';
  const planBadge = e.siguioPlan === 'Sí'
    ? `<span class="dj-badge dj-badge-plan-y">Plan ✓</span>`
    : e.siguioPlan === 'No'
    ? `<span class="dj-badge dj-badge-plan-n">Plan ✗</span>` : '';

  return `
  <div class="dj-card" id="djcard-${e.id}">
    <div class="dj-card-header" onclick="djToggleCard('${e.id}')">
      <div class="dj-card-meta">
        <div class="dj-card-date">${e.fecha} — ${e.sesion}</div>
        <div class="dj-card-session">${e.emocAntes} → ${e.emocDespues} · Confianza ${e.confianza}/10 · Disciplina ${e.disciplina}/10</div>
        <div class="dj-card-preview">${preview}</div>
      </div>
      <div class="dj-card-badges">${planBadge}</div>
      <div class="dj-card-actions" onclick="event.stopPropagation()">
        <button class="dj-action-btn edit" onclick="djStartEdit('${e.id}')">✏</button>
        <button class="dj-action-btn del"  onclick="djDelete('${e.id}')">✕</button>
      </div>
    </div>
    <div class="dj-card-body">
      <div class="dj-detail-grid">
        ${djDetailField('Seguí el plan', e.siguioPlan)}
        ${djDetailField('Estado emocional antes', e.emocAntes)}
        ${djDetailField('Estado emocional después', e.emocDespues)}
        ${djDetailField('Confianza', e.confianza+'/10')}
        ${djDetailField('Disciplina', e.disciplina+'/10')}
      </div>
      <hr class="dj-detail-sep">
      ${e.bienes   ? djDetailFull('Qué hice bien', e.bienes)   : ''}
      ${e.males    ? djDetailFull('Errores / Qué hice mal', e.males) : ''}
      ${e.aprendi  ? djDetailFull('Qué aprendí', e.aprendi)    : ''}
      ${e.mejorar  ? djDetailFull('Qué mejorar', e.mejorar)    : ''}
      ${e.nota     ? djDetailFull('Nota libre', e.nota)         : ''}
      ${e.imagenes && e.imagenes.length ? `
        <hr class="dj-detail-sep">
        <div class="dj-detail-lbl" style="margin-bottom:6px">Imágenes (${e.imagenes.length})</div>
        <div class="dj-detail-imgs">${e.imagenes.map(src=>
          `<img class="dj-img-thumb" src="${src}" style="width:110px;height:78px" onclick="djViewImg('${src}')">`
        ).join('')}</div>` : ''}
    </div>
  </div>`;
}

function djDetailField(lbl, val){
  return `<div class="dj-detail-field">
    <div class="dj-detail-lbl">${lbl}</div>
    <div class="dj-detail-val">${val||'—'}</div>
  </div>`;
}
function djDetailFull(lbl, val){
  return `<div class="dj-detail-field" style="margin-bottom:10px">
    <div class="dj-detail-lbl">${lbl}</div>
    <div class="dj-detail-val">${val||'—'}</div>
  </div>`;
}

function djToggleCard(id){
  const card = document.getElementById('djcard-'+id);
  if(card) card.classList.toggle('expanded');
}

function djStartEdit(id){
  djEdit = id;
  djView = 'form';
  djRender();
}

function djDelete(id){
  if(!confirm('¿Eliminar esta entrada?')) return;
  const entries = djLoad().filter(e=>e.id!==id);
  djSave(entries);
  djRender();
}

// ── Auto-init ────────────────────────────────
