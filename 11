    document.getElementById(id).textContent=val;
    const item=document.getElementById(id.replace('mv-','mb-'));
    if(item&&cls) item.className='mbar-item '+cls;
  };

  if(stats){
    set('mv-wr', stats.wr.toFixed(1)+'%', stats.wr>=60?'m-g':stats.wr>=50?'m-a':'m-r');
    set('mv-pf', stats.pf>=99?'∞':stats.pf.toFixed(2), stats.pf>=1.5?'m-g':stats.pf>=1?'m-a':'m-r');
    set('mv-ev', (stats.ev>=0?'+':'')+stats.ev.toFixed(2)+'R', stats.ev>0?'m-g':'m-r');
    set('mv-cases', stats.total, 'm-b');
    document.getElementById('mv-wins').textContent   = stats.wins;
    document.getElementById('mv-losses').textContent = stats.losses;
    set('mv-mdd', stats.maxDD.toFixed(1)+'R', stats.maxDD>5?'m-r':stats.maxDD>2?'m-a':'m-n');
    const rrtSign=stats.rrTotal>=0?'+':'';
    set('mv-rrt', rrtSign+stats.rrTotal.toFixed(1)+'R', stats.rrTotal>=0?'m-g':'m-r');
  } else {
    ['mv-wr','mv-pf','mv-ev','mv-cases','mv-wins','mv-losses','mv-mdd','mv-rrt'].forEach(id=>document.getElementById(id).textContent='—');
  }
}

