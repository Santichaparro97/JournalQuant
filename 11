function efRestoreVarState(){
  const canvas = document.getElementById('ef-var-grid-inner');
  if(!canvas) return;
  const state = window._efVarState ||
    (()=>{ try{ return JSON.parse(localStorage.getItem(EF_STATE_KEY)||'null'); }catch(e){return null;} })();
