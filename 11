// Map month names to numbers (handles Spanish month names in CSV)
const MONTH_MAP = {
  'enero':1,'febrero':2,'marzo':3,'abril':4,'mayo':5,'junio':6,
  'julio':7,'agosto':8,'septiembre':9,'octubre':10,'noviembre':11,'diciembre':12,
  'january':1,'february':2,'march':3,'april':4,'may':5,'june':6,
  'july':7,'august':8,'september':9,'october':10,'november':11,'december':12,
  'jan':1,'feb':2,'mar':3,'apr':4,'jun':6,'jul':7,'aug':8,'sep':9,'oct':10,'nov':11,'dec':12
};

// Map day names across languages to a canonical value
const DAY_MAP = {
  // Spanish
  'lunes':'lunes','martes':'martes','miércoles':'miercoles','miercoles':'miercoles',
  'jueves':'jueves','viernes':'viernes','sábado':'sabado','sabado':'sabado','domingo':'domingo',
  // English
  'monday':'lunes','tuesday':'martes','wednesday':'miercoles',
  'thursday':'jueves','friday':'viernes','saturday':'sabado','sunday':'domingo',
  // Abbreviated English
  'mon':'lunes','tue':'martes','wed':'miercoles','thu':'jueves','fri':'viernes','sat':'sabado','sun':'domingo',
  // Abbreviated Spanish
  'lun':'lunes','mar':'martes','mie':'miercoles','mié':'miercoles','jue':'jueves','vie':'viernes'
};

function normDay(v){
  return DAY_MAP[(v||'').toLowerCase().trim()] || (v||'').toLowerCase().trim();
}

function toMonthNum(v){
  const n = parseInt(v, 10);
  if(!isNaN(n)) return n;
  return MONTH_MAP[(v||'').toLowerCase().trim()] || null;
}

function normBool(v){
  const u = v.toUpperCase().trim();
  if(u==='TRUE'||u==='SI'||u==='S'||u==='1'||u==='YES') return 'SI';
  if(u==='FALSE'||u==='NO'||u==='N'||u==='0') return 'NO';
  return u;
}

function filterTrades(filters){
  return csvData.filter(row=>{
    // Exclude no-fill trades before any filter check
    if(!isExecuted(row)) return false;

    return Object.entries(filters).every(([k,v])=>{
      if(!v) return true;
      const col = CMAP[k]; if(!col) return true;
      const cell = (row[col]||'').toString().trim();
      if(!cell) return false;

      if(k === 'dia'){
        return normDay(cell) === normDay(v);
      }
      if(k === 'mes'){
        const cellN = toMonthNum(cell);
        const valN  = toMonthNum(v);
        if(cellN && valN) return cellN === valN;
        return cell.toUpperCase() === v.toUpperCase();
      }
      if(k === 'semana'){
        return parseInt(cell,10) === parseInt(v,10);
      }
      if(k==='smt'||k==='es'){
        return normBool(cell) === normBool(v);
      }
      return cell.toUpperCase() === v.toUpperCase();
    });
  });
}

