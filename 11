// ── Tab drag reorder ──────────────────────────
function efInitTabDrag(){
  const bar = document.getElementById('ef-tabs-bar');
  if(!bar) return;
  let dragged = null;

  bar.querySelectorAll('.ef-tab').forEach(tab=>{
    tab.draggable = true;

    tab.addEventListener('click', ()=> showETab(tab.dataset.tab));

    tab.addEventListener('dragstart', e=>{
      dragged = tab;
      setTimeout(()=>tab.classList.add('tab-dragging'),0);
      e.dataTransfer.effectAllowed='move';
    });
    tab.addEventListener('dragend', ()=>{
      tab.classList.remove('tab-dragging');
      bar.querySelectorAll('.ef-tab').forEach(t=>t.classList.remove('tab-drag-over'));
      dragged=null;
    });
    tab.addEventListener('dragover', e=>{
      e.preventDefault();
      if(dragged && tab!==dragged){
        bar.querySelectorAll('.ef-tab').forEach(t=>t.classList.remove('tab-drag-over'));
        tab.classList.add('tab-drag-over');
      }
    });
    tab.addEventListener('drop', e=>{
      e.preventDefault();
      if(dragged && tab!==dragged){
        const tabs=[...bar.querySelectorAll('.ef-tab')];
        const fi=tabs.indexOf(dragged), ti=tabs.indexOf(tab);
        if(fi<ti) bar.insertBefore(dragged,tab.nextSibling);
        else      bar.insertBefore(dragged,tab);
        tab.classList.remove('tab-drag-over');
      }
    });
  });
}

