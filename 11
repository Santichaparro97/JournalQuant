// ── Stats engine ─────────────────────────────
function efCalcStats(trades){
  // Strip no-fill trades
  const exec = trades.filter(isExecuted);
  if(!exec||!exec.length) return null;
  let w=0, l=0, rrs=[], curStreak=0, maxCL=0;
  const curve = [0];

  exec.forEach(t=>{
    const rr  = getRR(t);
    const res = (t[RES_COL]||'').toString().trim().toUpperCase();
    let win;
    if(res.includes('WIN'))       win = true;
    else if(res.includes('LOSS')) win = false;
    else                          win = rr !== null ? rr > 0 : false;

    if(win){ w++; curStreak=0; }
    else   { l++; curStreak++; if(curStreak>maxCL) maxCL=curStreak; }

    const rrUsed = rr !== null ? rr : (win?1:-1);
    rrs.push(rrUsed);
    curve.push(curve[curve.length-1] + rrUsed);
  });

  const n=w+l, wr=n>0?w/n*100:0;
  const wRR=rrs.filter(r=>r>0), lRR=rrs.filter(r=>r<0);
  const sw=wRR.reduce((a,b)=>a+b,0), sl=Math.abs(lRR.reduce((a,b)=>a+b,0));
  const pf=sl>0?sw/sl:(sw>0?99:0);
  const rrT=rrs.reduce((a,b)=>a+b,0), avg=rrs.length?rrT/rrs.length:0;
  const avgWin  = wRR.length ? sw/wRR.length : 0;
  const avgLoss = lRR.length ? sl/lRR.length : 1;
  const ev = (wr/100)*avgWin - ((1-wr/100))*avgLoss;

  let dd=0, pk=curve[0];
  for(let i=1;i<curve.length;i++){
    if(curve[i]>pk) pk=curve[i];
    const d=pk-curve[i]; if(d>dd) dd=d;
  }

  return{n,w,l,wr,pf,ev,avg,dd,rrT,maxCL};
}

function efGroupBy(trades, col){
  const m={};
  trades.forEach(t=>{ const k=(t[col]||'—').toString().trim(); if(!m[k])m[k]=[]; m[k].push(t); });
  return Object.entries(m).map(([val,ts])=>({val,ts,s:efCalcStats(ts)}))
    .filter(g=>g.s)
    .sort((a,b)=>{ const na=parseFloat(a.val),nb=parseFloat(b.val); if(!isNaN(na)&&!isNaN(nb))return na-nb; return a.val.localeCompare(b.val); });
}

function efGroupBy2(trades, c1, c2){
  const m={};
  trades.forEach(t=>{
    const k1=(t[c1]||'—').trim(), k2=(t[c2]||'—').trim(), k=k1+'|||'+k2;
    if(!m[k])m[k]={k1,k2,ts:[]}; m[k].ts.push(t);
  });
  return Object.values(m).map(g=>({...g,s:efCalcStats(g.ts)})).filter(g=>g.s);
}

// ── Helpers ───────────────────────────────────
function efFmt(v){ return (v>=0?'+':'')+v.toFixed(1)+'R'; }
function efClrRR(v){ if(v>4)return'ef-pos ef-cp3'; if(v>1)return'ef-pos ef-cp2'; if(v>0)return'ef-pos ef-cp1'; if(v<-2)return'ef-neg ef-cn2'; return v<0?'ef-neg ef-cn1':'ef-c0'; }
function efClrWR(v){ return v>=60?'ef-pos':v>=50?'ef-neu':'ef-neg'; }
function efClrPF(v){ return v>=1.5?'ef-pos':v>=1?'ef-neu':'ef-neg'; }
function efMaxAbs(gs){ return Math.max(...gs.map(g=>Math.abs(g.s.rrT)),1); }

function efVarTable(groups, lbl){
  if(!groups.length) return `<div class="ef-empty">Sin datos para ${lbl}</div>`;
  const mx = efMaxAbs(groups);
  return `<table class="ef-tbl">
    <thead><tr>
      <th>${lbl}</th>
      <th class="r">Trades</th><th class="r">W</th><th class="r">L</th>
      <th class="r">WR%</th><th class="r">RR Total</th><th class="r">PF</th>
    </tr></thead>
    <tbody>${groups.map(g=>{
      const s=g.s, bw=Math.round(Math.abs(s.rrT)/mx*80), bc=s.rrT>=0?'var(--green2)':'var(--red2)';
      return `<tr>
        <td class="lbl">${g.val}</td>
        <td class="r ef-dim">${s.n}</td>
        <td class="r ef-dim">${s.w}</td>
        <td class="r ef-dim">${s.l}</td>
        <td class="r ${efClrWR(s.wr)}">${s.wr.toFixed(0)}%
          <span class="ef-wr-bar-o" style="margin-left:4px">
            <span class="ef-wr-bar-i" style="width:${s.wr}%;background:${s.wr>=55?'var(--green2)':'var(--red2)'}"></span>
          </span>
        </td>
        <td class="r ${efClrRR(s.rrT)}">
          <span class="ef-rr-bar-wrap">${efFmt(s.rrT)}
            <span class="ef-rr-bar" style="width:${bw}px;background:${bc}"></span>
          </span>
        </td>
        <td class="r ${efClrPF(s.pf)}">${s.pf>=99?'∞':s.pf.toFixed(2)}</td>
      </tr>`;
    }).join('')}</tbody>
  </table>`;
}

function efCombTable(groups, l1, l2, min=5){
  const f = groups.filter(g=>g.s.n>=min).sort((a,b)=>b.s.rrT-a.s.rrT).slice(0,12);
  if(!f.length) return `<div class="ef-empty">Sin combinaciones con ≥${min} trades</div>`;
  const mx = efMaxAbs(f);
  return `<table class="ef-tbl">
    <thead><tr>
      <th>${l1}</th><th>${l2}</th>
      <th class="r">Trades</th><th class="r">WR%</th>
      <th class="r">RR Total</th><th class="r">PF</th><th class="r">EV</th>
    </tr></thead>
    <tbody>${f.map(g=>{
      const s=g.s, bw=Math.round(Math.abs(s.rrT)/mx*80), bc=s.rrT>=0?'var(--green2)':'var(--red2)';
      return `<tr>
        <td class="lbl">${g.k1}</td><td class="lbl">${g.k2}</td>
        <td class="r ef-dim">${s.n}</td>
        <td class="r ${efClrWR(s.wr)}">${s.wr.toFixed(0)}%</td>
        <td class="r ${efClrRR(s.rrT)}">
          <span class="ef-rr-bar-wrap">${efFmt(s.rrT)}
            <span class="ef-rr-bar" style="width:${bw}px;background:${bc}"></span>
          </span>
        </td>
        <td class="r ${efClrPF(s.pf)}">${s.pf>=99?'∞':s.pf.toFixed(2)}</td>
        <td class="r ${s.ev>0?'ef-pos':'ef-neg'}">${(s.ev>=0?'+':'')+s.ev.toFixed(2)}R</td>
      </tr>`;
    }).join('')}</tbody>
  </table>`;
}

function efMatrix(c1, c2, metric){
  const sort = arr => arr.sort((a,b)=>{ const na=parseFloat(a),nb=parseFloat(b); if(!isNaN(na)&&!isNaN(nb))return na-nb; return a.localeCompare(b); });
  const xs = sort([...new Set(efWorkTrades.map(t=>(t[c1]||'—').trim()))]);
  const ys = sort([...new Set(efWorkTrades.map(t=>(t[c2]||'—').trim()))]);
  const lk = {};
  efWorkTrades.forEach(t=>{ const k=(t[c1]||'—').trim()+'|||'+(t[c2]||'—').trim(); if(!lk[k])lk[k]=[]; lk[k].push(t); });

  const vals = [];
  xs.forEach(x=>ys.forEach(y=>{ const s=efCalcStats(lk[x+'|||'+y]||[]); if(s) vals.push(metric==='wr'?s.wr:metric==='n'?s.n:s.rrT); }));
  if(!vals.length) return '<div class="ef-empty">Sin datos</div>';
  const mx = Math.max(...vals.map(Math.abs),1);

  function cls(v, m){
    if(m==='n') return v>0?'ef-cp1':'ef-c0';
    if(m==='wr'){ if(v>=70)return'ef-cp3'; if(v>=60)return'ef-cp2'; if(v>=50)return'ef-cp1'; if(v>=40)return'ef-cn1'; if(v>=30)return'ef-cn2'; return'ef-cn3'; }
    const p=v/mx; if(p>0.6)return'ef-cp3'; if(p>0.2)return'ef-cp2'; if(p>0)return'ef-cp1'; if(p>-0.2)return'ef-cn1'; if(p>-0.6)return'ef-cn2'; return'ef-cn3';
  }
  function fmt(s,m){ if(!s)return'—'; if(m==='wr')return s.wr.toFixed(0)+'%'; if(m==='n')return s.n; return efFmt(s.rrT); }

  const l1 = EF_VARS.find(v=>v.col===c1)?.lbl||c1;
  const l2 = EF_VARS.find(v=>v.col===c2)?.lbl||c2;
  return `<table class="ef-mx-tbl">
    <thead><tr>
      <th class="rh">${l2} \\ ${l1}</th>
      ${xs.map(x=>`<th>${x}</th>`).join('')}
    </tr></thead>
    <tbody>${ys.map(y=>`<tr>
      <td class="rl">${y}</td>
      ${xs.map(x=>{
        const s=efCalcStats(lk[x+'|||'+y]||[]);
        const v=s?(metric==='wr'?s.wr:metric==='n'?s.n:s.rrT):null;
        if(v===null)return'<td class="ef-c0">—</td>';
        return `<td class="${cls(v,metric)}" title="${s.n} trades">${fmt(s,metric)}</td>`;
      }).join('')}
    </tr>`).join('')}</tbody>
  </table>`;
}

// ── Render functions ───────────────────────────
function efRenderOverview(){
  const t = efWorkTrades;
  const s = efCalcStats(t);
