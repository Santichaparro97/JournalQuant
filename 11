<noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
<style>
/* ── TOKENS ─────────────────────────────────────── */
:root {
  --bg:     #07090c;
  --s1:     #0c1118;
  --s2:     #111820;
  --s3:     #16202c;
  --bd:     #1e2d3d;
  --bd2:    #263648;
  --green:  #16a34a;
  --green2: #22c55e;
  --gd:     rgba(22,163,74,.12);
  --red:    #dc2626;
  --red2:   #ef4444;
  --rd:     rgba(220,38,38,.12);
  --amber:  #d97706;
  --amber2: #f59e0b;
  --ad:     rgba(217,119,6,.12);
  --blue:   #1d4ed8;
  --blue2:  #3b82f6;
  --bd_:    rgba(29,78,216,.12);
  --tx:     #e2eaf2;
  --t2:     #8fa4b8;
  --t3:     #364e62;
  --sans:   'Inter', sans-serif;
  --mono:   'JetBrains Mono', monospace;
  --hh:     40px;
  --rw:     4px;
}

/* ── LIGHT MODE ──────────────────────────────────── */
[data-theme="light"] {
  --bg:     #f5efe6;
  --s1:     #fdf8f2;
  --s2:     #f0e8dc;
  --s3:     #e8ddd0;
  --bd:     #d4c8b8;
  --bd2:    #c0b4a0;
  --green:  #16a34a;
  --green2: #15803d;
  --gd:     rgba(22,163,74,.10);
  --red:    #dc2626;
  --red2:   #b91c1c;
  --rd:     rgba(220,38,38,.10);
  --amber:  #d97706;
  --amber2: #92400e;
  --ad:     rgba(217,119,6,.10);
  --blue:   #1d4ed8;
  --blue2:  #1e40af;
  --bd_:    rgba(29,78,216,.08);
  --tx:     #2c1f0e;
  --t2:     #5c4a36;
  --t3:     #a08060;
}
[data-theme="light"] html,
[data-theme="light"] body,
[data-theme="light"] #main,
[data-theme="light"] #hdr,
[data-theme="light"] #mbar {
  background: linear-gradient(135deg, #f5efe6 0%, #ede0ce 50%, #e8d5bc 100%) !important;
}
[data-theme="light"] .col,
[data-theme="light"] .cbody { background: transparent; }

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--tx); font-family: var(--sans); font-size: 12px; }

/* ── HEADER ─────────────────────────────────────── */
#hdr {
  height: var(--hh);
  background: var(--s1);
  border-bottom: 1px solid var(--bd);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 14px;
  flex-shrink: 0;
  z-index: 200;
}

.h-logo { font-weight: 800; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: var(--blue2); }
.h-logo em { color: var(--green2); font-style: normal; }

.h-right { display: flex; align-items: center; gap: 10px; }

.h-btn {
  background: var(--s2); border: 1px solid var(--bd2); color: var(--t2);
  font-family: var(--mono); font-size: 10px; letter-spacing: .5px;
  padding: 3px 10px; border-radius: 3px; cursor: pointer; transition: all .12s; font-weight: 600;
}
.h-btn:hover { border-color: var(--blue2); color: var(--blue2); }

.h-tag { font-family: var(--mono); font-size: 10px; font-weight: 700; }
.h-tag.ok  { color: var(--green2); }
.h-tag.off { color: var(--t3); }

#h-clock { font-family: var(--mono); font-size: 11px; font-weight: 600; color: var(--t2); }

/* ── METRICS BAR ────────────────────────────────── */
#mbar {
  height: 44px;
  background: var(--s1);
  border-bottom: 1px solid var(--bd);
  display: flex;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
  overflow: hidden;
}

.mbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 16px;
  border-right: 1px solid var(--bd);
  height: 100%;
  min-width: 80px;
}

.mbar-lbl { font-size: 8px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--t3); margin-bottom: 2px; }
.mbar-val { font-family: var(--mono); font-size: 14px; font-weight: 700; line-height: 1; }

.m-g .mbar-val { color: var(--green2); }
.m-r .mbar-val { color: var(--red2); }
.m-a .mbar-val { color: var(--amber2); }
.m-b .mbar-val { color: var(--blue2); }
.m-n .mbar-val { color: var(--tx); }

.mbar-alerts {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  padding: 0 12px;
  align-items: center;
}

.malert {
  font-size: 9px; font-weight: 700; letter-spacing: .5px;
  padding: 2px 8px; border-radius: 2px; text-transform: uppercase;
}
.ma-ok   { background: var(--gd); border: 1px solid rgba(34,197,94,.3); color: var(--green2); }
.ma-warn { background: var(--ad); border: 1px solid rgba(245,158,11,.3); color: var(--amber2); }
.ma-bad  { background: var(--rd); border: 1px solid rgba(239,68,68,.3);  color: var(--red2); }

/* ── 4-COL LAYOUT ───────────────────────────────── */
#main { display: flex; height: calc(100vh - var(--hh) - 44px); overflow: hidden; }

.col { display: flex; flex-direction: column; overflow: hidden; min-width: 80px; position: relative; }

#c1 { flex: 0 0 210px; }
#c2 { flex: 0 0 400px; }
#c3 { flex: 0 0 310px; }
#c4 { flex: 1 1 auto; }

/* Col header */
.chdr {
  height: 30px; background: var(--s2); border-bottom: 1px solid var(--bd);
  border-right: 1px solid var(--bd); display: flex; align-items: center;
  padding: 0 12px; justify-content: space-between; flex-shrink: 0;
}
.chdr-title { font-size: 9px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--t2); }
.chdr-badge { font-family: var(--mono); font-size: 9px; font-weight: 700; color: var(--blue2); }

.cbody {
  flex: 1; overflow-y: auto; overflow-x: hidden;
  border-right: 1px solid var(--bd);
}
.cbody::-webkit-scrollbar { width: 3px; }
.cbody::-webkit-scrollbar-thumb { background: var(--bd2); border-radius: 2px; }

/* Resize */
.rh {
  width: var(--rw); background: transparent; cursor: col-resize;
  position: absolute; right: 0; top: 0; bottom: 0; z-index: 50; transition: background .12s;
}
.rh:hover, .rh.drag { background: rgba(59,130,246,.4); }

/* ── C1 CHECKLIST ───────────────────────────────── */
.fsec { padding: 8px 10px 4px; border-bottom: 1px solid var(--bd); }

.fsec-title {
  font-size: 7px; font-weight: 800; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--t3); margin-bottom: 7px; padding-bottom: 4px; border-bottom: 1px solid var(--bd);
}

.frow { display: flex; flex-direction: column; margin-bottom: 5px; }

.frow label {
  font-size: 8px; font-weight: 700; letter-spacing: 1px; color: var(--t2);
  text-transform: uppercase; margin-bottom: 3px;
}

.frow select {
  background: var(--s2); border: 1px solid var(--bd2); color: var(--tx);
  font-family: var(--mono); font-size: 10px; font-weight: 600;
  padding: 4px 8px; border-radius: 3px; outline: none; width: 100%;
  -webkit-appearance: none; appearance: none; transition: border-color .12s; cursor: pointer;
}
.frow select:focus { border-color: var(--blue2); }
.frow select.active { border-color: rgba(59,130,246,.5); background: rgba(59,130,246,.06); }
.frow select option { background: #0c1118; }

.c1-btns { padding: 10px; display: flex; flex-direction: column; gap: 6px; }

#run-btn {
  padding: 9px; background: var(--blue2); border: none; border-radius: 4px;
  font-family: var(--sans); font-size: 11px; font-weight: 800;
  letter-spacing: 1.5px; color: #fff; cursor: pointer; transition: background .12s;
  text-transform: uppercase; width: 100%;
}
#run-btn:hover { background: #2563eb; }

#clr-btn {
  padding: 6px; background: transparent; border: 1px solid var(--bd);
  border-radius: 4px; font-family: var(--sans); font-size: 10px; font-weight: 700;
  letter-spacing: 1px; color: var(--t3); cursor: pointer; transition: all .12s;
  text-transform: uppercase; width: 100%;
}
#clr-btn:hover { border-color: var(--t2); color: var(--t2); }

/* ── C2 STATS + TRADES ─────────────────────────── */
.scards {
  display: grid; grid-template-columns: repeat(2,1fr);
  gap: 1px; background: var(--bd); border-bottom: 1px solid var(--bd);
}

.scard { background: var(--s1); padding: 10px 12px; }
.sc-lbl { font-size: 7px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--t3); margin-bottom: 4px; }
.sc-val { font-family: var(--mono); font-size: 16px; font-weight: 700; line-height: 1; }
.sc-sub { font-size: 8px; font-weight: 600; color: var(--t3); margin-top: 2px; }
.sc-g .sc-val { color: var(--green2); }
.sc-r .sc-val { color: var(--red2); }
.sc-a .sc-val { color: var(--amber2); }
.sc-b .sc-val { color: var(--blue2); }
.sc-n .sc-val { color: var(--tx); }

.wbar-wrap { padding: 7px 12px; border-bottom: 1px solid var(--bd); background: var(--s1); }
.wbar-top { display: flex; justify-content: space-between; font-size: 8px; font-weight: 700; color: var(--t2); margin-bottom: 4px; }
.wbar { height: 3px; background: var(--bd); border-radius: 2px; display: flex; overflow: hidden; }
.wbar-g { background: var(--green2); height: 100%; transition: width .4s; }
.wbar-r { background: var(--red2); height: 100%; transition: width .4s; }

.trades-hdr-row {
  padding: 6px 12px; font-size: 7px; font-weight: 800; letter-spacing: 2px;
  text-transform: uppercase; color: var(--t3); border-bottom: 1px solid var(--bd);
  background: var(--s2);
}

.th-cols {
  display: grid;
  grid-template-columns: 72px 52px 52px 1fr;
  gap: 4px; padding: 5px 12px;
  font-size: 7px; font-weight: 800; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--t3);
  border-bottom: 1px solid var(--bd); background: var(--s2);
}

.tr-row {
  display: grid;
  grid-template-columns: 72px 52px 52px 1fr;
  gap: 4px; padding: 5px 12px;
  border-bottom: 1px solid rgba(30,45,61,.6);
  font-size: 10px; font-weight: 600;
  transition: background .08s; cursor: default;
  align-items: center;
}
.tr-row:hover { background: rgba(59,130,246,.04); }
.tr-row.tw { border-left: 2px solid var(--green2); }
.tr-row.tl { border-left: 2px solid var(--red2); }
.tx-g { color: var(--green2); font-weight: 700; }
.tx-r { color: var(--red2); font-weight: 700; }
.tx-d { color: var(--t2); }
.tx-3 { color: var(--t3); }

/* Observation expand */
.obs-cell { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; cursor: pointer; color: var(--t2); font-weight: 500; font-size: 9px; }
.obs-cell:hover { color: var(--blue2); text-decoration: underline; }

/* Obs modal */
#obs-modal {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,.75);
  z-index: 9999; align-items: center; justify-content: center;
}
#obs-modal.open { display: flex; }
#obs-inner {
  background: var(--s1); border: 1px solid var(--bd2); border-radius: 6px;
  padding: 22px 22px 18px; max-width: 520px; width: 92%; position: relative;
  max-height: 80vh; display: flex; flex-direction: column;
}
#obs-inner-label {
  font-size: 7px; font-weight: 800; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--t3); margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid var(--bd);
}
#obs-text {
  font-size: 12px; font-weight: 500; line-height: 1.8; color: var(--tx);
  white-space: pre-wrap; word-break: break-word;
  overflow-y: auto; flex: 1;
}
#obs-text::-webkit-scrollbar { width: 3px; }
#obs-text::-webkit-scrollbar-thumb { background: var(--bd2); border-radius: 2px; }
#obs-close {
  position: absolute; top: 10px; right: 12px; background: none;
  border: 1px solid var(--bd); color: var(--t2); font-size: 10px;
  font-weight: 700; padding: 2px 9px; cursor: pointer; border-radius: 3px;
  transition: all .12s;
}
#obs-close:hover { border-color: var(--red2); color: var(--red2); }

/* Clickable obs cell */
.obs-clickable {
  cursor: pointer !important;
  color: var(--b2) !important;
  text-decoration: underline dotted !important;
  text-underline-offset: 3px;
}

/* Empty */
.empty-st { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; gap: 7px; color: var(--t3); text-align: center; }
.empty-icon { font-size: 20px; opacity: .3; }
.empty-ttl { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; }
.empty-sub { font-size: 9px; font-weight: 600; }

/* ── C3 DECISION ANALYSIS ───────────────────────── */
.dae-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 100%; gap: 8px; color: var(--t3); text-align: center; padding: 20px;
}
.dae-empty-icon  { font-size: 20px; opacity: .3; }
.dae-empty-title { font-size: 9px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; }
.dae-empty-sub   { font-size: 8px; font-weight: 600; color: var(--t3); line-height: 1.6; }

/* 1. DECISION BLOCK */
.dae-decision {
  padding: 14px 14px 12px;
  border-bottom: 1px solid var(--bd);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.dae-verdict-main {
  font-family: var(--sans);
  font-size: 26px;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
  line-height: 1;
}

.dv-aplus  { color: var(--green2); }
.dv-a      { color: #4ade80; }
.dv-reduce { color: var(--amber2); }
.dv-no     { color: var(--red2); }

.dae-confidence-row { display: flex; align-items: center; gap: 8px; }
.dae-conf-bar-track { flex: 1; height: 4px; background: var(--bd); border-radius: 2px; overflow: hidden; }
.dae-conf-bar-fill  { height: 100%; border-radius: 2px; transition: width .5s; }
.dae-conf-pct { font-family: var(--mono); font-size: 11px; font-weight: 700; min-width: 38px; text-align: right; }

/* 2. CONTEXT QUICK */
.dae-ctx {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1px; background: var(--bd); border-bottom: 1px solid var(--bd);
}

.dae-ctx-item { background: var(--s1); padding: 8px 11px; }
.dae-ctx-lbl { font-size: 7px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--t3); margin-bottom: 3px; }
.dae-ctx-val { font-family: var(--mono); font-size: 14px; font-weight: 700; }
.dctx-g .dae-ctx-val { color: var(--green2); }
.dctx-r .dae-ctx-val { color: var(--red2); }
.dctx-a .dae-ctx-val { color: var(--amber2); }
.dctx-n .dae-ctx-val { color: var(--tx); }

/* 3. FACTORS */
.dae-factors { padding: 10px 12px; border-bottom: 1px solid var(--bd); }
.dae-factors-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }

.fbox { border-radius: 3px; padding: 7px 9px; }
.fbox-favor  { background: var(--gd); border: 1px solid rgba(34,197,94,.2); }
.fbox-contra { background: var(--rd); border: 1px solid rgba(239,68,68,.2); }

.fbox-title { font-size: 7px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 5px; }
.fbox-favor  .fbox-title { color: var(--green2); }
.fbox-contra .fbox-title { color: var(--red2); }

.fbox-item {
  font-size: 9px; font-weight: 600; line-height: 1.55; color: var(--t2);
  padding-left: 6px; border-left: 1.5px solid var(--bd2); margin-bottom: 3px;
}

/* 4. ACTION */
.dae-action { padding: 10px 12px; border-bottom: 1px solid var(--bd); }

.action-box {
  border-radius: 4px; padding: 10px 12px;
  display: flex; align-items: center; gap: 10px;
}

.action-box.trade   { background: var(--gd); border: 1px solid rgba(34,197,94,.3); }
.action-box.reduce  { background: var(--ad); border: 1px solid rgba(245,158,11,.3); }
.action-box.notrade { background: var(--rd); border: 1px solid rgba(239,68,68,.3); }
.action-box.wait    { background: var(--bd_); border: 1px solid rgba(59,130,246,.3); }

.action-icon { font-size: 18px; flex-shrink: 0; }

.action-cmd { font-family: var(--sans); font-size: 14px; font-weight: 800; letter-spacing: .5px; text-transform: uppercase; line-height: 1; }
.action-sub { font-size: 9px; font-weight: 600; color: var(--t2); margin-top: 3px; }

.action-box.trade   .action-cmd { color: var(--green2); }
.action-box.reduce  .action-cmd { color: var(--amber2); }
.action-box.notrade .action-cmd { color: var(--red2); }
.action-box.wait    .action-cmd { color: var(--blue2); }

/* 5. WHAT'S MISSING */
.dae-missing { padding: 10px 12px; border-bottom: 1px solid var(--bd); }
.dae-sec-title { font-size: 7px; font-weight: 800; letter-spacing: 2.5px; text-transform: uppercase; color: var(--t3); margin-bottom: 6px; }

.miss-item {
  display: flex; align-items: flex-start; gap: 6px;
  font-size: 9px; font-weight: 600; color: var(--t2); line-height: 1.5; margin-bottom: 4px;
}
.miss-bullet { color: var(--amber2); flex-shrink: 0; font-size: 8px; margin-top: 2px; }

/* 6. VALIDATION */
.dae-validation { padding: 10px 12px; }
.dae-val-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
.val-item { background: var(--s2); border: 1px solid var(--bd); border-radius: 3px; padding: 6px 9px; }
.val-lbl { font-size: 7px; font-weight: 800; letter-spacing: 1.5px; color: var(--t3); text-transform: uppercase; margin-bottom: 2px; }
.val-val { font-family: var(--mono); font-size: 13px; font-weight: 700; }
.vv-g .val-val { color: var(--green2); }
.vv-r .val-val { color: var(--red2); }
.vv-a .val-val { color: var(--amber2); }
.vv-n .val-val { color: var(--tx); }

/* ── C4 GALLERY — FOLDER EXPLORER ────────────── */
.gal-toolbar {
  padding: 7px 10px; border-bottom: 1px solid var(--bd);
  background: var(--s2); flex-shrink: 0; display: flex; flex-direction: column; gap: 5px;
}

.gal-upload-row { display: flex; gap: 5px; }

.gal-ubtn {
  flex: 1; background: var(--s2); border: 1px solid var(--bd2); color: var(--t2);
  font-family: var(--sans); font-size: 9px; font-weight: 700; letter-spacing: .5px;
  padding: 5px 8px; border-radius: 3px; cursor: pointer; transition: all .12s; text-align: center;
}
.gal-ubtn:hover { border-color: var(--blue2); color: var(--blue2); }

.gal-breadcrumb {
  display: flex; align-items: center; gap: 4px; flex-wrap: wrap;
  font-size: 9px; font-weight: 700; color: var(--t2); padding-top: 2px;
}
.bc-part { cursor: pointer; color: var(--blue2); transition: opacity .12s; }
.bc-part:hover { opacity: .7; text-decoration: underline; }
.bc-sep { color: var(--t3); }
.bc-current { color: var(--t2); cursor: default; }

.cur-chart-wrap { position: relative; margin: 6px 10px 0; display: none; }
.cur-chart-wrap img { width: 100%; border-radius: 4px; border: 1px solid var(--blue2); display: block; }
.cur-chart-tag {
  position: absolute; top: 4px; left: 4px; background: var(--blue2); color: #fff;
  font-size: 7px; font-weight: 800; letter-spacing: 1px; padding: 2px 6px; border-radius: 2px; text-transform: uppercase;
}

.gal-scroll { flex: 1; overflow-y: auto; }
.gal-scroll::-webkit-scrollbar { width: 3px; }
.gal-scroll::-webkit-scrollbar-thumb { background: var(--bd2); }

/* ROOT: 2 big target folders */
.folder-root { padding: 8px; display: flex; flex-direction: column; gap: 6px; }

.folder-card-big {
  background: var(--s2); border: 1px solid var(--bd2); border-radius: 6px;
  padding: 16px 14px; cursor: pointer; transition: all .15s;
  display: flex; align-items: center; gap: 12px;
}
.folder-card-big:hover { border-color: var(--blue2); background: rgba(59,130,246,.06); }
.folder-card-big.active-target { border-color: var(--blue2); background: rgba(59,130,246,.08); }

.fcb-icon { font-size: 22px; flex-shrink: 0; }
.fcb-info { flex: 1; }
.fcb-name { font-size: 13px; font-weight: 800; color: var(--tx); letter-spacing: .5px; }
.fcb-sub  { font-size: 9px; font-weight: 600; color: var(--t2); margin-top: 3px; }
.fcb-count { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--blue2); }

/* LEVEL 1: 4 subfolder cards */
.folder-level1 { padding: 8px; display: flex; flex-direction: column; gap: 5px; }

.back-btn {
  display: flex; align-items: center; gap: 6px; padding: 6px 10px; margin-bottom: 4px;
  background: var(--s2); border: 1px solid var(--bd); border-radius: 4px;
  cursor: pointer; font-size: 10px; font-weight: 700; color: var(--t2); transition: all .12s;
}
.back-btn:hover { border-color: var(--blue2); color: var(--blue2); }

.subfolder-card {
  background: var(--s2); border: 1px solid var(--bd); border-radius: 5px;
  padding: 11px 13px; cursor: pointer; transition: all .12s;
  display: flex; align-items: center; gap: 10px;
}
.subfolder-card:hover { border-color: var(--blue2); background: rgba(59,130,246,.05); }
.subfolder-card.active-sub { border-color: var(--green2); background: rgba(34,197,94,.06); }
.subfolder-card.highlighted { border-color: var(--green2); box-shadow: 0 0 0 1px rgba(34,197,94,.3); }

.sfc-icon { font-size: 16px; flex-shrink: 0; color: var(--amber2); }
.sfc-name { font-size: 11px; font-weight: 800; color: var(--tx); }
.sfc-count { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--t2); margin-left: auto; }
.sfc-badge {
  font-size: 7px; font-weight: 800; letter-spacing: 1px; padding: 2px 6px;
  border-radius: 10px; text-transform: uppercase;
}
.sfc-badge-auto { background: var(--gd); border: 1px solid rgba(34,197,94,.3); color: var(--green2); }

.subfolder-upload-btn {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--s3); border: 1px solid var(--bd2); color: var(--blue2);
  font-size: 9px; font-weight: 800; letter-spacing: .5px;
  padding: 3px 9px; border-radius: 3px; cursor: pointer;
  transition: all .12s; white-space: nowrap; font-family: var(--sans);
  flex-shrink: 0;
}
.subfolder-upload-btn:hover { background: var(--blue2); color: #fff; border-color: var(--blue2); }

/* LEVEL 2: image grid */
.img-level { padding: 6px 8px; }

.img-level-info {
  padding: 6px 8px 8px; font-size: 8px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--t3);
  display: flex; justify-content: space-between; align-items: center;
}

.gal-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 5px; align-content: start;
}

.gcard {
  background: var(--s2); border: 1px solid var(--bd); border-radius: 4px;
  overflow: hidden; cursor: pointer; transition: all .12s;
  position: relative;
}
.gcard:hover { border-color: var(--blue2); transform: scale(1.03); box-shadow: 0 0 0 1px var(--blue2); }
.gcard:hover .gcard-del { opacity: 1; }

.gcard-del {
  position: absolute; top: 4px; right: 4px;
  width: 20px; height: 20px;
  background: rgba(220,38,38,.85); border: none; border-radius: 3px;
  color: #fff; font-size: 11px; font-weight: 800; line-height: 1;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity .15s; z-index: 10;
}
.gcard-del:hover { background: var(--red2); }

.gcard img { width: 100%; height: 90px; object-fit: cover; display: block; }

@keyframes fadeInImg {
  from { opacity: 0; transform: scale(.96); }
  to   { opacity: 1; transform: scale(1); }
}
.gcard-foot { padding: 4px 6px; display: flex; justify-content: space-between; align-items: center; }
.gcard-res { font-size: 8px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }
.gcard-rr  { font-family: var(--mono); font-size: 8px; font-weight: 700; color: var(--t2); }
.gw-txt { color: var(--green2); }
.gl-txt { color: var(--red2); }

.gal-ph {
  padding: 30px 16px; text-align: center; color: var(--t3);
  font-size: 10px; font-weight: 700; line-height: 2;
}

/* ── IMG MODAL ──────────────────────────────────── */
#img-modal {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,.88);
  z-index: 9998; align-items: center; justify-content: center;
}
#img-modal.open { display: flex; }
#img-inner { background: var(--s1); border: 1px solid var(--bd2); border-radius: 6px; max-width: 740px; max-height: 90vh; overflow-y: auto; padding: 18px; position: relative; width: 90%; }
#img-close { position: absolute; top: 10px; right: 12px; background: none; border: 1px solid var(--bd); color: var(--t2); font-family: var(--mono); font-size: 10px; font-weight: 700; padding: 2px 9px; cursor: pointer; border-radius: 3px; }
#img-close:hover { border-color: var(--red2); color: var(--red2); }
#img-modal-img { width: 100%; border-radius: 4px; margin-bottom: 10px; display: block; }
#img-modal-meta { display: flex; flex-wrap: wrap; gap: 5px; }
.mchip { background: var(--s2); border: 1px solid var(--bd2); padding: 3px 8px; border-radius: 3px; font-size: 9px; font-weight: 700; }
.img-nav { display: flex; justify-content: space-between; margin-top: 10px; }
.img-nav-btn { background: var(--s2); border: 1px solid var(--bd2); color: var(--t2); font-size: 10px; font-weight: 700; padding: 4px 14px; cursor: pointer; border-radius: 3px; transition: all .12s; }
.img-nav-btn:hover { border-color: var(--blue2); color: var(--blue2); }

/* ── HIDDEN INPUTS ──────────────────────────────── */
input[type="file"] { display: none; }

/* ── EDGE FINDER OVERLAY ─────────────────── */
.ef-tab {
  padding: 6px 14px 7px; font-size: 10px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; color: var(--t3); cursor: pointer;
  border-bottom: 2px solid transparent; transition: all .12s; user-select: none;
}
.ef-tab:hover { color: var(--t2); }
.ef-tab.active { color: var(--blue2); border-bottom-color: var(--blue2); }

/* ef-view base handled by absolute-positioned block below */

.ef-fsel {
  background: var(--s2); border: 1px solid var(--bd2); color: var(--tx);
  font-family: var(--mono); font-size: 9px; font-weight: 600;
  padding: 2px 6px; border-radius: 3px; outline: none; cursor: pointer;
  -webkit-appearance: none; appearance: none;
}
.ef-fsel option { background: #0c1118; }
.ef-fclr {
  background: transparent; border: 1px solid var(--bd); color: var(--t3);
  font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 3px; cursor: pointer;
  transition: all .12s;
}
.ef-fclr:hover { border-color: var(--t2); color: var(--t2); }

/* Edge finder content styles */
.ef-sec { margin-bottom: 22px; }
.ef-sec-title {
  font-size: 9px; font-weight: 800; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--t3); margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid var(--bd);
}
.ef-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.ef-grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
.ef-grid4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }

.ef-mcard {
  background: var(--s1); border: 1px solid var(--bd); border-radius: 5px; padding: 12px 14px;
}
.ef-mc-lbl { font-size: 7px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--t3); margin-bottom: 5px; }
.ef-mc-val { font-family: var(--mono); font-size: 18px; font-weight: 700; line-height: 1; }
.ef-mc-sub { font-size: 8px; font-weight: 600; color: var(--t3); margin-top: 3px; }
.ef-g .ef-mc-val { color: var(--green2); }
.ef-r .ef-mc-val { color: var(--red2); }
.ef-a .ef-mc-val { color: var(--amber2); }
.ef-b .ef-mc-val { color: var(--blue2); }
.ef-n .ef-mc-val { color: var(--tx); }

.ef-tbl { width: 100%; border-collapse: collapse; font-size: 11px; }
.ef-tbl thead tr { background: var(--s2); }
.ef-tbl th {
  padding: 7px 10px; text-align: left; font-size: 7px; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase; color: var(--t3);
  border-bottom: 1px solid var(--bd); white-space: nowrap;
}
.ef-tbl th.r { text-align: right; }
.ef-tbl td { padding: 6px 10px; border-bottom: 1px solid rgba(30,45,61,.5); font-family: var(--mono); }
.ef-tbl td.lbl { font-family: var(--sans); font-weight: 700; color: var(--tx); }
.ef-tbl td.r { text-align: right; }
.ef-tbl tr:hover { background: rgba(59,130,246,.03); }

.ef-pos { color: var(--green2); }
.ef-neg { color: var(--red2); }
.ef-neu { color: var(--amber2); }
.ef-dim { color: var(--t2); }

.ef-rr-bar-wrap { display: flex; align-items: center; gap: 5px; }
.ef-rr-bar { height: 4px; border-radius: 2px; min-width: 2px; flex-shrink: 0; }
.ef-wr-bar-o { width: 60px; height: 4px; background: var(--bd); border-radius: 2px; display: inline-block; vertical-align: middle; overflow: hidden; }
.ef-wr-bar-i { height: 100%; border-radius: 2px; }

.ef-mx-wrap { overflow: auto; }
.ef-mx-tbl { border-collapse: collapse; font-size: 10px; }
.ef-mx-tbl th { padding: 5px 10px; text-align: center; font-size: 7px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--t3); border: 1px solid var(--bd); white-space: nowrap; }
.ef-mx-tbl th.rh { text-align: left; }
.ef-mx-tbl td { padding: 5px 10px; text-align: center; border: 1px solid var(--bd); font-family: var(--mono); font-weight: 700; min-width: 60px; }
.ef-mx-tbl td.rl { text-align: left; font-family: var(--sans); font-weight: 700; color: var(--t2); }
.ef-cp3 { background: rgba(22,163,74,.32); color: var(--green2); }
.ef-cp2 { background: rgba(22,163,74,.18); color: #4ade80; }
.ef-cp1 { background: rgba(22,163,74,.07); color: #86efac; }
.ef-cn1 { background: rgba(220,38,38,.07); color: #fca5a5; }
.ef-cn2 { background: rgba(220,38,38,.18); color: var(--red2); }
.ef-cn3 { background: rgba(220,38,38,.32); color: var(--red2); }
.ef-c0  { color: var(--t3); }

.ef-insight-row { display: flex; align-items: center; gap: 10px; padding: 9px 0; border-bottom: 1px solid rgba(30,45,61,.4); }
.ef-insight-row:last-child { border-bottom: none; }
.ef-insight-icon { font-size: 15px; flex-shrink: 0; }
.ef-insight-key  { font-size: 10px; font-weight: 700; color: var(--tx); }
.ef-insight-val  { font-family: var(--mono); font-size: 12px; font-weight: 800; margin-left: auto; flex-shrink: 0; }
.ef-insight-sub  { font-size: 8px; font-weight: 600; color: var(--t3); margin-top: 2px; }

.ef-card { background: var(--s1); border: 1px solid var(--bd); border-radius: 5px; padding: 14px; margin-bottom: 14px; }

/* Accordion variable blocks */
.ef-accordion { margin-bottom: 8px; border: 1px solid var(--bd); border-radius: 5px; overflow: hidden; }
.ef-accordion-hdr { display: flex; align-items: center; justify-content: space-between; padding: 9px 13px; background: var(--s2); cursor: pointer; user-select: none; transition: background .1s; }
.ef-accordion-hdr:hover { background: var(--s3); }
.ef-accordion-title { font-size: 9px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--t2); }
.ef-accordion-meta { display: flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 9px; font-weight: 700; }
.ef-accordion-chevron { font-size: 10px; color: var(--t3); transition: transform .2s; flex-shrink: 0; margin-left: 8px; }
.ef-accordion-body { display: none; }
.ef-accordion.ef-open .ef-accordion-body { display: block; }
/* ef-var-canvas: free-position container */
.ef-var-canvas {
  position: relative;
  width: 100%;
  min-height: 100%;
  padding: 12px;
}
.ef-var-canvas .ef-accordion {
  position: absolute;
  width: 320px;
  min-width: 200px;
  min-height: 44px;
  cursor: default;
  box-shadow: 0 2px 10px rgba(0,0,0,.25);
}
.ef-var-canvas .ef-accordion .ef-accordion-hdr {
  cursor: grab;
}
.ef-var-canvas .ef-accordion .ef-accordion-hdr:active {
  cursor: grabbing;
}
.ef-var-canvas .ef-accordion.ef-moving {
  opacity: .9;
  box-shadow: 0 8px 32px rgba(0,0,0,.4);
  z-index: 100;
}
/* Snap guides: invisible by default, shown only on drag */
.ef-snap-guide-v, .ef-snap-guide-h { display: none; }

/* ── GLOBAL BOLD ──────────────────────────────── */
*, *::before, *::after { font-weight: 700 !important; }

/* ── GLOBAL BORDER RADIUS ─────────────────────── */
.col, .cbody, .chdr,
.mbar-item,
.scard, .scards,
.tr-row, .th-cols,
.ef-accordion, .ef-comb-card, .ef-card,
.ef-mcard, .dae-empty, #dae-report,
#c2-empty, #c2-data,
.frow select, .frow2 select, .ef-var-select, .ef-fsel, .fb-sel,
.ef-tbl td, .ef-tbl th,
.ef-comb-body,
#obs-inner, #img-inner,
.ef-pattern-row,
.val-item,
.de-factor,
.run-btn, .ef-run-btn, .ef-fclr, .fb-clr, .ef-sort-btn,
.h-btn, #obs-close, #img-close {
  border-radius: 6px !important;
}
/* Keep header square */
#hdr, #mbar, #tabs, .chdr { border-radius: 0 !important; }

/* ── GLOBAL CLEAN RR — no colored backgrounds anywhere ── */
.ef-rr-bar { display: none !important; }
.rr-bar    { display: none !important; }
/* Remove colored backgrounds from stat cells that had clrRR classes */
.ef-pos.ef-cp3, .ef-pos.ef-cp2, .ef-pos.ef-cp1,
.ef-neg.ef-cn1, .ef-neg.ef-cn2, .pos.cp3, .pos.cp2, .pos.cp1,
.neg.cn1, .neg.cn2 {
  background: transparent !important;
}

/* Data List — full 2-axis scroll */
#ef-view-datalist {
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
#dl-outer {
  flex: 1;
  overflow: auto;
  width: 100%;
  height: 100%;
}
#dl-outer table {
  border-collapse: collapse;
  white-space: nowrap;
  min-width: 100%;
}
#dl-outer thead tr {
  position: sticky; top: 0; z-index: 10;
  background: var(--s2);
}
#dl-outer th {
  padding: 7px 14px;
  text-align: left;
  font-size: 9px; letter-spacing: 1px; text-transform: uppercase;
  color: var(--t3);
  border-bottom: 2px solid var(--bd2);
  border-right: 1px solid var(--bd);
  background: var(--s2);
  white-space: nowrap;
}
#dl-outer th:first-child {
  position: sticky; left: 0; z-index: 11;
  background: var(--s2);
  border-right: 2px solid var(--bd2);
  min-width: 40px;
}
#dl-outer td {
  padding: 5px 14px;
  border-bottom: 1px solid rgba(30,45,61,.25);
  border-right: 1px solid rgba(30,45,61,.15);
  color: var(--t2);
  white-space: nowrap;
}
#dl-outer td:first-child {
  position: sticky; left: 0; z-index: 5;
  background: var(--s1);
  color: var(--t3);
  border-right: 2px solid var(--bd2);
}
#dl-outer tr:hover td { background: rgba(59,130,246,.06); }
#dl-outer tr:hover td:first-child { background: var(--s2); }
#dl-outer tr:nth-child(even) td { background: rgba(30,45,61,.08); }
#dl-outer tr:nth-child(even) td:first-child { background: var(--s2); }

/* Combination cards */
.ef-comb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.ef-comb-col-title { font-size: 8px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; padding: 8px 12px; border-radius: 4px; margin-bottom: 8px; text-align: center; }
.ef-comb-col-title.ef-win  { background: rgba(22,163,74,.12); color: var(--green2); border: 1px solid rgba(34,197,94,.25); }
.ef-comb-col-title.ef-lose { background: rgba(220,38,38,.12); color: var(--red2);   border: 1px solid rgba(239,68,68,.25); }
.ef-comb-card { border: 1px solid var(--bd); border-radius: 5px; overflow: hidden; margin-bottom: 6px; }
.ef-comb-card-hdr { display: flex; align-items: center; justify-content: space-between; padding: 8px 11px; background: var(--s2); cursor: pointer; user-select: none; transition: background .1s; }
.ef-comb-card-hdr:hover { background: var(--s3); }
.ef-comb-key { font-size: 10px; font-weight: 700; color: var(--tx); flex: 1; }
.ef-comb-rr  { font-family: var(--mono); font-size: 12px; font-weight: 800; margin-left: 8px; }
.ef-comb-body { display: none; padding: 9px 11px; border-top: 1px solid var(--bd); background: var(--s1); }
.ef-comb-body.ef-open { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
.ef-comb-stat { text-align: center; }
.ef-comb-stat-lbl { font-size: 7px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--t3); margin-bottom: 2px; }
.ef-comb-stat-val { font-family: var(--mono); font-size: 13px; font-weight: 700; }

/* Insight win-pattern list */
.ef-pattern-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid rgba(30,45,61,.4); }
.ef-pattern-row:last-child { border-bottom: none; }
.ef-pattern-rank { font-family: var(--mono); font-size: 10px; font-weight: 800; color: var(--t3); min-width: 18px; text-align: center; }
.ef-pattern-key  { font-size: 10px; font-weight: 700; color: var(--tx); flex: 1; }
.ef-pattern-pct  { font-family: var(--mono); font-size: 11px; font-weight: 800; color: var(--green2); min-width: 38px; text-align: right; }
.ef-pattern-bar-wrap { width: 60px; height: 4px; background: var(--bd); border-radius: 2px; overflow: hidden; flex-shrink: 0; }
.ef-pattern-bar-fill { height: 100%; background: var(--green2); border-radius: 2px; }
.ef-empty { padding: 30px 16px; text-align: center; color: var(--t3); font-size: 10px; font-weight: 700; line-height: 2; }
/* ef-page fills remaining space */
#ef-page { position: relative; overflow: hidden; }

/* All views fill ef-page fully — ONE source of truth */
.ef-view {
  position: absolute;
  inset: 0;
  display: none !important;
}
.ef-view.ef-active {
  display: flex !important;
  flex-direction: column;
  animation: efFade .12s ease;
}
@keyframes efFade { from{opacity:0} to{opacity:1} }

/* Scrollable views (combinations, insights) */

/* Playbook view */
#ef-view-playbook {
  overflow-y: auto;
  overflow-x: hidden;
  padding: 20px 24px;
}
.pb-section { margin-bottom: 28px; }
.pb-h1 { font-size: 10px; font-weight: 900; letter-spacing: 3px; text-transform: uppercase; color: var(--blue2); padding-bottom: 8px; border-bottom: 1px solid var(--bd); margin-bottom: 14px; }
.pb-h2 { font-size: 9px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--t2); margin: 12px 0 6px; }
.pb-rule { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; font-size: 11px; font-weight: 600; color: var(--tx); line-height: 1.5; }
.pb-dot-g { width: 6px; height: 6px; border-radius: 50%; background: var(--green2); flex-shrink: 0; margin-top: 5px; }
.pb-dot-r { width: 6px; height: 6px; border-radius: 50%; background: var(--red2); flex-shrink: 0; margin-top: 5px; }
.pb-dot-a { width: 6px; height: 6px; border-radius: 50%; background: var(--amber2); flex-shrink: 0; margin-top: 5px; }
.pb-stat { display: inline-flex; align-items: center; gap: 5px; background: var(--s2); border: 1px solid var(--bd); border-radius: 3px; padding: 2px 8px; font-family: var(--mono); font-size: 10px; font-weight: 700; margin: 3px 4px 3px 0; }
.pb-plan { background: linear-gradient(135deg, rgba(29,78,216,.12), rgba(29,78,216,.06)); border: 1px solid rgba(59,130,246,.3); border-radius: 6px; padding: 18px 20px; }
.pb-plan-title { font-size: 11px; font-weight: 900; letter-spacing: 3px; text-transform: uppercase; color: var(--blue2); margin-bottom: 14px; }
.pb-plan-line { font-size: 12px; font-weight: 600; color: var(--tx); line-height: 1.8; margin-bottom: 4px; }
.pb-plan-line b { color: var(--green2); }
.pb-plan-line s { color: var(--red2); text-decoration: none; font-style: normal; }
.pb-empty { padding: 60px 20px; text-align: center; color: var(--t3); font-size: 10px; font-weight: 700; letter-spacing: 1px; }

/* Variables canvas view */
#ef-view-variables {
  overflow: hidden;
  padding: 0;
}

/* Data List view */
#ef-view-datalist {
  overflow: hidden;
}

/* Thick scrollbars for dl-outer */
#dl-outer::-webkit-scrollbar { width: 10px; height: 10px; }
#dl-outer::-webkit-scrollbar-track { background: var(--s2); border-radius: 5px; }
#dl-outer::-webkit-scrollbar-thumb { background: var(--bd2); border-radius: 5px; }
#dl-outer::-webkit-scrollbar-thumb:hover { background: var(--t3); }
#dl-outer::-webkit-scrollbar-corner { background: var(--s2); }
#dl-wrap {
  width: 100%; height: 100%;
  overflow: auto;
  font-family: var(--mono);
  font-size: 11px;
}
#dl-wrap table {
  border-collapse: collapse;
  white-space: nowrap;
}
#dl-wrap thead tr {
  position: sticky; top: 0; z-index: 10;
  background: var(--s2);
}
#dl-wrap th {
  padding: 7px 12px;
  text-align: left;
  font-size: 8px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--t3);
  border-bottom: 2px solid var(--bd2);
  border-right: 1px solid var(--bd);
  background: var(--s2);
  white-space: nowrap;
  cursor: default;
}
#dl-wrap th:first-child {
  position: sticky; left: 0; z-index: 11;
  background: var(--s2);
  border-right: 2px solid var(--bd2);
}
#dl-wrap td {
  padding: 5px 12px;
  border-bottom: 1px solid rgba(30,45,61,.3);
  border-right: 1px solid rgba(30,45,61,.2);
  color: var(--t2);
  max-width: 280px;
  overflow: hidden;
  text-overflow: ellipsis;
}
#dl-wrap td:first-child {
  position: sticky; left: 0; z-index: 5;
  background: var(--s1);
  color: var(--t3);
  font-weight: 700;
  border-right: 2px solid var(--bd2);
}
#dl-wrap tr:hover td { background: rgba(59,130,246,.05); }
#dl-wrap tr:hover td:first-child { background: var(--s2); }
#dl-wrap tr:nth-child(even) td { background: rgba(30,45,61,.1); }
#dl-wrap tr:nth-child(even) td:first-child { background: var(--s2); }
.dl-empty { padding: 60px; text-align: center; color: var(--t3); font-size: 11px; font-weight: 700; }
/* ── DATA LIST cell borders ──────────────── */
#dl-outer td {
  border: 1px solid var(--bd);
  border-radius: 3px;
}
#dl-outer td:first-child {
  border-right: 2px solid var(--bd2);
}

/* ── TAB DRAG STYLES ────────────────────── */
#ef-tabs-bar { display:flex; align-items:flex-end; gap:2px; padding:0 16px; flex:1; }
.ef-tab { cursor: grab; }
.ef-tab.tab-dragging { opacity:.4; cursor:grabbing; }
::-webkit-scrollbar { width: 3px; height: 3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bd2); border-radius: 2px; }
#ef-view-chat {
  display: none;
  flex-direction: column;
  overflow: hidden;
}
#ef-view-chat.ef-active { display: flex; }
#chat-history {
  flex: 1;
  overflow-y: auto;
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
#chat-history::-webkit-scrollbar { width: 3px; }
#chat-history::-webkit-scrollbar-thumb { background: var(--bd2); border-radius: 2px; }
.chat-msg-user {
  align-self: flex-end;
  max-width: 70%;
  background: var(--blue);
  color: #fff;
  border-radius: 12px 12px 2px 12px;
  padding: 9px 14px;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.5;
}
.chat-msg-bot {
  align-self: flex-start;
  max-width: 88%;
  background: var(--s2);
  border: 1px solid var(--bd);
  border-radius: 2px 12px 12px 12px;
  padding: 12px 16px;
  font-size: 11px;
  line-height: 1.6;
}
.chat-block-title {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--blue2);
  margin-bottom: 8px;
  padding-bottom: 5px;
  border-bottom: 1px solid var(--bd);
}
.chat-block-title.red { color: var(--red2); }
.chat-stat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 10px;
}
.chat-chip {
  background: var(--s1);
  border: 1px solid var(--bd);
  border-radius: 3px;
  padding: 2px 9px;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
}
.chat-expl {
  font-size: 11px;
  font-weight: 500;
  color: var(--t2);
  line-height: 1.7;
}
.chat-expl b { color: var(--tx); font-weight: 700; }
.chat-separator { border: none; border-top: 1px solid var(--bd); margin: 10px 0; }
#chat-input-row {
  display: flex;
  gap: 8px;
  padding: 10px 14px;
  background: var(--s1);
  border-top: 1px solid var(--bd);
  flex-shrink: 0;
}
#chat-input {
  flex: 1;
  background: var(--s2);
  border: 1px solid var(--bd2);
  color: var(--tx);
  font-family: var(--sans);
  font-size: 12px;
  padding: 8px 12px;
  border-radius: 6px;
  outline: none;
  transition: border-color .12s;
}
#chat-input:focus { border-color: var(--blue2); }
#chat-input::placeholder { color: var(--t3); }
#chat-send {
  background: var(--blue2);
  border: none;
  color: #fff;
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 800;
  padding: 8px 18px;
  border-radius: 6px;
  cursor: pointer;
  transition: background .12s;
  letter-spacing: .5px;
}
#chat-send:hover { background: #2563eb; }
.chat-thinking {
  color: var(--t3);
  font-size: 10px;
  font-style: italic;
  align-self: flex-start;
}

/* ── PLAN DE TRADING ─────────────────────── */
#ef-view-plan {
  overflow-y: auto;
  overflow-x: hidden;
  padding: 0;
}
#ef-view-plan::-webkit-scrollbar { width: 3px; }
#ef-view-plan::-webkit-scrollbar-thumb { background: var(--bd2); border-radius: 2px; }

/* ── DIARIO DE TRADING ───────────────────────── */
#ef-view-diario { overflow-y:auto; overflow-x:hidden; padding:0; }
#ef-view-diario::-webkit-scrollbar { width:3px; }
#ef-view-diario::-webkit-scrollbar-thumb { background:rgba(0,212,255,.2); border-radius:2px; }
.dj-wrap { padding:20px 24px 40px; max-width:860px; margin:0 auto; }
.dj-header { text-align:center; padding:18px 0 20px; border-bottom:1px solid rgba(0,212,255,.1); margin-bottom:22px; }
.dj-header-title { font-size:13px; font-weight:900; letter-spacing:4px; text-transform:uppercase; color:var(--blue2); margin-bottom:3px; }
.dj-header-sub { font-size:8px; font-weight:700; letter-spacing:2px; color:var(--t3); text-transform:uppercase; }
.dj-tabs { display:flex; gap:6px; margin-bottom:18px; }
.dj-tab-btn {
  padding:5px 14px; font-size:9px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase;
  background:rgba(0,212,255,.05); border:1px solid rgba(0,212,255,.15); color:var(--t3);
  border-radius:5px; cursor:pointer; transition:all .15s; font-family:var(--sans);
}
.dj-tab-btn.active { background:rgba(0,212,255,.12); border-color:rgba(0,212,255,.4); color:var(--blue2); }
.dj-tab-btn:hover { border-color:rgba(0,212,255,.3); color:var(--t2); }
/* Form */
.dj-form { display:flex; flex-direction:column; gap:14px; }
.dj-section-title {
  font-size:7px; font-weight:900; letter-spacing:3px; text-transform:uppercase;
  color:rgba(0,212,255,.4); padding-bottom:6px; border-bottom:1px solid rgba(0,212,255,.08);
  margin-bottom:6px;
}
.dj-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.dj-row-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; }
.dj-field { display:flex; flex-direction:column; gap:4px; }
.dj-field label { font-size:7px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:var(--t3); }
.dj-input, .dj-select, .dj-textarea {
  background:rgba(0,212,255,.04); border:1px solid rgba(0,212,255,.15);
  color:var(--tx); font-family:var(--sans); font-size:11px;
  padding:7px 10px; border-radius:6px; outline:none; transition:border-color .12s;
  width:100%;
}
.dj-input:focus, .dj-select:focus, .dj-textarea:focus {
  border-color:var(--blue2); box-shadow:0 0 0 2px rgba(0,212,255,.08);
}
.dj-select option { background:#0b1220; }
.dj-textarea { resize:vertical; min-height:80px; line-height:1.6; }
.dj-textarea.tall { min-height:120px; }
.dj-slider-row { display:flex; align-items:center; gap:10px; }
.dj-slider { flex:1; accent-color:var(--blue2); }
.dj-slider-val {
  font-family:var(--mono); font-size:13px; font-weight:800; min-width:28px; text-align:center;
  color:var(--blue2);
}
.dj-radio-row { display:flex; gap:8px; }
.dj-radio-btn {
  flex:1; padding:7px 6px; text-align:center; font-size:9px; font-weight:800;
  letter-spacing:1px; text-transform:uppercase; border-radius:5px; cursor:pointer;
  border:1px solid rgba(0,212,255,.15); background:rgba(0,212,255,.03);
  color:var(--t3); transition:all .12s; user-select:none;
}
.dj-radio-btn.selected { background:rgba(0,212,255,.15); border-color:var(--blue2); color:var(--blue2); }
.dj-img-preview { display:flex; flex-wrap:wrap; gap:8px; margin-top:6px; }
.dj-img-thumb { width:90px; height:64px; object-fit:cover; border-radius:5px; border:1px solid rgba(0,212,255,.2); cursor:pointer; }
.dj-save-btn {
  background:linear-gradient(135deg,#006ab5,#004d8a); border:1px solid rgba(0,212,255,.3);
  color:#fff; font-family:var(--sans); font-size:10px; font-weight:800; letter-spacing:2px;
  text-transform:uppercase; padding:10px 24px; border-radius:7px; cursor:pointer;
  transition:all .15s; align-self:flex-end;
  box-shadow:0 0 16px rgba(0,212,255,.15);
}
.dj-save-btn:hover { background:linear-gradient(135deg,#008fd4,#006ab5); box-shadow:0 0 28px rgba(0,212,255,.28); transform:translateY(-1px); }
/* History cards */
.dj-history { display:flex; flex-direction:column; gap:10px; }
.dj-card {
  background:rgba(11,18,32,.85); border:1px solid rgba(0,212,255,.1);
  border-radius:9px; overflow:hidden; transition:all .15s;
  cursor:pointer;
}
.dj-card:hover { border-color:rgba(0,212,255,.25); box-shadow:0 4px 20px rgba(0,0,0,.3); }
.dj-card-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 14px; gap:12px;
}
.dj-card-meta { display:flex; flex-direction:column; gap:2px; flex:1; min-width:0; }
.dj-card-date { font-family:var(--mono); font-size:10px; font-weight:700; color:var(--blue2); }
.dj-card-session { font-size:8px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:var(--t3); }
.dj-card-preview { font-size:10px; color:var(--t2); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:260px; }
.dj-card-badges { display:flex; gap:6px; align-items:center; flex-shrink:0; }
.dj-badge {
  font-size:8px; font-weight:800; padding:2px 7px; border-radius:3px; letter-spacing:.5px;
}
.dj-badge-plan-y { background:rgba(0,229,160,.1); border:1px solid rgba(0,229,160,.25); color:var(--green2); }
.dj-badge-plan-n { background:rgba(255,92,92,.1);  border:1px solid rgba(255,92,92,.25);  color:var(--red2); }
.dj-card-actions { display:flex; gap:4px; flex-shrink:0; }
.dj-action-btn {
  font-size:9px; font-weight:700; padding:3px 8px; border-radius:4px; cursor:pointer;
  border:1px solid transparent; background:transparent; color:var(--t3); transition:all .12s;
  font-family:var(--sans);
}
.dj-action-btn.edit  { border-color:rgba(0,212,255,.2); }
.dj-action-btn.edit:hover  { border-color:var(--blue2); color:var(--blue2); }
.dj-action-btn.del   { border-color:rgba(255,92,92,.2); }
.dj-action-btn.del:hover   { border-color:var(--red2); color:var(--red2); }
.dj-card-body {
  display:none; padding:12px 14px 14px; border-top:1px solid rgba(0,212,255,.07);
}
.dj-card.expanded .dj-card-body { display:block; }
.dj-card.expanded .dj-card-header { background:rgba(0,212,255,.03); }
.dj-detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.dj-detail-field { display:flex; flex-direction:column; gap:3px; }
.dj-detail-lbl { font-size:7px; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:var(--t3); }
.dj-detail-val { font-size:10px; font-weight:600; color:var(--tx); line-height:1.5; white-space:pre-wrap; }
.dj-detail-sep { border:none; border-top:1px solid rgba(0,212,255,.07); margin:10px 0; }
.dj-detail-imgs { display:flex; flex-wrap:wrap; gap:8px; margin-top:8px; }
.dj-empty { text-align:center; padding:48px 20px; color:var(--t3); font-size:9px; font-weight:700; letter-spacing:2px; text-transform:uppercase; line-height:2.5; }
.pt-wrap { padding: 20px 24px 40px; max-width: 900px; margin: 0 auto; }
.pt-header { text-align: center; padding: 20px 0 24px; border-bottom: 1px solid var(--bd); margin-bottom: 24px; }
.pt-header-title { font-size: 14px; font-weight: 900; letter-spacing: 4px; text-transform: uppercase; color: var(--blue2); margin-bottom: 4px; }
.pt-header-sub { font-size: 9px; font-weight: 700; letter-spacing: 2px; color: var(--t3); text-transform: uppercase; }
.pt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.pt-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.pt-grid-1 { margin-bottom: 14px; }
.pt-card { background: var(--s2); border: 1px solid var(--bd); border-radius: 6px; padding: 16px 18px; }
.pt-card.pt-green { border-left: 3px solid var(--green2); }
.pt-card.pt-red   { border-left: 3px solid var(--red2); }
.pt-card.pt-amber { border-left: 3px solid var(--amber2); }
.pt-card.pt-blue  { border-left: 3px solid var(--blue2); }
.pt-card.pt-plan  { background: linear-gradient(135deg,rgba(29,78,216,.1),rgba(29,78,216,.04)); border: 1px solid rgba(59,130,246,.3); }
.pt-card-title { font-size: 9px; font-weight: 900; letter-spacing: 2.5px; text-transform: uppercase; color: var(--t2); margin-bottom: 12px; padding-bottom: 7px; border-bottom: 1px solid var(--bd); }
.pt-card-title span { margin-right: 6px; }
.pt-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 7px; font-size: 11px; }
.pt-row-label { color: var(--t2); font-weight: 600; }
.pt-row-val { font-family: var(--mono); font-weight: 800; font-size: 12px; }
.pt-rule { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; font-size: 11px; font-weight: 600; color: var(--tx); line-height: 1.5; }
.pt-dot-g { width:6px;height:6px;border-radius:50%;background:var(--green2);flex-shrink:0;margin-top:5px; }
.pt-dot-r { width:6px;height:6px;border-radius:50%;background:var(--red2);flex-shrink:0;margin-top:5px; }
.pt-dot-a { width:6px;height:6px;border-radius:50%;background:var(--amber2);flex-shrink:0;margin-top:5px; }
.pt-dot-b { width:6px;height:6px;border-radius:50%;background:var(--blue2);flex-shrink:0;margin-top:5px; }
.pt-semaforo { display: flex; gap: 8px; margin-top: 8px; }
.pt-sem { flex:1; border-radius:4px; padding:8px 10px; text-align:center; }
.pt-sem-g { background:rgba(22,163,74,.12); border:1px solid rgba(34,197,94,.3); }
.pt-sem-a { background:rgba(217,119,6,.12);  border:1px solid rgba(245,158,11,.3); }
.pt-sem-r { background:rgba(220,38,38,.12);  border:1px solid rgba(239,68,68,.3); }
.pt-sem-icon { font-size:16px; margin-bottom:3px; }
.pt-sem-label { font-size:8px; font-weight:800; letter-spacing:1px; text-transform:uppercase; }
.pt-sem-val { font-family:var(--mono); font-size:10px; font-weight:700; margin-top:3px; color:var(--t2); }
.pt-combo { background:var(--s1); border:1px solid var(--bd); border-radius:4px; padding:8px 11px; margin-bottom:6px; }
.pt-combo-key { font-size:10px; font-weight:700; color:var(--tx); margin-bottom:3px; }
.pt-combo-stats { display:flex; gap:8px; font-family:var(--mono); font-size:9px; font-weight:700; }
.pt-checklist-item { display:flex; align-items:center; gap:8px; padding:5px 0; border-bottom:1px solid rgba(30,45,61,.4); font-size:11px; font-weight:600; color:var(--tx); }
.pt-checklist-item:last-child { border-bottom:none; }
.pt-check { width:14px;height:14px;border-radius:3px;border:1px solid var(--bd2);background:var(--s1);flex-shrink:0; }
.pt-plan-block { margin-bottom:14px; }
.pt-plan-label { font-size:9px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--blue2);margin-bottom:6px; }
.pt-plan-text { font-size:12px;font-weight:600;color:var(--tx);line-height:1.8; }
.pt-plan-text b { color:var(--green2); }
.pt-plan-text s { color:var(--red2);text-decoration:none; }
.pt-empty { padding:60px 20px;text-align:center;color:var(--t3);font-size:10px;font-weight:700;letter-spacing:1px; }
.pt-warning { background:rgba(217,119,6,.1);border:1px solid rgba(245,158,11,.3);border-radius:4px;padding:8px 12px;font-size:10px;font-weight:700;color:var(--amber2);margin-bottom:14px; }

/* ── AUTO GALLERY ───────────────────────── */
.ag-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; padding:6px 8px; }
.ag-card { border-radius:4px; overflow:hidden; cursor:pointer; border:1px solid var(--bd); background:var(--s2); transition:border-color .12s; }
.ag-card:hover { border-color:var(--blue2); transform:scale(1.02); }
.ag-card.ag-w { border-left:2px solid var(--green2); }
.ag-card.ag-l { border-left:2px solid var(--red2); }
.ag-card img  { width:100%; height:66px; object-fit:cover; display:block; }
.ag-foot      { padding:3px 7px; display:flex; justify-content:space-between; font-size:8px; font-weight:700; }
.ag-res       { text-transform:uppercase; letter-spacing:1px; }
.ag-rr        { font-family:var(--mono); color:var(--t2); }
.ag-empty     { padding:28px 14px; text-align:center; color:var(--t3); font-size:9px; font-weight:700; line-height:1.9; }
/* ── GALLERY CAROUSEL VIEWER ─────────────────── */
#ag-modal {
  display:none; position:fixed; inset:0;
  width:100vw; height:100vh;
  background:rgba(0,0,0,.9);
  z-index:10000; flex-direction:column;
  align-items:center; justify-content:center;
  overflow:hidden; padding:0; gap:8px;
}
#ag-modal.ag-open { display:flex; }

/* Image area — no intermediate container restrictions */
#ag-img-wrap {
  position:relative; display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
#ag-img {
  width:auto; height:auto;
  max-width:80vw; max-height:80vh;
  object-fit:contain; image-rendering:auto;
  display:block;
  box-shadow:0 8px 48px rgba(0,0,0,.7);
  backface-visibility:hidden;
  -webkit-backface-visibility:hidden;
}
#ag-img.fading { opacity:0; transition:opacity .15s ease; }
#ag-img.visible { opacity:1; transition:opacity .15s ease; }

/* Nav arrows — fixed to modal sides */
.ag-arrow {
  position:fixed; top:50%; transform:translateY(-50%);
  background:rgba(0,212,255,.12); border:1px solid rgba(0,212,255,.25);
  color:var(--blue2); font-size:28px; font-weight:300;
  width:48px; height:48px; border-radius:50%; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:all .15s; z-index:10002; user-select:none;
}
.ag-arrow:hover { background:rgba(0,212,255,.25); color:#fff; box-shadow:0 0 16px rgba(0,212,255,.35); }
#ag-prev { left:16px; }
#ag-next { right:16px; }

/* Counter */
#ag-counter {
  font-family:var(--mono); font-size:9px; font-weight:700; letter-spacing:2px;
  color:var(--t3); text-align:center; flex-shrink:0; line-height:1;
}

/* Trade info panel — max 20vh, does not push image */
#ag-info {
  width:min(80vw,900px); flex-shrink:0;
  max-height:20vh; overflow-y:auto;
  background:rgba(11,18,32,.97); border:1px solid rgba(0,212,255,.12);
  border-radius:8px; padding:8px 14px;
}
.ag-info-row {
  display:flex; gap:20px; flex-wrap:wrap; align-items:flex-start;
}
.ag-info-field { display:flex; flex-direction:column; gap:2px; min-width:80px; }
.ag-info-lbl {
  font-size:7px; font-weight:800; letter-spacing:2px; text-transform:uppercase;
  color:var(--t3);
}
.ag-info-val {
  font-family:var(--mono); font-size:11px; font-weight:700; color:var(--tx);
}
.ag-info-val.win  { color:var(--green2); }
.ag-info-val.loss { color:var(--red2); }
.ag-obs {
  margin-top:8px; padding-top:8px; border-top:1px solid rgba(0,212,255,.08);
}
.ag-obs-lbl {
  font-size:7px; font-weight:800; letter-spacing:2px; text-transform:uppercase;
  color:var(--t3); margin-bottom:5px;
}
.ag-obs-text {
  font-size:10px; font-weight:500; color:var(--t2); line-height:1.6;
  white-space:pre-wrap; word-break:break-word;
  max-height:80px; overflow-y:auto;
}

/* Close button */
#ag-close {
  position:fixed; top:12px; right:16px;
  background:rgba(8,13,20,.9); border:1px solid rgba(0,212,255,.2);
  color:var(--t2); font-family:var(--mono); font-size:10px; font-weight:700;
  padding:4px 14px; border-radius:6px; cursor:pointer; z-index:10003;
  transition:all .15s;
}
#ag-close:hover { border-color:var(--red2); color:var(--red2); }

/* ══════════════════════════════════════════════════════
   SCIFI DASHBOARD — fiel replicación visual
   Basado en imagen de referencia SciFi 2024
   Pure CSS overrides — sin tocar JS ni layout.
   ══════════════════════════════════════════════════════ */

/* ── TOKENS SciFi ──────────────────────────────────── */
:root {
  --bg:     #080d14;
  --s1:     #0b1220;
  --s2:     #0e1628;
  --s3:     #111c30;
  --bd:     rgba(0,210,255,.10);
  --bd2:    rgba(0,210,255,.18);
  --green:  #00c97a;
  --green2: #00e5a0;
  --gd:     rgba(0,229,160,.08);
  --red:    #e03e3e;
  --red2:   #ff5c5c;
  --rd:     rgba(255,92,92,.08);
  --amber:  #e09c00;
  --amber2: #ffc130;
  --ad:     rgba(255,193,48,.08);
  --blue:   #006ab5;
  --blue2:  #00d4ff;
  --bd_:    rgba(0,212,255,.08);
  --cyan:   #00e5d4;
  --violet: #6c63ff;
  --tx:     #d6e8f5;
  --t2:     #7a9bb5;
  --t3:     #2e4560;
  --glow-b: 0 0 16px rgba(0,212,255,.28), 0 0 40px rgba(0,212,255,.08);
  --glow-g: 0 0 14px rgba(0,229,160,.28), 0 0 36px rgba(0,229,160,.08);
  --glow-r: 0 0 12px rgba(255,92,92,.22);
  --card-shadow: 0 4px 28px rgba(0,0,0,.55), 0 1px 0 rgba(0,212,255,.06);
  --card-hover:  0 8px 44px rgba(0,0,0,.65), 0 0 0 1px rgba(0,212,255,.15);
  --t-fast: .15s ease;
  --t-mid:  .25s ease;
}

/* ── BACKGROUND ────────────────────────────────────── */
html, body {
  background: var(--bg);
  background-image:
    radial-gradient(ellipse 100% 60% at 50% -10%, rgba(0,120,200,.07) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 100% 100%, rgba(0,229,160,.04) 0%, transparent 50%);
  font-family: var(--sans);
}

/* ── HEADER ─────────────────────────────────────────── */
#hdr {
  background: rgba(8,13,20,.97);
  border-bottom: 1px solid rgba(0,212,255,.12);
  box-shadow: 0 1px 0 rgba(0,212,255,.06), 0 4px 24px rgba(0,0,0,.5);
  backdrop-filter: blur(20px);
  height: 44px;
}
.h-logo {
  color: #fff;
  text-shadow: none;
  letter-spacing: 2px;
  font-weight: 700;
  font-size: 13px;
}
.h-logo em { color: var(--cyan); font-style: normal; text-shadow: 0 0 12px rgba(0,229,212,.6); }

.h-btn {
  background: rgba(0,212,255,.07);
  border: 1px solid rgba(0,212,255,.2);
  color: var(--t2);
  border-radius: 6px;
  padding: 4px 12px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .5px;
  transition: all var(--t-fast);
}
.h-btn:hover {
  background: rgba(0,212,255,.15);
  border-color: var(--blue2);
  color: var(--blue2);
  box-shadow: var(--glow-b);
  transform: translateY(-1px);
}
.h-tag.ok { color: var(--cyan); text-shadow: 0 0 10px rgba(0,229,212,.45); }
#h-clock { color: var(--t3); letter-spacing: 1px; }

/* ── METRICS BAR — SciFi KPI bar ─────────────────── */
#mbar {
  background: rgba(8,13,20,.92);
  border-bottom: 1px solid rgba(0,212,255,.1);
  box-shadow: 0 2px 20px rgba(0,0,0,.4);
  backdrop-filter: blur(12px);
  height: 52px;
}
.mbar-item {
  border-right: 1px solid rgba(0,212,255,.08);
  position: relative;
  transition: background var(--t-fast);
}
.mbar-item:hover { background: rgba(0,212,255,.04); }
.mbar-lbl {
  color: var(--t3);
  font-size: 8px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 700;
}
.mbar-val { font-size: 14px; font-weight: 700; line-height: 1; }
.m-g .mbar-val { color: var(--green2); text-shadow: 0 0 12px rgba(0,229,160,.4); }
.m-r .mbar-val { color: var(--red2);   text-shadow: 0 0 10px rgba(255,92,92,.3); }
.m-b .mbar-val { color: var(--blue2);  text-shadow: 0 0 12px rgba(0,212,255,.4); }
.m-a .mbar-val { color: var(--amber2); text-shadow: 0 0 10px rgba(255,193,48,.3); }
.m-n .mbar-val { color: var(--tx); }

.malert { border-radius: 4px; }
.ma-ok   { background: rgba(0,229,160,.08); border-color: rgba(0,229,160,.25); color: var(--green2); }
.ma-warn { background: rgba(255,193,48,.08); border-color: rgba(255,193,48,.25); color: var(--amber2); }
.ma-bad  { background: rgba(255,92,92,.08);  border-color: rgba(255,92,92,.25);  color: var(--red2); }

/* ── COLUMN HEADERS ──────────────────────────────── */
.chdr {
  background: rgba(8,13,20,.95);
  border-bottom: 1px solid rgba(0,212,255,.12);
  border-right: 1px solid rgba(0,212,255,.07);
  height: 34px;
}
.chdr-title {
  color: rgba(0,212,255,.45);
}
.chdr-badge { color: var(--cyan); text-shadow: 0 0 8px rgba(0,229,212,.4); }
.cbody { border-right: 1px solid rgba(0,212,255,.07); }
.cbody::-webkit-scrollbar { width: 2px; }
.cbody::-webkit-scrollbar-thumb { background: rgba(0,212,255,.2); border-radius: 2px; }
.rh:hover, .rh.drag { background: linear-gradient(to bottom,transparent,rgba(0,212,255,.5),transparent); }

/* ── CHECKLIST C1 ────────────────────────────────── */
.fsec { border-bottom: 1px solid rgba(0,212,255,.07); padding: 9px 10px 5px; }
.fsec-title { color: rgba(0,212,255,.3); border-bottom: 1px solid rgba(0,212,255,.07); letter-spacing: 3px; }
.frow label { color: var(--t3); }
.frow select {
  background: rgba(0,212,255,.04);
  border: 1px solid rgba(0,212,255,.14);
  color: var(--tx);
  border-radius: 6px;
  font-size: 10px;
  transition: all var(--t-fast);
}
.frow select:focus { border-color: var(--blue2); box-shadow: 0 0 0 2px rgba(0,212,255,.1); background: rgba(0,212,255,.07); }
.frow select.active { border-color: rgba(0,229,212,.45); background: rgba(0,229,212,.06); }
.frow select option { background: #0b1220; }

/* ── BUTTONS ────────────────────────────────────────── */
#run-btn {
  background: linear-gradient(135deg, #006ab5 0%, #004d8a 100%);
  border-radius: 7px;
  border: 1px solid rgba(0,212,255,.3);
  font-size: 10px;
  letter-spacing: 2px;
  box-shadow: 0 0 18px rgba(0,212,255,.18), 0 4px 12px rgba(0,0,0,.35);
  transition: all var(--t-mid);
  color: #fff;
}
#run-btn:hover {
  background: linear-gradient(135deg, #008fd4 0%, #006ab5 100%);
  box-shadow: 0 0 28px rgba(0,212,255,.32), 0 4px 18px rgba(0,0,0,.35);
  transform: translateY(-1px);
}
#run-btn:active { transform: translateY(0); }
#clr-btn {
  border: 1px solid rgba(0,212,255,.12);
  color: var(--t3);
  border-radius: 7px;
  transition: all var(--t-fast);
}
#clr-btn:hover { border-color: rgba(255,92,92,.4); color: var(--red2); background: rgba(255,92,92,.05); }

/* ── STAT CARDS C2 ───────────────────────────────── */
.scards { background: transparent; gap: 0; }
.scard {
  background: var(--s1);
  border: 1px solid rgba(0,212,255,.08);
  border-right: none;
  border-top: none;
  padding: 12px 14px;
  position: relative;
  transition: background var(--t-fast);
}
.scard::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(0,212,255,.3), transparent);
  opacity: 0;
  transition: opacity var(--t-fast);
}
.scard:hover { background: rgba(0,212,255,.04); }
.scard:hover::after { opacity: 1; }
.sc-lbl { color: var(--t3); letter-spacing: 2px; }
.sc-val { font-size: 16px; font-weight: 700; line-height: 1; }
.sc-sub { color: rgba(100,130,160,.5); font-size: 8px; }
.sc-g .sc-val { color: var(--green2); text-shadow: 0 0 10px rgba(0,229,160,.3); }
.sc-r .sc-val { color: var(--red2);   text-shadow: 0 0 10px rgba(255,92,92,.3); }
.sc-b .sc-val { color: var(--blue2);  text-shadow: 0 0 10px rgba(0,212,255,.3); }
.sc-a .sc-val { color: var(--amber2); }

.wbar-wrap { background: rgba(8,13,20,.7); border-bottom: 1px solid rgba(0,212,255,.08); }
.wbar { height: 3px; background: rgba(255,255,255,.04); border-radius: 2px; }
.wbar-g { background: linear-gradient(to right, var(--green2), #00ffc0); }
.wbar-r { background: linear-gradient(to right, var(--red2), #ff9090); }

/* ── TRADE TABLE ─────────────────────────────────── */
.trades-hdr-row {
  background: rgba(8,13,20,.95);
  border-bottom: 1px solid rgba(0,212,255,.1);
  color: rgba(0,212,255,.3);
  letter-spacing: 3px;
  font-size: 7px;
}
.th-cols {
  background: rgba(11,18,32,.9);
  border-bottom: 1px solid rgba(0,212,255,.1);
  color: var(--t3);
  font-size: 7px;
  letter-spacing: 1.5px;
}
.tr-row {
  border-bottom: 1px solid rgba(0,212,255,.05);
  transition: background var(--t-fast), border-color var(--t-fast);
}
.tr-row:hover {
  background: rgba(0,212,255,.04);
  border-bottom-color: rgba(0,212,255,.12);
}
.tr-row.tw { border-left: 2px solid var(--green2); }
.tr-row.tl { border-left: 2px solid var(--red2); }
.tx-g { color: var(--green2); text-shadow: 0 0 8px rgba(0,229,160,.3); }
.tx-r { color: var(--red2);   text-shadow: 0 0 6px rgba(255,92,92,.2); }

/* ── DECISION ANALYSIS C3 ────────────────────────── */
.dae-decision { border-bottom: 1px solid rgba(0,212,255,.1); }
.dv-aplus { color: var(--green2); text-shadow: 0 0 20px rgba(0,229,160,.5); }
.dv-a     { color: #00ffc0;       text-shadow: 0 0 16px rgba(0,255,192,.4); }
.dv-reduce{ color: var(--amber2); text-shadow: 0 0 14px rgba(255,193,48,.4); }
.dv-no    { color: var(--red2);   text-shadow: 0 0 14px rgba(255,92,92,.4); }
.dae-conf-bar-track { background: rgba(255,255,255,.05); height: 5px; border-radius: 4px; }
.dae-ctx { gap: 0; background: transparent; }
.dae-ctx-item {
  background: rgba(11,18,32,.8);
  border: 1px solid rgba(0,212,255,.08);
  margin: 2px;
  border-radius: 7px;
  padding: 10px 12px;
  transition: all var(--t-fast);
}
.dae-ctx-item:hover { border-color: rgba(0,212,255,.2); background: rgba(0,212,255,.04); }
.dctx-g .dae-ctx-val { color: var(--green2); text-shadow: 0 0 8px rgba(0,229,160,.3); }
.dctx-r .dae-ctx-val { color: var(--red2); }
.fbox { border-radius: 7px; transition: all var(--t-fast); }
.fbox-favor  { background: rgba(0,229,160,.07); border: 1px solid rgba(0,229,160,.2); }
.fbox-contra { background: rgba(255,92,92,.07);  border: 1px solid rgba(255,92,92,.2); }
.fbox-favor:hover  { background: rgba(0,229,160,.11); }
.fbox-contra:hover { background: rgba(255,92,92,.11); }
.action-box { border-radius: 8px; }
.action-box.trade   { background: rgba(0,229,160,.08); border: 1px solid rgba(0,229,160,.25); box-shadow: 0 0 20px rgba(0,229,160,.07); }
.action-box.reduce  { background: rgba(255,193,48,.08); border: 1px solid rgba(255,193,48,.25); }
.action-box.notrade { background: rgba(255,92,92,.08);  border: 1px solid rgba(255,92,92,.25); }
.action-box.wait    { background: rgba(0,212,255,.08);  border: 1px solid rgba(0,212,255,.25); }
.val-item { background: rgba(11,18,32,.8); border: 1px solid rgba(0,212,255,.1); border-radius: 7px; transition: all var(--t-fast); }
.val-item:hover { border-color: rgba(0,212,255,.22); background: rgba(0,212,255,.04); }
.vv-g .val-val { color: var(--green2); }
.vv-r .val-val { color: var(--red2); }

/* ── GALLERY ─────────────────────────────────────── */
.folder-card-big {
  background: var(--s1);
  border: 1px solid rgba(0,212,255,.12);
  border-radius: 10px;
  box-shadow: var(--card-shadow);
  transition: all var(--t-mid);
}
.folder-card-big:hover {
  border-color: var(--blue2);
  box-shadow: var(--card-hover), var(--glow-b);
  transform: translateY(-2px);
}
.fcb-count { color: var(--cyan); text-shadow: 0 0 8px rgba(0,229,212,.3); }
.subfolder-card {
  background: var(--s1);
  border: 1px solid rgba(0,212,255,.1);
  border-radius: 8px;
  transition: all var(--t-mid);
}
.subfolder-card:hover {
  border-color: var(--blue2);
  box-shadow: var(--card-hover), var(--glow-b);
  transform: translateY(-1px);
}
.subfolder-card.highlighted { border-color: var(--green2); box-shadow: 0 0 0 1px rgba(0,229,160,.3), var(--glow-g); }
.gcard { background: var(--s1); border: 1px solid rgba(0,212,255,.1); border-radius: 8px; transition: all var(--t-mid); }
.gcard:hover { border-color: var(--blue2); box-shadow: var(--card-hover), var(--glow-b); transform: translateY(-2px) scale(1.01); }
.back-btn { background: rgba(0,212,255,.05); border: 1px solid rgba(0,212,255,.12); border-radius: 6px; transition: all var(--t-fast); }
.back-btn:hover { background: rgba(0,212,255,.1); border-color: var(--blue2); color: var(--blue2); }

/* ── MODALS ─────────────────────────────────────────── */
#obs-inner, #img-inner {
  background: rgba(8,13,20,.97);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(0,212,255,.2);
  border-radius: 12px;
  box-shadow: 0 28px 80px rgba(0,0,0,.7), 0 0 0 1px rgba(0,212,255,.04);
}
#obs-inner-label { color: rgba(0,212,255,.38); letter-spacing: 3px; }
#obs-close, #img-close { border: 1px solid rgba(0,212,255,.15); border-radius: 6px; transition: all var(--t-fast); }
#obs-close:hover, #img-close:hover { border-color: var(--red2); color: var(--red2); }
/* ag-modal styled in base CSS above */

/* ── EDGE FINDER TABS ────────────────────────────── */
#edge-view { background: var(--bg); }
.ef-tab { padding: 7px 16px 8px; color: var(--t3); font-size: 9px; letter-spacing: 1.5px; transition: all var(--t-fast); }
.ef-tab:hover { color: var(--t2); background: rgba(0,212,255,.03); }
.ef-tab.active { color: var(--cyan); border-bottom-color: var(--cyan); text-shadow: 0 0 10px rgba(0,229,212,.4); }
.ef-fsel { background: rgba(0,212,255,.05); border: 1px solid rgba(0,212,255,.15); border-radius: 5px; color: var(--t2); transition: all var(--t-fast); }
.ef-fsel:focus { border-color: var(--blue2); }
.ef-fclr { border: 1px solid rgba(0,212,255,.12); border-radius: 5px; transition: all var(--t-fast); }
.ef-fclr:hover { border-color: var(--red2); color: var(--red2); background: rgba(255,92,92,.05); }

/* EF CARDS & TABLES */
.ef-mcard {
  background: var(--s1);
  border: 1px solid rgba(0,212,255,.1);
  border-radius: 9px;
  box-shadow: var(--card-shadow);
  transition: all var(--t-mid);
}
.ef-mcard:hover { border-color: rgba(0,212,255,.22); box-shadow: var(--card-hover); transform: translateY(-1px); }
.ef-mc-lbl { color: rgba(0,212,255,.3); letter-spacing: 2.5px; font-size: 7px; }
.ef-mc-val { font-size: 18px; font-weight: 700; line-height: 1; }
.ef-g .ef-mc-val { color: var(--green2); text-shadow: 0 0 10px rgba(0,229,160,.35); }
.ef-r .ef-mc-val { color: var(--red2);   text-shadow: 0 0 10px rgba(255,92,92,.25); }
.ef-b .ef-mc-val { color: var(--blue2);  text-shadow: 0 0 10px rgba(0,212,255,.35); }
.ef-a .ef-mc-val { color: var(--amber2); }
.ef-tbl thead tr { background: rgba(8,13,20,.95); }
.ef-tbl th { color: rgba(0,212,255,.32); letter-spacing: 2px; border-bottom: 1px solid rgba(0,212,255,.1); font-size: 7px; }
.ef-tbl td { border-bottom: 1px solid rgba(0,212,255,.05); }
.ef-tbl td.lbl { color: var(--tx); font-weight: 700; }
.ef-tbl tr:hover { background: rgba(0,212,255,.04); }
.ef-mx-tbl th, .ef-mx-tbl td { border: 1px solid rgba(0,212,255,.08); }
.ef-mx-tbl th { color: rgba(0,212,255,.32); }
.ef-card { background: var(--s1); border: 1px solid rgba(0,212,255,.1); border-radius: 9px; box-shadow: var(--card-shadow); transition: all var(--t-mid); }
.ef-card:hover { border-color: rgba(0,212,255,.22); box-shadow: var(--card-hover); }

/* ── PLAN / PLAYBOOK CARDS ────────────────────────── */
.pb-h1 { color: var(--cyan); text-shadow: 0 0 10px rgba(0,229,212,.3); border-bottom-color: rgba(0,212,255,.12); letter-spacing: 3px; }
.pb-plan { background: rgba(0,212,255,.04); border: 1px solid rgba(0,212,255,.2); border-radius: 10px; }
.pt-card {
  background: var(--s1);
  border: 1px solid rgba(0,212,255,.1);
  border-radius: 10px;
  box-shadow: var(--card-shadow);
  transition: all var(--t-mid);
}
.pt-card:hover { border-color: rgba(0,212,255,.22); box-shadow: var(--card-hover); transform: translateY(-1px); }
.pt-card.pt-green { border-left: 2px solid var(--green2); box-shadow: var(--card-shadow), -2px 0 14px rgba(0,229,160,.1); }
.pt-card.pt-red   { border-left: 2px solid var(--red2);   box-shadow: var(--card-shadow), -2px 0 14px rgba(255,92,92,.1); }
.pt-card.pt-amber { border-left: 2px solid var(--amber2); box-shadow: var(--card-shadow), -2px 0 14px rgba(255,193,48,.1); }
.pt-card.pt-blue  { border-left: 2px solid var(--blue2);  box-shadow: var(--card-shadow), -2px 0 14px rgba(0,212,255,.1); }
.pt-card.pt-plan  { background: rgba(0,212,255,.04); border: 1px solid rgba(0,212,255,.2); }
.pt-card-title { color: rgba(0,212,255,.4); border-bottom-color: rgba(0,212,255,.1); letter-spacing: 2.5px; }
.pt-combo { background: rgba(8,13,20,.8); border: 1px solid rgba(0,212,255,.1); border-radius: 6px; transition: all var(--t-fast); }
.pt-combo:hover { border-color: rgba(0,212,255,.22); background: rgba(0,212,255,.04); }
.pt-sem-g { background: rgba(0,229,160,.07); border: 1px solid rgba(0,229,160,.2); border-radius: 8px; }
.pt-sem-a { background: rgba(255,193,48,.07);  border: 1px solid rgba(255,193,48,.2);  border-radius: 8px; }
.pt-sem-r { background: rgba(255,92,92,.07);   border: 1px solid rgba(255,92,92,.2);   border-radius: 8px; }

/* ── CHAT ───────────────────────────────────────────── */
#chat-key-bar { background: rgba(8,13,20,.92); border-bottom: 1px solid rgba(0,212,255,.1); }
#chat-api-key { background: rgba(0,212,255,.04) !important; border: 1px solid rgba(0,212,255,.15) !important; color: var(--tx) !important; border-radius: 6px !important; }
#chat-api-key:focus { border-color: var(--blue2) !important; }
.chat-msg-user {
  background: linear-gradient(135deg, #005fa3 0%, #004d8a 100%);
  border: 1px solid rgba(0,212,255,.3);
  border-radius: 16px 16px 4px 16px;
  box-shadow: 0 4px 18px rgba(0,106,181,.25), var(--glow-b);
  color: #fff; font-weight: 600;
}
.chat-msg-bot {
  background: rgba(11,18,32,.9);
  border: 1px solid rgba(0,212,255,.12);
  border-radius: 4px 16px 16px 16px;
  box-shadow: var(--card-shadow);
  backdrop-filter: blur(8px);
}
.chat-msg-bot:hover { border-color: rgba(0,212,255,.22); }
.chat-block-title { color: var(--cyan); text-shadow: 0 0 8px rgba(0,229,212,.3); letter-spacing: 2px; border-bottom: 1px solid rgba(0,212,255,.1); }
.chat-block-title.red { color: var(--red2); }
.chat-chip { background: rgba(8,13,20,.9); border: 1px solid rgba(0,212,255,.15); border-radius: 5px; font-size: 10px; }
.chat-separator { border-top: 1px solid rgba(0,212,255,.08); }
#chat-input-row { background: rgba(6,10,18,.95); border-top: 1px solid rgba(0,212,255,.1); backdrop-filter: blur(12px); }
#chat-input { background: rgba(0,212,255,.04); border: 1px solid rgba(0,212,255,.15); border-radius: 8px; color: var(--tx); transition: all var(--t-fast); }
#chat-input:focus { border-color: var(--blue2); box-shadow: 0 0 0 2px rgba(0,212,255,.1); outline: none; }
#chat-input::placeholder { color: var(--t3); }
#chat-send { background: linear-gradient(135deg, #006ab5, #004d8a); border: 1px solid rgba(0,212,255,.28); border-radius: 8px; box-shadow: 0 0 16px rgba(0,212,255,.15); transition: all var(--t-mid); }
#chat-send:hover { background: linear-gradient(135deg, #008fd4, #006ab5); box-shadow: 0 0 26px rgba(0,212,255,.3); transform: translateY(-1px); }

/* ── LIGHT MODE (champagne) ──────────────────────── */
