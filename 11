    </div>`
  );
  html += `</div>`;

  function planColor(){
    if(planRisk===semG_risk) return 'var(--green2)';
    if(planRisk===semA_risk) return 'var(--amber2)';
    return 'var(--red2)';
  }

  // ROW 4: racha + parciales
  html += `<div class="pt-grid">`;

  // 6. PROTOCOLO RACHA
  html += card('pt-red','🔁','PROTOCOLO DE RACHA',
    rule('pt-dot-a','<b>3 pérdidas seguidas</b> → reducir tamaño a la mitad. Revisar condiciones.') +
    rule('pt-dot-r','<b>5 pérdidas seguidas</b> → pausar el día. Analizar logs.') +
    rule('pt-dot-r',`<b>MCL histórica (${mcl} ops)</b> → pausa mínima de 24h. Revalidar setup.`) +
    rule('pt-dot-g','<b>Recovery</b> → volver con 50% del riesgo habitual durante 1 semana.')
  );

  // 7. GESTIÓN DEL TRADE
  const hasParciales = trades.some(t=>parseFloat(t['RR Parciales 50% + BE']||'')>0);
  html += card('pt-amber','📈','GESTIÓN DEL TRADE',
    (hasParciales
      ? rule('pt-dot-g','Se detectaron trades con parciales — el sistema tiene historial de salidas escalonadas.')
      : rule('pt-dot-a','No se detectaron parciales en el historial.')) +
    rule('pt-dot-g',`Si el trade llega a <b>+${(avgWin*0.5).toFixed(1)}R</b>, evaluar parcial del 50%.`) +
    rule('pt-dot-b','Si el precio supera el POI con fuerza, dejar correr hasta TP completo.') +
    rule('pt-dot-a','Mover SL a BE una vez que el trade está en <b>+1R</b>.')
  );

  html += `</div>`;

  // ROW 5: mejores + peores combos
  html += `<div class="pt-grid">`;

  html += card('pt-green','🧠','MEJORES ESCENARIOS — TOP 3',
    bestCombos.length
      ? bestCombos.map((c,i)=>combo(c,i+1)).join('')
      : '<div style="color:var(--t3);font-size:10px;">Necesitás ≥4 trades por combinación</div>'
  );

  html += card('pt-red','🚫','PEORES ESCENARIOS — TOP 3',
    worstCombos.length
      ? worstCombos.map((c,i)=>combo(c,i+1)).join('')
      : '<div style="color:var(--t3);font-size:10px;">Necesitás ≥4 trades por combinación</div>'
  );

  html += `</div>`;

  // ROW 6: fijos (noticias + rutinas)
  html += `<div class="pt-grid-3">`;

  html += card('pt-red','📰','NOTICIAS — NO OPERAR EN',
    rule('pt-dot-r','<b>NFP</b> — Non-Farm Payrolls') +
    rule('pt-dot-r','<b>FOMC</b> — Fed Meeting') +
    rule('pt-dot-r','<b>CPI</b> — Índice de precios') +
    rule('pt-dot-r','<b>PPI</b> — Precios al productor') +
    rule('pt-dot-a','Revisar calendario semanal antes de operar.')
  );

  html += card('pt-blue','🧘','RUTINA PRE-TRADING',
    rule('pt-dot-g','Dormir mínimo <b>8 horas</b>') +
    rule('pt-dot-g','Revisar este plan antes de abrir posición') +
    rule('pt-dot-g','Verificar calendario de noticias') +
    rule('pt-dot-b','Confirmar condiciones del checklist') +
    rule('pt-dot-b','Sin distracciones durante la sesión')
  );

  html += card('pt-blue','🧠','RUTINA POST-TRADING',
    rule('pt-dot-b','Registrar el trade en el CSV inmediatamente') +
    rule('pt-dot-b','Anotar: ejecución, emociones, errores') +
    rule('pt-dot-g','Si fue WIN: identificar qué se ejecutó bien') +
    rule('pt-dot-r','Si fue LOSS: identificar causa raíz') +
    rule('pt-dot-a','Revisión semanal de métricas cada viernes')
  );

  html += `</div>`;

  // ROW 7: requisitos + retiro + revisión + discontinuación
  html += `<div class="pt-grid">`;

  html += card('pt-green','⚙️','REQUISITOS PARA OPERAR',
    (checkItems.length
      ? checkItems.map(ci=>`<div class="pt-checklist-item"><div class="pt-check"></div><span>${ci}</span></div>`).join('')
      : '<div style="color:var(--t3);font-size:10px;">Sin condiciones dominantes detectadas</div>') +
    `<div class="pt-checklist-item"><div class="pt-check"></div><span>Sin noticias de alto impacto</span></div>` +
    `<div class="pt-checklist-item"><div class="pt-check"></div><span>No estoy en racha negativa activa</span></div>`
  );

  html += card('pt-amber','💸','REGLAS DE RETIRO Y REVISIÓN',
    rule('pt-dot-g','Retirar <b>50%</b> de las ganancias mensuales una vez alcanzado el objetivo.') +
    rule('pt-dot-b','Proteger el capital base — nunca arriesgar más del 2% total del mes.') +
    `<div style="margin:10px 0 6px;font-size:9px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--t3);">REVISIÓN PERIÓDICA</div>` +
    rule('pt-dot-b','<b>Semanal:</b> calidad de ejecución vs plan') +
    rule('pt-dot-b','<b>Mensual:</b> WR, PF, EV, MDD, Calmar')
  );

  html += `</div>`;

  // Discontinuación
  html += `<div class="pt-grid-1">`;
  html += card('pt-red','🛑','CONDICIONES DE DISCONTINUACIÓN',
    `<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">` +
    `<div>` +
      rule('pt-dot-r',`WR cae por debajo de <b>${Math.max(40,(wr-10)).toFixed(0)}%</b> en las últimas 2 semanas`) +
      rule('pt-dot-r',`Drawdown supera <b>${(mdd*1.5).toFixed(1)}R</b> en una semana`) +
      rule('pt-dot-r','Racha de pérdidas supera MCL histórica') +
    `</div><div>` +
      rule('pt-dot-a','En cualquiera de estos casos: PAUSAR y revalidar con nuevos datos') +
      rule('pt-dot-b','Actualizar el CSV, re-generar el plan y comparar métricas') +
      rule('pt-dot-b','Volver al mercado solo si el sistema vuelve a zona FAVORABLE') +
    `</div></div>`
  );
  html += `</div>`;

  // PLAN DE EJECUCIÓN DIARIO
  html += `<div class="pt-grid-1">`;
  html += `<div class="pt-card pt-plan">
    <div class="pt-card-title"><span>🚀</span>PLAN DE EJECUCIÓN DIARIO</div>
    <div class="pt-plan-block">
      <div class="pt-plan-label">👉 QUÉ BUSCAR</div>
      <div class="pt-plan-text">Setups con <b>${planSetup || 'condiciones del perfil ganador'}</b>.<br>
      Esperar confluencia de al menos 2 condiciones antes de entrar.</div>
    </div>
    <div class="pt-plan-block">
      <div class="pt-plan-label">👉 QUÉ EVITAR</div>
      <div class="pt-plan-text"><s>NO operar</s> si se presenta: ${planAvoid}.<br>
      <s>NO operar</s> en días con NFP / FOMC / CPI / PPI.</div>
    </div>
    <div class="pt-plan-block">
      <div class="pt-plan-label">👉 CÓMO EJECUTAR</div>
      <div class="pt-plan-text">
        Riesgo por trade: <b>${planRisk}</b>.<br>
        Target mínimo: <b>${planTarget}</b>.<br>
        ${planPause}.<br>
        Registrar el trade inmediatamente después del cierre.
      </div>
    </div>
  </div>`;
  html += `</div>`;

  html += `</div>`; // pt-wrap
  el.innerHTML = html;
}

// ══════════════════════════════════════════════
//  PLAYBOOK PERSONAL — solo lectura de csvData
// ══════════════════════════════════════════════
function efRenderPlaybook(){
  const el = document.getElementById('ef-view-playbook');
  if(!el) return;
  if(!csvData.length){
    el.innerHTML = '<div class="pb-empty">Cargá el CSV para ver tu Playbook Personal</div>';
    return;
  }

  const trades = csvData;
  const total  = trades.length;

  // ── helpers ──────────────────────────────────
  function isWin(t){
    const res = (t[RES_COL]||'').toUpperCase();
    if(res.includes('WIN'))  return true;
    if(res.includes('LOSS')) return false;
    const rr = parseRR(t[RR_COL]);
    return !isNaN(rr) ? rr > 0 : false;
  }
  function getRR(t){ const v=parseRR(t[RR_COL]); return isNaN(v)?null:v; }

  const wins   = trades.filter(isWin);
  const losses = trades.filter(t=>!isWin(t));
  const wr     = total ? (wins.length/total*100).toFixed(1) : 0;

  const rrVals = trades.map(getRR).filter(v=>v!==null);
  const avgRR  = rrVals.length ? (rrVals.reduce((a,b)=>a+b,0)/rrVals.length).toFixed(2) : '—';
  const winRRs = wins.map(getRR).filter(v=>v!==null);
  const lossRRs= losses.map(getRR).filter(v=>v!==null);
  const avgWin = winRRs.length  ? (winRRs.reduce((a,b)=>a+b,0)/winRRs.length).toFixed(2)   : '—';
  const avgLoss= lossRRs.length ? (lossRRs.reduce((a,b)=>a+b,0)/lossRRs.length).toFixed(2) : '—';
  const rrTotal= rrVals.reduce((a,b)=>a+b,0).toFixed(1);

  // ── variable analysis ────────────────────────
  // For each variable col, compute WR and avg RR per value, min 3 trades
  const COLS = [
    {col:'Dia',         lbl:'Día'},
    {col:'Bias',        lbl:'Bias'},
    {col:'Target',      lbl:'Target'},
    {col:'Rango AS/LN', lbl:'Rango'},
    {col:'Tipo MMXM',   lbl:'MMXM'},
    {col:'SMT OPEN',    lbl:'SMT'},
    {col:'ERL/IRL',     lbl:'ERL/IRL'},
    {col:'PDA',         lbl:'PDA'},
    {col:'WO',          lbl:'WO'},
    {col:'Horario OC',  lbl:'Horario'},
  ];

  function analyzeCol(col){
    const map = {};
    trades.forEach(t=>{
      const v = (t[col]||'').trim(); if(!v) return;
      if(!map[v]) map[v]={wins:0,total:0,rrs:[]};
      map[v].total++;
      if(isWin(t)) map[v].wins++;
      const rr=getRR(t); if(rr!==null) map[v].rrs.push(rr);
    });
    return Object.entries(map)
      .filter(([,d])=>d.total>=3)
      .map(([val,d])=>({
        val,
        total: d.total,
        wr:    d.total ? d.wins/d.total*100 : 0,
        avgRR: d.rrs.length ? d.rrs.reduce((a,b)=>a+b,0)/d.rrs.length : 0,
        rrSum: d.rrs.reduce((a,b)=>a+b,0),
      }))
      .sort((a,b)=>b.wr - a.wr);
  }

  // Best and worst per column
  const best=[], worst=[];
  COLS.forEach(({col,lbl})=>{
    const rows = analyzeCol(col);
    if(!rows.length) return;
    const top = rows[0];
    const bot = rows[rows.length-1];
    if(top.wr >= 60) best.push ({lbl, val:top.val, wr:top.wr.toFixed(0), avgRR:top.avgRR.toFixed(2), total:top.total});
    if(bot.wr <= 40) worst.push({lbl, val:bot.val, wr:bot.wr.toFixed(0), avgRR:bot.avgRR.toFixed(2), total:bot.total});
  });

  // ── best combinations (2 vars) ───────────────
  const combMap = {};
  const COMBO_COLS = ['Bias','Target','Rango AS/LN','Dia'];
  trades.forEach(t=>{
    for(let i=0;i<COMBO_COLS.length;i++){
      for(let j=i+1;j<COMBO_COLS.length;j++){
        const v1=(t[COMBO_COLS[i]]||'').trim(), v2=(t[COMBO_COLS[j]]||'').trim();
        if(!v1||!v2) continue;
        const key=`${COMBO_COLS[i]}=${v1} + ${COMBO_COLS[j]}=${v2}`;
        if(!combMap[key]) combMap[key]={wins:0,total:0,rrs:[]};
        combMap[key].total++;
        if(isWin(t)) combMap[key].wins++;
        const rr=getRR(t); if(rr!==null) combMap[key].rrs.push(rr);
      }
    }
  });
  const topCombos = Object.entries(combMap)
    .filter(([,d])=>d.total>=4)
    .map(([key,d])=>({key,wr:d.wins/d.total*100,total:d.total,rrSum:d.rrs.reduce((a,b)=>a+b,0)}))
    .sort((a,b)=>b.wr-a.wr).slice(0,5);

  const badCombos = Object.entries(combMap)
    .filter(([,d])=>d.total>=4)
    .map(([key,d])=>({key,wr:d.wins/d.total*100,total:d.total,rrSum:d.rrs.reduce((a,b)=>a+b,0)}))
    .sort((a,b)=>a.wr-b.wr).slice(0,3);

  // ── drawdown patterns ─────────────────────────
  // Find the worst consecutive loss streak
  let maxStreak=0, curStreak=0;
  trades.forEach(t=>{ if(!isWin(t)){curStreak++;maxStreak=Math.max(maxStreak,curStreak);}else{curStreak=0;} });

  // ── ideal profile (top values per key col) ────
  const profile = {};
  ['Dia','Horario OC','Rango AS/LN','Bias','Target','Tipo MMXM'].forEach(col=>{
    const rows = analyzeCol(col);
    if(rows.length) profile[col] = rows[0];
  });

  // ── build HTML ────────────────────────────────
  function stat(label, val, color){
    return `<span class="pb-stat" style="border-color:${color||'var(--bd)'};color:${color||'var(--tx)'}">${label}: <b>${val}</b></span>`;
  }
  function rule(dot, text){
    return `<div class="pb-rule"><div class="${dot}"></div><span>${text}</span></div>`;
  }

  let html = '';

  // ── 0. RESUMEN ────────────────────────────────
  html += `<div class="pb-section">
    <div class="pb-h1">📊 Resumen del sistema</div>
    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px;">
      ${stat('Trades',total)}
      ${stat('Win Rate',wr+'%', parseFloat(wr)>=60?'var(--green2)':parseFloat(wr)>=50?'var(--amber2)':'var(--red2)')}
      ${stat('RR promedio',avgRR)}
      ${stat('RR total',rrTotal+'R', parseFloat(rrTotal)>=0?'var(--green2)':'var(--red2)')}
      ${stat('Avg WIN','+'+avgWin+'R','var(--green2)')}
      ${stat('Avg LOSS',avgLoss+'R','var(--red2)')}
      ${stat('Max racha perdedora',maxStreak+' ops','var(--amber2)')}
    </div>
  </div>`;

  // ── 1. CONDICIONES GANADORAS ──────────────────
  html += `<div class="pb-section">
    <div class="pb-h1">✅ Condiciones de alta probabilidad</div>`;
  if(best.length){
    best.forEach(b=>{
      html += rule('pb-dot-g', `<b>${b.lbl} = ${b.val}</b> — WR ${b.wr}% · RR prom ${b.avgRR}R · (${b.total} trades)`);
    });
  } else {
    html += `<div style="color:var(--t3);font-size:10px;">No se encontraron variables con WR ≥60% (mín. 3 trades)</div>`;
  }
  if(topCombos.length){
    html += `<div class="pb-h2">Mejores combinaciones</div>`;
    topCombos.forEach(c=>{
      html += rule('pb-dot-g', `<b>${c.key}</b> — WR ${c.wr.toFixed(0)}% · ${c.total} trades · ΣRR ${c.rrSum.toFixed(1)}R`);
    });
  }
  html += `</div>`;

  // ── 2. CONDICIONES A EVITAR ───────────────────
  html += `<div class="pb-section">
    <div class="pb-h1">❌ Condiciones a evitar</div>`;
  if(worst.length){
    worst.forEach(w=>{
      html += rule('pb-dot-r', `<b>${w.lbl} = ${w.val}</b> — WR ${w.wr}% · RR prom ${w.avgRR}R · (${w.total} trades)`);
    });
  } else {
    html += `<div style="color:var(--t3);font-size:10px;">No se encontraron variables con WR ≤40% (mín. 3 trades)</div>`;
  }
  if(badCombos.length){
    html += `<div class="pb-h2">Peores combinaciones</div>`;
    badCombos.forEach(c=>{
      html += rule('pb-dot-r', `<b>${c.key}</b> — WR ${c.wr.toFixed(0)}% · ${c.total} trades · ΣRR ${c.rrSum.toFixed(1)}R`);
    });
  }
  html += `</div>`;

  // ── 3. PERFIL IDEAL ───────────────────────────
  html += `<div class="pb-section">
    <div class="pb-h1">🎯 Perfil ideal de trade</div>`;
  const profCols = {
    'Dia':'Mejor día','Horario OC':'Mejor horario','Rango AS/LN':'Mejor rango',
    'Bias':'Mejor bias','Target':'Mejor target','Tipo MMXM':'Mejor MMXM'
  };
  let hasProfile = false;
  Object.entries(profCols).forEach(([col,lbl])=>{
    if(profile[col]){
      hasProfile = true;
      html += rule('pb-dot-g', `${lbl}: <b>${profile[col].val}</b> — WR ${profile[col].wr.toFixed(0)}% · ${profile[col].total} trades`);
    }
  });
  if(!hasProfile) html += `<div style="color:var(--t3);font-size:10px;">Datos insuficientes para definir perfil</div>`;
  html += `</div>`;

  // ── 4. GESTIÓN DE RIESGO ──────────────────────
  html += `<div class="pb-section">
    <div class="pb-h1">⚖️ Gestión de riesgo</div>
    ${rule('pb-dot-g', `RR promedio de trades ganadores: <b>+${avgWin}R</b>`)}
    ${rule('pb-dot-r', `RR promedio de trades perdedores: <b>${avgLoss}R</b>`)}
    ${rule('pb-dot-a', `Máxima racha de pérdidas consecutivas: <b>${maxStreak} operaciones</b>`)}
    ${rule('pb-dot-a', `Sugerencia: dimensionar riesgo para soportar <b>${maxStreak+2} SL seguidos</b> sin comprometer la cuenta`)}
  </div>`;

  // ── 5. ERRORES CRÍTICOS ───────────────────────
  html += `<div class="pb-section">
    <div class="pb-h1">⚠️ Errores críticos detectados</div>`;
  const errorItems = worst.slice(0,3);
  if(errorItems.length){
    errorItems.forEach(w=>{
      html += rule('pb-dot-r', `Operar con <b>${w.lbl} = ${w.val}</b> genera WR de solo ${w.wr}% — evitar sistemáticamente`);
    });
  }
  if(maxStreak >= 4){
    html += rule('pb-dot-r', `Racha de ${maxStreak} pérdidas detectada — considerar regla de pausa tras 3 SL consecutivos`);
  }
  if(parseFloat(avgRR) < 1.5){
    html += rule('pb-dot-a', `RR promedio (${avgRR}R) por debajo de 1.5R — revisar targets o entradas`);
  }
  if(!errorItems.length && maxStreak < 4 && parseFloat(avgRR) >= 1.5){
    html += `<div style="color:var(--t3);font-size:10px;">No se detectaron patrones de error críticos con los datos disponibles</div>`;
  }
  html += `</div>`;

  // ── 6. PLAN DE EJECUCIÓN (lo más importante) ──
  const topBest  = best.slice(0,3).map(b=>`${b.lbl}=${b.val}`).join(' + ') || 'condiciones favorables según WR';
  const topWorst = worst.slice(0,2).map(w=>`${w.lbl}=${w.val}`).join(' o ') || 'condiciones de bajo WR';
  const idealDay = profile['Dia']       ? profile['Dia'].val       : '—';
  const idealHor = profile['Horario OC'] ? profile['Horario OC'].val : '—';
  const idealTgt = profile['Target']    ? profile['Target'].val    : '—';
  const idealRng = profile['Rango AS/LN']? profile['Rango AS/LN'].val : '—';

  html += `<div class="pb-section">
    <div class="pb-plan">
      <div class="pb-plan-title">🚀 Plan de ejecución personal</div>
      <div class="pb-plan-line"><b>QUÉ BUSCAR:</b> Setups con ${topBest}</div>
      <div class="pb-plan-line"><b>CUÁNDO OPERAR:</b> ${idealDay !== '—' ? 'Día preferido: '+idealDay+' · ' : ''}${idealHor !== '—' ? 'Horario: '+idealHor : 'revisar distribución horaria'}</div>
      <div class="pb-plan-line"><b>TARGET / RANGO:</b> ${idealTgt !== '—' ? 'Target: '+idealTgt : '—'} · ${idealRng !== '—' ? 'Rango: '+idealRng : '—'}</div>
      <div class="pb-plan-line" style="color:var(--red2);margin-top:8px;"><b>CUÁNDO NO OPERAR:</b> Si se presenta ${topWorst}</div>
      <div class="pb-plan-line" style="margin-top:8px;"><b>EJECUCIÓN:</b> Confirmar al menos 2 condiciones del perfil ideal antes de entrar. Respetar el SL siempre. Pausar tras ${maxStreak>=3?maxStreak:3} pérdidas consecutivas.</div>
    </div>
  </div>`;

  el.innerHTML = html;
}


