function runAnalysis(){
  const filters  = getFilters();
  const filtered0 = filterTrades(filters);
  const filtered  = dynApplyFilters(filtered0);
  const stats    = computeStats(filtered);
  const {verdict,vclass,alerts,score,conf} = buildVerdict(stats,filters);

  renderMBar(stats,alerts);
  renderC2(filtered,stats);
  renderDAE(stats,filters,verdict,vclass,conf,score);
  updateFCCount();


  updateGallery(filtered);

