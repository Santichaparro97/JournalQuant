function updateFCCount(){
  const all = document.querySelectorAll('#c1 select');
  const staticN = [...all].filter(s=>s.value!=='').length;
  const dynN = dynState && dynState.cats
    ? Object.values(dynState.cats).flat().filter(f=>f.col&&f.value).length
    : 0;
  document.getElementById('fc-count').textContent = (staticN+dynN)+' filtros';
}

function clearFilters(){
  document.querySelectorAll('#c1 select').forEach(s=>{s.value='';s.classList.remove('active');});
  if(dynState && dynState.cats){
    Object.values(dynState.cats).flat().forEach(f=>{ f.value=''; });
    document.querySelectorAll('.frow-dyn-val').forEach(s=>{s.value='';s.classList.remove('active');});
  }
  updateFCCount();
  if(csvData.length) runAnalysis();
}

// ══════════════════════════════════════════════
//  STATISTICS
// ══════════════════════════════════════════════

// Source columns — only these two per spec
// RR_COL and RES_COL resolve dynamically against loaded CSV headers
// These getters always return the best matching actual column name
function getRRCol()  { return resolveCol('iFVG - RR'); }
function getRESCol() { return resolveCol('iFVG - RES'); }
// Backwards-compat aliases used throughout the codebase — they now resolve live
const RR_COL_FALLBACK  = 'iFVG - RR';
const RES_COL_FALLBACK = 'iFVG - RES';
// RR_COL / RES_COL as writable vars that get refreshed after CSV load
let RR_COL  = 'iFVG - RR';
let RES_COL = 'iFVG - RES';

function refreshDynamicCols(){
  // If user has manually selected an RR column, preserve it; otherwise auto-resolve
  if(!dynState || !dynState.rrCol){
    RR_COL = getRRCol();
  } else {
    RR_COL = dynState.rrCol;
  }
  RES_COL = getRESCol();
  // Also refresh CMAP to use resolved column names
  Object.keys(CMAP).forEach(k=>{
    const resolved = resolveCol(CMAP_CANONICAL[k]);
    if(resolved) CMAP[k] = resolved;
  });
  // Refresh dynState imgCol default
  const imgResolved = resolveCol('Link Trade');
  if(imgResolved && dynState && !dynState.imgCol) dynState.imgCol = imgResolved;
}

// Returns RR value from canonical column, null if not a real trade
// Robust RR parser — handles "+2.50R", "-1.00R", "2,50", plain numbers
function parseRR(value){
  if(value === null || value === undefined || value === '') return null;
  const s = String(value)
    .trim()
    .replace(/,/g, '.')          // comma → dot (European decimals)
    .replace(/[^\d.\-]/g, '')    // strip R, +, spaces, etc — keep digits, dot, minus
    .trim();
  if(s === '' || s === '-' || s === '.') return null;
  const n = parseFloat(s);
  return isNaN(n) ? null : n;
}

function getRR(t){
  const v = parseRR(t[RR_COL]);
  return v;   // null if unparseable
}

// Returns true if this row is a real executed trade (not "no fill")
function isExecuted(t){
  const res = (t[RES_COL]||'').toString().trim().toLowerCase();
  if(res === 'no fill' || res === 'nofill' || res === 'no_fill') return false;
  // Also check RR column for "no fill" text
  const rr = (t[RR_COL]||'').toString().trim().toLowerCase();
  if(rr === 'no fill' || rr === 'nofill' || rr === 'no_fill') return false;
  // Must have either a valid RES or a numeric RR to count
  const rrNum = parseRR(t[RR_COL]);
  const hasRes = res !== '' && res !== '-' && res !== 'n/a';
  const hasRR  = !isNaN(rrNum);
  return hasRes || hasRR;
}

function computeStats(trades){
  // Strip no-fill trades before any calculation
  const executed = trades.filter(isExecuted);
  if(!executed.length) return null;

  let wins=0, losses=0, rrVals=[];
  let curStreak=0, maxCL=0;
  // Equity curve — start at 0
  const equityCurve = [0];

  executed.forEach(t=>{
    const rr  = getRR(t);
    const res = (t[RES_COL]||'').toString().trim().toUpperCase();

    // Win/Loss: primary source = iFVG - RES, secondary = sign of iFVG - RR
    let isWin;
    if(res.includes('WIN'))       isWin = true;
    else if(res.includes('LOSS')) isWin = false;
    else if(rr !== null)          isWin = rr > 0;
    else                          isWin = false;

    if(isWin){ wins++; curStreak = 0; }
    else      { losses++; curStreak++; if(curStreak > maxCL) maxCL = curStreak; }

    // Only push RR if numeric
    const rrUsed = rr !== null ? rr : (isWin ? 1 : -1);
    rrVals.push(rrUsed);
    equityCurve.push(equityCurve[equityCurve.length-1] + rrUsed);
  });

  const total = wins + losses;
  const wr    = total > 0 ? wins / total * 100 : 0;

  // Profit Factor = sum(wins R) / |sum(losses R)|
  const wRR  = rrVals.filter(r => r > 0);
  const lRR  = rrVals.filter(r => r < 0);
  const sumW = wRR.reduce((a,b) => a+b, 0);
  const sumL = Math.abs(lRR.reduce((a,b) => a+b, 0));
  const pf   = sumL > 0 ? sumW / sumL : (sumW > 0 ? 99 : 0);

  const rrTotal = rrVals.reduce((a,b) => a+b, 0);
  const avgRR   = rrVals.length ? rrTotal / rrVals.length : 0;

  // EV = (WR × avg_winner) − ((1−WR) × avg_loser)
  const avgWin  = wRR.length ? sumW / wRR.length : 0;
  const avgLoss = lRR.length ? sumL / lRR.length : 1;  // use 1R as default loser if none
  const ev      = (wr/100) * avgWin - ((1 - wr/100)) * avgLoss;

  // MDD = max (peak - trough) over equity curve, in R units
  // Uses (peak - trough) / peak × 100 when peak > 0, else R units
  let maxDD = 0;
  let peak  = equityCurve[0];
  for(let i = 1; i < equityCurve.length; i++){
    if(equityCurve[i] > peak) peak = equityCurve[i];
    const dd = peak - equityCurve[i];
    if(dd > maxDD) maxDD = dd;
  }

  const sorted = [...rrVals].sort((a,b) => a-b);
  const medRR  = sorted.length ? sorted[Math.floor(sorted.length/2)] : 0;

  return {total, wins, losses, wr, pf, ev, avgRR, avgWin, avgLoss,
          medRR, maxDD, maxCL, rrVals, rrTotal};
}

// ══════════════════════════════════════════════
//  DECISION ENGINE — 3 bloques: Sistema, Contexto, Decisión
// ══════════════════════════════════════════════
function buildVerdict(stats, filters){
  if(!stats) return {verdict:'SIN DATOS',vclass:'dv-no',alerts:[],score:0,conf:0};
  const d = buildDecision(stats, filters);
  return {verdict:d.decision, vclass:'dv-aplus', alerts:[], score:d.riskPct*10, conf:d.confScore};
}

function buildDecision(stats, filters){
  const {wr, pf, ev, avgRR, maxDD, maxCL, rrTotal, total} = stats;

  // ── MÉTRICAS CORE ──────────────────────────
  // Calmar = RR Total / Max Drawdown
  const calmar = maxDD > 0 ? rrTotal / maxDD : (rrTotal > 0 ? 99 : 0);

  // MDD % = calculado desde equity acumulada (maxDD ya está en R desde computeStats)
  // Lo expresamos como % del peak: si peak>0 usamos la proporción, sino usamos R directamente
  const mddPct = maxDD; // en R units (ya calculado sobre equity curve en computeStats)

  // MCL ya está en stats.maxCL
  const mcl = maxCL || 0;

  // ── ESTADO DEL SISTEMA ──────────────────────
  // FUERTE: Calmar>2, EV positivo, MDD controlado, MCL bajo
  // NEUTRO:  Calmar 1-2, EV~0, drawdown moderado
  // DÉBIL:   Calmar<1, EV negativo, MDD alto, MCL alto
  let systemLabel, systemColor, systemIcon;
  const isFuerte = calmar >= 2 && ev > 0 && mddPct < 10 && mcl <= 4;
  const isDebil  = calmar < 1 || ev < 0 || mddPct > 15 || mcl > 7;
  if(isFuerte){
    systemLabel = 'SISTEMA FUERTE'; systemColor = 'var(--green2)'; systemIcon = '🟢';
  } else if(isDebil){
    systemLabel = 'SISTEMA DÉBIL';  systemColor = 'var(--red2)';   systemIcon = '🔴';
  } else {
    systemLabel = 'SISTEMA NEUTRO'; systemColor = 'var(--amber2)'; systemIcon = '🟡';
  }

  // ── CONTEXTO ───────────────────────────────
  const dia    = filters.dia    || '';
  const semana = filters.semana || '';
  const bias   = filters.bias   || '';
  const wo     = filters.wo     || '';

  const complexDays = ['lunes','monday','jueves','thursday','viernes','friday'];
  const isDayComplex = complexDays.some(d => dia.toLowerCase().includes(d));
  const isWeek3 = semana === '3';

  // ── DECISIÓN ───────────────────────────────
  let decision, riskPct, confLabel, confScore;

  // NO OPERAR: Calmar<1, EV negativo, MDD alto, MCL alto, semana3 sin confirmación
  if(calmar < 1 || ev < 0 || mddPct > 15 || mcl > 7 || (isWeek3 && calmar < 1.5)){
    decision = 'NO OPERAR'; riskPct = 0; confLabel = 'BAJA'; confScore = 20;
  }
  // ESCALAR: Calmar>3, EV alto, WR alto, RR sólido
  else if(calmar >= 3 && ev >= 0.3 && wr >= 60 && pf >= 1.5 && !isWeek3 && !isDayComplex){
    decision = 'ESCALAR'; riskPct = 1.5; confLabel = 'ALTA'; confScore = 95;
  }
  // OPERAR: Calmar>2, EV positivo sólido, MDD controlado, MCL bajo, alineación completa
  else if(calmar >= 2 && ev > 0 && mddPct < 10 && mcl <= 4 && !isWeek3 && !isDayComplex){
    decision = 'OPERAR'; riskPct = 1; confLabel = 'ALTA'; confScore = 80;
  }
  // REDUCIR RIESGO: todo lo demás con edge positivo
  else {
    riskPct   = calmar >= 1.5 && ev > 0 ? 0.5 : 0.25;
    confLabel = calmar >= 1.5 && ev > 0 ? 'MEDIA' : 'BAJA';
    confScore = calmar >= 1.5 && ev > 0 ? 55 : 30;
    decision  = 'REDUCIR RIESGO';
  }

  return {calmar, mddPct, mcl, systemLabel, systemColor, systemIcon,
          dia, semana, bias, wo, isDayComplex, isWeek3,
          decision, riskPct, confLabel, confScore};
}

