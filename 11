    </div>
    <div class="wbar">
      <div class="wbar-g" style="width:${wPct}%"></div>
      <div class="wbar-r" style="width:${100-wPct}%"></div>
    </div>
  `;

  // Use a temporary store for obs text to avoid encoding issues in onclick
  const obsStore = [];
  // Exclude no-fill trades from display (same rule as computeStats)
  const displayTrades = filtered.filter(isExecuted);
  document.getElementById('trades-body').innerHTML=displayTrades.slice(0,50).map(t=>{
    const rr  = getRR(t);
    const res = (t[RES_COL]||'').toString().trim().toUpperCase();
    // Win determination: RES first, then RR sign
    const isW = res.includes('WIN') ? true : res.includes('LOSS') ? false : (rr !== null ? rr > 0 : false);
    const rrS = rr !== null ? (rr>0?'+':'')+rr.toFixed(2)+'R' : '—';
    const _fechaCol = resolveCol('Fecha');
    const _diaCol   = CMAP.dia; const _mesCol = CMAP.mes;
    const fecha = t[_fechaCol]||(t[_diaCol]&&t[_mesCol]?t[_diaCol]+'/'+t[_mesCol]:'')||'—';

    // Observation: try all known column names for "Observación"
    const _obsCol = resolveCol('Observación');
    const obsRaw = (
      t[_obsCol] || t['Observación'] || t['Observacion'] || t['Observaciones'] ||
      t['Obs'] || t['Notas'] || t['Notes'] || t['Nota'] ||
      t['Observación trade'] || t['observacion'] || ''
    ).toString().trim();

    // Summary: first 70 chars at word boundary, never cut mid-word
    function makeSummary(txt){
      if(!txt || txt.length <= 70) return txt || '—';
      const cut = txt.slice(0, 70);
      const lastSpace = cut.lastIndexOf(' ');
      return (lastSpace > 30 ? cut.slice(0, lastSpace) : cut) + '…';
    }

    const obsShort   = obsRaw ? makeSummary(obsRaw) : '—';
    const hasContent = obsRaw && obsRaw.length > 0;

    const obsIdx = obsStore.length;
    obsStore.push(obsRaw || '—');

    return `<div class="tr-row ${isW?'tw':'tl'}">
      <span class="tx-d">${fecha}</span>
      <span class="${isW?'tx-g':'tx-r'}">${isW?'WIN':'LOSS'}</span>
      <span class="${isW?'tx-g':'tx-r'}">${rrS}</span>
      <span class="obs-cell${hasContent?' obs-clickable':''}" ${hasContent?`onclick="openObsIdx(${obsIdx})" title="Click — ver observación completa"`:''}>${obsShort}</span>
    </div>`;
  }).join('');
  window._obsStore = obsStore;
}

