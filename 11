  index:   0,    // current position
};

function updateGallery(filteredTrades) {
  const gallery = document.getElementById('trade-gallery');
  if (!gallery) return;
  gallery.innerHTML = '';

  const imgCol = (dynState && dynState.imgCol) ? dynState.imgCol : 'Link Trade';

  // Build array of trades that have a valid image link
  agState.trades = filteredTrades.filter(t => {
    const l = (t[imgCol] || '').trim();
    return l !== '';
  });

  agState.trades.forEach((trade, index) => {
    const cleanLink = trade[imgCol].trim();

    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'width:200px;margin:10px;cursor:pointer;border-radius:8px;overflow:hidden;border:1px solid rgba(0,212,255,.12);transition:all .15s;';
    wrapper.onmouseenter = () => { wrapper.style.borderColor='rgba(0,212,255,.35)'; wrapper.style.transform='translateY(-2px)'; };
    wrapper.onmouseleave = () => { wrapper.style.borderColor='rgba(0,212,255,.12)'; wrapper.style.transform=''; };

    const img = document.createElement('img');
    img.src = cleanLink;
    img.style.cssText = 'width:100%;display:block;';
    img.onerror = () => { wrapper.style.display='none'; };

    wrapper.addEventListener('click', () => agOpen(index));
    wrapper.appendChild(img);
    gallery.appendChild(wrapper);
  });
}

function agOpen(index) {
  const m = document.getElementById('ag-modal');
  if (!m) return;
  agState.index = Math.max(0, Math.min(index, agState.trades.length - 1));
  agRender();
  m.classList.add('ag-open');
  document.body.style.overflow = 'hidden';
  document.addEventListener('keydown', agKeyNav);
}

function agRender() {
  const { trades, index } = agState;
  if (!trades.length) return;

  const trade   = trades[index];
  const imgCol  = (dynState && dynState.imgCol) ? dynState.imgCol : 'Link Trade';
  const imgEl   = document.getElementById('ag-img');
  const counter = document.getElementById('ag-counter');
  const imgSrc  = (trade[imgCol] || '').trim();

  console.log('[Gallery] Imagen actual índice:', index);
  console.log('[Gallery] Fila datos:', trade);
  const _obsColDbg = resolveCol('Observación');
  console.log('[Gallery] Observaciones:', trade[_obsColDbg] || trade['Observación'] || trade['Observacion'] || trade['Obs'] || '(vacío)');

  // Fade out → swap src → show only after fully loaded
  imgEl.classList.remove('visible');
  imgEl.classList.add('fading');

  setTimeout(() => {
    // Reset any previous inline size constraints before loading new src
    imgEl.style.maxWidth  = '';
    imgEl.style.maxHeight = '';
    imgEl.src = imgSrc;

    imgEl.onload = () => {
      const nw = imgEl.naturalWidth;
      const nh = imgEl.naturalHeight;
      console.log('[Gallery] SRC actual:', imgEl.src);
      console.log('[Gallery] Natural size:', nw, 'x', nh);
      console.log('[Gallery] Rendered size:', imgEl.clientWidth, 'x', imgEl.clientHeight);

      // Cap: never render beyond original resolution (prevents upscaling blur)
      if (imgEl.clientWidth > nw || imgEl.clientHeight > nh) {
        imgEl.style.maxWidth  = 'min(80vw, ' + nw + 'px)';
        imgEl.style.maxHeight = 'min(80vh, ' + nh + 'px)';
      }

      // Only reveal after image is fully decoded at correct size
      imgEl.classList.remove('fading');
      imgEl.classList.add('visible');
    };

    imgEl.onerror = () => {
      imgEl.classList.remove('fading');
      imgEl.classList.add('visible');
    };
  }, 120);

  // Counter
  if (counter) counter.textContent = `${index + 1} / ${trades.length}`;

  // Nav arrows
  const prev = document.getElementById('ag-prev');
  const next = document.getElementById('ag-next');
  if (prev) prev.style.opacity = index === 0 ? '.25' : '1';
  if (next) next.style.opacity = index === trades.length - 1 ? '.25' : '1';

  // ── Trade info ──────────────────────────────
  const fechaCol = resolveCol('Fecha');
  const fecha = trade[fechaCol]
    || (trade[CMAP.dia] && trade[CMAP.mes] ? trade[CMAP.dia]+'/'+trade[CMAP.mes] : '')
    || '—';
  const res   = (trade[RES_COL] || '').toString().trim().toUpperCase();
  const rr    = parseRR(trade[RR_COL]);
  const rrFmt = rr !== null ? (rr >= 0 ? '+' : '') + rr.toFixed(2) + 'R' : '—';
  const isWin = res.includes('WIN') ? true : res.includes('LOSS') ? false : (rr !== null ? rr > 0 : null);

  const fechaEl = document.getElementById('ag-fecha');
  const resEl   = document.getElementById('ag-res');
  const rrEl    = document.getElementById('ag-rr');
  if (fechaEl) fechaEl.textContent = fecha;
  if (resEl) {
    resEl.textContent = res || '—';
    resEl.className = 'ag-info-val' + (isWin === true ? ' win' : isWin === false ? ' loss' : '');
  }
  if (rrEl) {
    rrEl.textContent = rrFmt;
    rrEl.className = 'ag-info-val' + (rr !== null ? (rr >= 0 ? ' win' : ' loss') : '');
  }

  // ── Observaciones — mostrar texto COMPLETO ──
  const obsCol = resolveCol('Observación');
  // Try every possible column name
  const obs = (
    trade[obsCol] ||
    trade['Observación'] || trade['Observacion'] || trade['Observaciones'] ||
    trade['Obs'] || trade['Notas'] || trade['Notes'] || trade['Nota'] ||
    trade['Comentario'] || trade['Comentarios'] || trade['Comments'] || ''
  ).toString().trim();

  const obsWrap = document.getElementById('ag-obs-wrap');
  const obsText = document.getElementById('ag-obs-text');
  if (obsWrap && obsText) {
    if (obs) {
      obsWrap.style.display = 'block';
      obsText.textContent = obs;  // texto completo, sin colapsar
    } else {
      obsWrap.style.display = 'none';
      obsText.textContent = '';
    }
  }
}

function agNav(dir) {
  const { trades, index } = agState;
  const newIdx = index + dir;
  if (newIdx < 0 || newIdx >= trades.length) return;
  agState.index = newIdx;
  agRender();
}

// agToggleObs removed — observaciones siempre visibles completas

function agKeyNav(e) {
  if (e.key === 'ArrowRight') agNav(+1);
  else if (e.key === 'ArrowLeft') agNav(-1);
  else if (e.key === 'Escape') agClose();
}

function agClose(e) {
  const m = document.getElementById('ag-modal');
  if (!m) return;
  const closeBtn = document.getElementById('ag-close');
  if (!e || e.target === m || e.target === closeBtn) {
    m.classList.remove('ag-open');
    document.getElementById('ag-img').src = '';
    document.body.style.overflow = '';
    document.removeEventListener('keydown', agKeyNav);
  }
}

