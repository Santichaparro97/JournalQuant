//  DYNAMIC CHECKLIST + IMAGE COLUMN SYSTEM
//  State per category: dynState.cats.{tiempo,contexto,setup}
//  Image column: dynState.imgCol
// ══════════════════════════════════════════════

const dynState = {
  colCache: {},
  cats: { tiempo: [], contexto: [], setup: [] },
  imgCol:  'Link Trade',
  rrCol:   '',          // '' = auto-resolved by buildColResolver
  counter: 0,
};

// ── Memoised unique values ────────────────────
function dynGetVals(col){
  if(!csvData.length || !col) return [];
  if(dynState.colCache[col]) return dynState.colCache[col];
  const vals = [...new Set(csvData.map(r=>(r[col]||'').trim()).filter(Boolean))].sort((a,b)=>{
    const na=parseFloat(a), nb=parseFloat(b);
    return !isNaN(na)&&!isNaN(nb) ? na-nb : a.localeCompare(b);
  });
  dynState.colCache[col] = vals;
  return vals;
}

function dynGetAllCols(){
  return csvData.length ? Object.keys(csvData[0]) : [];
}

function dynBuildColOptions(el, selected){
  const cols = dynGetAllCols();
  el.innerHTML = '<option value="">— Columna —</option>';
  cols.forEach(c=>{
    const o = document.createElement('option');
    o.value = c; o.textContent = c;
    if(c === selected) o.selected = true;
    el.appendChild(o);
  });
}

// ── Show per-category buttons when CSV loaded ─
function dynShow(){
  const hasCsv = csvData.length > 0;
  ['tiempo','contexto','setup'].forEach(cat=>{
    const btn = document.getElementById('dyn-btn-'+cat);
    if(btn) btn.style.display = hasCsv ? 'inline-block' : 'none';
  });
  const imgBar = document.getElementById('dyn-img-bar');
  if(imgBar) imgBar.style.display = hasCsv ? 'flex' : 'none';
  const rrBar = document.getElementById('dyn-rr-bar');
  if(rrBar) rrBar.style.display = hasCsv ? 'flex' : 'none';
  if(hasCsv){ dynRefreshImgSel(); dynRefreshRRSel(); }
}

// ── Add a field row inside a specific category ─
function dynAddField(cat){
  if(!csvData.length || !dynState.cats[cat]) return;

  const list = document.getElementById('dyn-list-'+cat);
  if(!list) return;

  // ── STEP 1: temp column picker (disappears on selection) ──
  const picker = document.createElement('div');
  picker.className = 'frow';
  picker.style.cssText = 'margin-bottom:5px;';

  const colSel = document.createElement('select');
  colSel.className = 'dyn-col-sel';
  // Build options
  const cols = dynGetAllCols();
  colSel.innerHTML = '<option value="">Elegir columna…</option>';
  cols.forEach(c=>{
    const o = document.createElement('option');
    o.value = c; o.textContent = c;
    colSel.appendChild(o);
  });

  colSel.addEventListener('change', function(){
    const col = this.value;
    if(!col){ return; }

    // ── STEP 2: replace picker with native frow block ──
    const id = 'dyn-f-' + (++dynState.counter);
    dynState.cats[cat].push({ id, col, value:'' });

    const block = document.createElement('div');
    block.className = 'frow';
    block.id = id;
    block.style.cssText = 'margin-bottom:5px;position:relative;';

    // Label row: column name + remove button
    const labelRow = document.createElement('div');
    labelRow.style.cssText = 'display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;';

    const lbl = document.createElement('label');
    lbl.textContent = col;
    lbl.style.cssText = 'margin-bottom:0;flex:1;';

    const rmBtn = document.createElement('button');
    rmBtn.textContent = '×';
    rmBtn.title = 'Eliminar';
    rmBtn.style.cssText = [
      'background:none','border:none','color:var(--t3)',
      'font-size:12px','font-weight:800','cursor:pointer',
      'line-height:1','padding:0 2px','transition:color .12s',
      'flex-shrink:0',
    ].join(';');
    rmBtn.onmouseover = ()=>{ rmBtn.style.color='var(--red2)'; };
    rmBtn.onmouseout  = ()=>{ rmBtn.style.color='var(--t3)'; };
    rmBtn.addEventListener('click', ()=>dynRemoveField(id, cat));

    labelRow.appendChild(lbl);
    labelRow.appendChild(rmBtn);

    // Value select — same style as native selects
    const valSel = document.createElement('select');
    valSel.style.cssText = 'width:100%;';
    valSel.className = 'frow-dyn-val';
    // Populate values
    const vals = dynGetVals(col);
    valSel.innerHTML = '<option value="">— Todos —</option>';
    vals.forEach(v=>{
      const o = document.createElement('option');
      o.value = v; o.textContent = v;
      valSel.appendChild(o);
    });
    valSel.addEventListener('change', function(){
      const field = dynState.cats[cat].find(f=>f.id===id);
      if(field) field.value = this.value;
      // Mirror native active class
      this.classList.toggle('active', !!this.value);
      if(csvData.length) runAnalysis();
    });

    block.appendChild(labelRow);
    block.appendChild(valSel);

    // Replace picker with final block
    list.replaceChild(block, picker);
    updateFCCount();
    // Trigger analysis if a value was pre-set (none here, but consistent)
    if(csvData.length) runAnalysis();
  });

  picker.appendChild(colSel);
  list.appendChild(picker);
  // Focus the picker immediately
  setTimeout(()=>colSel.focus(), 0);
}

function dynRefreshValSel(valSel, col){
  const vals = dynGetVals(col);
  valSel.innerHTML = '<option value="">— Todos —</option>';
  vals.forEach(v=>{
    const o = document.createElement('option');
    o.value = v; o.textContent = v;
    valSel.appendChild(o);
  });
  valSel.classList.remove('active');
}

function dynRemoveField(id, cat){
  if(dynState.cats[cat])
    dynState.cats[cat] = dynState.cats[cat].filter(f=>f.id!==id);
  const row = document.getElementById(id);
  if(row) row.remove();
  if(csvData.length) runAnalysis();
  updateFCCount();
}

// ── Image column selector ─────────────────────
function dynRefreshImgSel(){
  const sel = document.getElementById('dyn-img-sel');
  if(!sel) return;
  const prev = dynState.imgCol;
  dynBuildColOptions(sel, prev);
  const none = document.createElement('option');
  none.value=''; none.textContent='— Ninguna —';
  sel.insertBefore(none, sel.firstChild);
  sel.value = prev || '';
}

function dynImgColChange(col){
  dynState.imgCol = col || resolveCol('Link Trade') || 'Link Trade';
  if(csvData.length) runAnalysis();
}

// ── RR column selector ────────────────────────
function dynRefreshRRSel(){
  const sel = document.getElementById('dyn-rr-sel');
  if(!sel) return;
  const prev = dynState.rrCol || RR_COL;
  // Rebuild options from all CSV columns
  const cols = dynGetAllCols();
  sel.innerHTML = '<option value="">— Auto —</option>';
  cols.forEach(c=>{
    const o = document.createElement('option');
    o.value = c; o.textContent = c;
    if(c === prev) o.selected = true;
    sel.appendChild(o);
  });
  // Pre-select auto-resolved column
  if(!dynState.rrCol && RR_COL){
    sel.value = RR_COL;
  }
}

function dynRRColChange(col){
  // '' means auto — use whatever resolveCol found
  dynState.rrCol = col;
  // Override RR_COL globally so all calculations use this column
  RR_COL = col || getRRCol();
  // Debug: show first 5 parsed values
  if(csvData.length){
    const sample = csvData.slice(0,5).map(t=>{
      const raw = t[RR_COL];
      return { raw, parsed: parseRR(raw) };
    });
  }
  if(csvData.length) runAnalysis();
}

// ── Apply all dynamic filters (all categories) ─
function dynApplyFilters(trades){
  const allFields = [
    ...dynState.cats.tiempo,
    ...dynState.cats.contexto,
    ...dynState.cats.setup,
  ].filter(f=>f.col && f.value);
  if(!allFields.length) return trades;
  return trades.filter(row=>{
    return allFields.every(f=>{
      const cell = (row[f.col]||'').toString().trim().toUpperCase();
      return cell === f.value.toUpperCase();
    });
  });
}

// ── Reset on CSV reload ───────────────────────
function dynReset(){
  dynState.colCache = {};
  dynState.cats     = { tiempo: [], contexto: [], setup: [] };
  dynState.imgCol   = resolveCol('Link Trade') || 'Link Trade';
  dynState.rrCol    = '';   // '' = use auto-resolved RR_COL
  dynState.counter  = 0;
  ['tiempo','contexto','setup'].forEach(cat=>{
    const list = document.getElementById('dyn-list-'+cat);
    if(list) list.innerHTML = '';
  });
  dynShow();
  dynRefreshImgSel();
  dynRefreshRRSel();
  const imgSel = document.getElementById('dyn-img-sel');
  if(imgSel) imgSel.value = dynState.imgCol;
}

